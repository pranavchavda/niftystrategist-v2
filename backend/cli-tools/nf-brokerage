#!/usr/bin/env python3
"""Pre-trade brokerage and charges estimate."""

import argparse
import sys
import os

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import format_inr, init_client, print_error, print_json, run_async, validate_symbol  # noqa: E402


def show_brokerage(symbol: str, quantity: int, side: str, product: str,
                   price: float, as_json: bool):
    """Show brokerage estimate for a trade."""
    client = init_client()
    try:
        result = run_async(client.get_brokerage(
            symbol=symbol,
            quantity=quantity,
            transaction_type=side,
            product=product,
            price=price,
        ))
    except Exception as e:
        print_error(f"Failed to get brokerage: {e}")

    if as_json:
        print_json(result)
        return

    trade_price = result.get("price", price)
    trade_value = trade_price * quantity

    print(f"💰 Brokerage Estimate\n")
    print(f"  {side} {quantity} × {symbol} @ {format_inr(trade_price)}")
    print(f"  Product: {'Delivery' if product == 'D' else 'Intraday'}")
    print(f"  Trade Value: {format_inr(trade_value)}")

    # Navigate nested charges structure (API returns {charges: {total, brokerage, taxes, ...}})
    charges = result.get("charges", result)  # May be nested or flat
    if isinstance(charges, dict) and "total" in charges:
        data = charges
    else:
        data = result

    brokerage = data.get("brokerage")
    total = data.get("total")

    if brokerage is not None:
        print(f"\n  Brokerage:            {format_inr(brokerage)}")

    # Taxes
    taxes = data.get("taxes", {})
    if taxes and isinstance(taxes, dict):
        for label, value in taxes.items():
            if value is not None:
                display = label.replace("_", " ").upper()
                print(f"  {display:<24}{format_inr(value)}")

    # Other charges
    other = data.get("other_taxes", {}) or data.get("other_charges", {})
    if other and isinstance(other, dict):
        for label, value in other.items():
            if value is not None:
                display = label.replace("_", " ").title()
                print(f"  {display:<24}{format_inr(value)}")

    # DP plan
    dp_plan = data.get("dp_plan", {})
    if isinstance(dp_plan, dict) and dp_plan.get("name"):
        dp_label = f"DP ({dp_plan['name']})"
        print(f"  {dp_label:<24}{format_inr(dp_plan.get('min_expense', 0))}")

    if total is not None:
        print(f"\n  ── Total Charges:     {format_inr(total)}")
        pct = (total / trade_value * 100) if trade_value > 0 else 0
        print(f"  ── As % of Trade:     {pct:.4f}%")


def main():
    parser = argparse.ArgumentParser(
        prog="nf-brokerage",
        description="Pre-trade brokerage and charges estimate",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  nf-brokerage RELIANCE 10                   Buy 10 shares (delivery, market price)
  nf-brokerage RELIANCE 10 --side SELL       Sell estimate
  nf-brokerage INFY 50 --product I           Intraday estimate
  nf-brokerage TCS 5 --price 3500            At specific price
  nf-brokerage RELIANCE 10 --json            JSON output
""",
    )
    parser.add_argument("symbol", help="Stock symbol")
    parser.add_argument("quantity", type=int, help="Number of shares")
    parser.add_argument("--side", default="BUY", choices=["BUY", "SELL"], help="Transaction type (default: BUY)")
    parser.add_argument("--product", default="D", choices=["D", "I"], help="D=Delivery, I=Intraday (default: D)")
    parser.add_argument("--price", type=float, default=0, help="Limit price (0 = use current market price)")
    parser.add_argument("--json", action="store_true", help="Output as JSON")

    args = parser.parse_args()
    symbol = validate_symbol(args.symbol)
    show_brokerage(symbol, args.quantity, args.side, args.product, args.price, args.json)


if __name__ == "__main__":
    main()
