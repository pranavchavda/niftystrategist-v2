def _fmt_time(hour, minute):
    h = hour % 12 or 12
    ampm = "AM" if hour < 12 else "PM"
    return f"{h}:{minute:02d} {ampm}"


def cmd_schedules_list(args):
    """List recurring awakening schedules."""
    from database.session import get_db_context
    from database.models import UserAwakeningSchedule
    from sqlalchemy import select

    user_id = _get_user_id()

    async def _list():
        async with get_db_context() as session:
            result = await session.execute(
                select(UserAwakeningSchedule)
                .where(UserAwakeningSchedule.user_id == user_id)
                .order_by(UserAwakeningSchedule.cron_hour, UserAwakeningSchedule.cron_minute)
            )
            return list(result.scalars().all())

    schedules = run_async(_list())

    if args.json:
        print_json({
            "schedules": [
                {"id": s.id, "name": s.name, "enabled": s.enabled,
                 "time_ist": f"{s.cron_hour:02d}:{s.cron_minute:02d}",
                 "weekdays_only": s.weekdays_only, "run_count": s.run_count,
                 "last_run_at": s.last_run_at.isoformat() if s.last_run_at else None,
                 "last_error": s.last_error,
                 "prompt": s.prompt}
                for s in schedules
            ],
            "count": len(schedules),
        })
        return

    if not schedules:
        print("No recurring awakening schedules configured.")
        print("Use: nf-mandate schedules add --name 'Morning Scan' --time 09:20 --prompt '...'")
        return

    print(f"Recurring Awakening Schedules ({len(schedules)})\n")
    for s in schedules:
        status = "ON " if s.enabled else "OFF"
        icon = "✓" if s.enabled else "✗"
        days = "Mon-Fri" if s.weekdays_only else "Daily"
        print(f"  #{s.id}  [{icon} {status}]  {s.name:<25}  {_fmt_time(s.cron_hour, s.cron_minute)} IST  {days}  ({s.run_count} runs)")
        if s.last_error:
            print(f"     ⚠ Last error: {s.last_error[:80]}")


def cmd_schedules_add(args):
    """Add a new awakening schedule."""
    from database.session import get_db_context
    from services.awakening_scheduler import create_schedule

    user_id = _get_user_id()

    # Parse time
    parts = args.time.split(":")
    if len(parts) != 2:
        print_error("Time must be HH:MM format (IST), e.g., 09:20")
    try:
        hour, minute = int(parts[0]), int(parts[1])
        if not (0 <= hour <= 23 and 0 <= minute <= 59):
            raise ValueError
    except ValueError:
        print_error("Invalid time. Use HH:MM (24h IST), e.g., 09:20 or 15:45")

    async def _add():
        async with get_db_context() as session:
            return await create_schedule(
                session,
                user_id=user_id,
                name=args.name,
                cron_hour=hour,
                cron_minute=minute,
                prompt=args.prompt,
                enabled=not args.disabled,
                weekdays_only=not args.include_weekends,
                timeout_seconds=args.timeout,
            )

    try:
        schedule = run_async(_add())
    except Exception as e:
        if "unique" in str(e).lower():
            print_error(f"Schedule '{args.name}' already exists")
        raise

    # Notify scheduler
    try:
        _notify_scheduler_update(schedule)
    except Exception:
        pass

    if args.json:
        print_json({"id": schedule.id, "name": schedule.name,
                     "time_ist": f"{hour:02d}:{minute:02d}", "enabled": schedule.enabled})
    else:
        status = "enabled" if schedule.enabled else "disabled"
        print_success(f"Schedule '{schedule.name}' added at {_fmt_time(hour, minute)} IST ({status})")


def cmd_schedules_remove(args):
    """Remove an awakening schedule."""
    from database.session import get_db_context
    from services.awakening_scheduler import delete_schedule

    user_id = _get_user_id()

    async def _remove():
        async with get_db_context() as session:
            return await delete_schedule(session, args.schedule_id, user_id)

    deleted = run_async(_remove())

    if not deleted:
        print_error(f"Schedule #{args.schedule_id} not found")

    if args.json:
        print_json({"deleted": True, "id": args.schedule_id})
    else:
        print_success(f"Schedule #{args.schedule_id} deleted")


def cmd_schedules_toggle(args):
    """Enable or disable an awakening schedule."""
    from database.session import get_db_context
    from services.awakening_scheduler import update_schedule

    user_id = _get_user_id()
    enable = args.action == "enable"

    async def _toggle():
        async with get_db_context() as session:
            return await update_schedule(session, args.schedule_id, user_id, enabled=enable)

    schedule = run_async(_toggle())

    if not schedule:
        print_error(f"Schedule #{args.schedule_id} not found")

    try:
        _notify_scheduler_update(schedule)
    except Exception:
        pass

    if args.json:
        print_json({"id": schedule.id, "name": schedule.name, "enabled": schedule.enabled})
    else:
        state = "enabled" if enable else "disabled"
        print_success(f"Schedule '{schedule.name}' {state}")


def _notify_scheduler_update(schedule):
    """Best-effort notify the running scheduler about a schedule change."""
    # This only works when called from the FastAPI process (same scheduler instance).
    # From CLI, the scheduler is in a different process — changes take effect on next restart.
    try:
        from services.scheduler import get_scheduler
        sched = get_scheduler()
        if sched:
            import asyncio
            asyncio.run(sched.add_or_update_awakening(schedule))
    except Exception:
        pass


def main():
    parser = argparse.ArgumentParser(
        prog="nf-mandate",
        description="View and manage trading mandate and awakening schedules",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  nf-mandate show                                      Show current mandate
  nf-mandate set --risk-per-trade "₹5,000"             Set risk per trade
  nf-mandate clear                                     Remove mandate

  nf-mandate followup schedule --thread-id THREAD \\
      --delay "2h" --prompt "Check RELIANCE position"   One-shot in-thread followup
  nf-mandate followup list                              List pending followups
  nf-mandate followup cancel 666                        Cancel a followup

  nf-mandate schedules list                             List awakening schedules
  nf-mandate schedules add --name "Morning Scan" \\
      --time 09:20 --prompt "Run morning scan..."       Add schedule
  nf-mandate schedules enable 3                         Enable schedule #3
  nf-mandate schedules disable 3                        Disable schedule #3
  nf-mandate schedules remove 3                         Delete schedule #3
""",
    )
    sub = parser.add_subparsers(dest="command")

    # show
    p_show = sub.add_parser("show", help="Show current trading mandate")
    p_show.add_argument("--json", action="store_true", help="JSON output")

    # set
    p_set = sub.add_parser("set", help="Set or update trading mandate")
    p_set.add_argument("--risk-per-trade", help="Max risk per trade (e.g., '₹5,000')")
    p_set.add_argument("--daily-loss-cap", help="Max daily loss (e.g., '₹10,000')")
    p_set.add_argument("--allowed-instruments", help="Allowed instruments")
    p_set.add_argument("--cutoff-time", help="Stop new trades after this time (e.g., '3:00 PM IST')")
    p_set.add_argument("--auto-squareoff-time", help="Auto-squareoff time (e.g., '3:15 PM IST')")
    p_set.add_argument("--custom-instructions", help="Free-form trading instructions for awakenings")
    p_set.add_argument("--json", action="store_true", help="JSON output")

    # clear
    p_clear = sub.add_parser("clear", help="Clear trading mandate")
    p_clear.add_argument("--json", action="store_true", help="JSON output")

    # followup (with sub-subcommands)
    p_fu = sub.add_parser("followup", help="Manage one-shot follow-ups")
    fu_sub = p_fu.add_subparsers(dest="followup_action")

    # followup schedule (default when --thread-id is given)
    p_fu_sched = fu_sub.add_parser("schedule", help="Schedule a follow-up in a thread")
    p_fu_sched.add_argument("--thread-id", required=True, help="Thread ID to follow up in")
    p_fu_sched.add_argument("--delay", required=True, help='Delay: "2 hours", "1 day", "30 minutes"')
    p_fu_sched.add_argument("--prompt", required=True, help="Task to execute when awakened")
    p_fu_sched.add_argument("--user-id", default=None, help="User ID or email (defaults to NF_USER_ID)")
    p_fu_sched.add_argument("--name", default=None, help="Workflow name (auto-generated if omitted)")
    p_fu_sched.add_argument("--timeout", type=int, default=900, help="Timeout in seconds (default: 900)")
    p_fu_sched.add_argument("--json", action="store_true", help="JSON output")

    # followup list
    p_fu_list = fu_sub.add_parser("list", help="List pending one-shot followups")
    p_fu_list.add_argument("--limit", type=int, default=20, help="Max results (default: 20)")
    p_fu_list.add_argument("--json", action="store_true", help="JSON output")

    # followup cancel
    p_fu_cancel = fu_sub.add_parser("cancel", help="Cancel a followup")
    p_fu_cancel.add_argument("followup_id", type=int, help="Workflow definition ID to cancel")
    p_fu_cancel.add_argument("--json", action="store_true", help="JSON output")

    # schedules (with sub-subcommands)
    p_sched = sub.add_parser("schedules", help="Manage awakening schedules")
    sched_sub = p_sched.add_subparsers(dest="sched_command")

    # schedules list
    p_sl = sched_sub.add_parser("list", help="List awakening schedules")
    p_sl.add_argument("--json", action="store_true", help="JSON output")

    # schedules add
    p_sa = sched_sub.add_parser("add", help="Add awakening schedule")
    p_sa.add_argument("--name", required=True, help="Schedule name (e.g., 'Morning Scan')")
    p_sa.add_argument("--time", required=True, help="Time in IST HH:MM (e.g., 09:20)")
    p_sa.add_argument("--prompt", required=True, help="Task prompt for the orchestrator")
    p_sa.add_argument("--disabled", action="store_true", help="Create as disabled")
    p_sa.add_argument("--include-weekends", action="store_true", help="Run on weekends too")
    p_sa.add_argument("--timeout", type=int, default=600, help="Timeout in seconds (default: 600)")
    p_sa.add_argument("--json", action="store_true", help="JSON output")

    # schedules remove
    p_sr = sched_sub.add_parser("remove", help="Remove awakening schedule")
    p_sr.add_argument("schedule_id", type=int, help="Schedule ID to remove")
    p_sr.add_argument("--json", action="store_true", help="JSON output")

    # schedules enable
    p_se = sched_sub.add_parser("enable", help="Enable awakening schedule")
    p_se.add_argument("schedule_id", type=int, help="Schedule ID to enable")
    p_se.add_argument("--json", action="store_true", help="JSON output")

    # schedules disable
    p_sd = sched_sub.add_parser("disable", help="Disable awakening schedule")
    p_sd.add_argument("schedule_id", type=int, help="Schedule ID to disable")
    p_sd.add_argument("--json", action="store_true", help="JSON output")

    args = parser.parse_args()

    if args.command == "show":
        cmd_show(args)
    elif args.command == "set":
        cmd_set(args)
    elif args.command == "clear":
        cmd_clear(args)
    elif args.command == "followup":
        cmd_followup(args)
    elif args.command == "schedules":
        if args.sched_command == "list":
            cmd_schedules_list(args)
        elif args.sched_command == "add":
            cmd_schedules_add(args)
        elif args.sched_command == "remove":
            cmd_schedules_remove(args)
        elif args.sched_command in ("enable", "disable"):
            args.action = args.sched_command
            cmd_schedules_toggle(args)
        else:
            # Default: list
            args.json = False
            cmd_schedules_list(args)
    else:
        # Default to show
        args.json = False
        cmd_show(args)


if __name__ == "__main__":
    main()
