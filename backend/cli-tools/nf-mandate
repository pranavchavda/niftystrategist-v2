def cmd_followup(args):
    """Dispatch followup subcommands: schedule (default), list, cancel."""
    if args.followup_action == "list":
        cmd_followup_list(args)
    elif args.followup_action == "cancel":
        cmd_followup_cancel(args)
    else:
        cmd_followup_schedule(args)


def cmd_followup_schedule(args):
    """Schedule a one-shot follow-up in a specific thread."""
    sys.path.insert(0, os.path.join(_backend_dir, "cli-tools"))
    from automations.schedule_followup import parse_delay, insert_workflow, activate_workflow, resolve_user_id

    user_id_raw = args.user_id or os.environ.get("NF_USER_ID", "999")

    async def _followup():
        user_id = await resolve_user_id(str(user_id_raw))

        delta = parse_delay(args.delay)
        from datetime import timezone
        scheduled_at = datetime.now(timezone.utc).replace(tzinfo=None) + delta

        name = args.name or f"Follow up: {args.prompt[:80]}"

        result = await insert_workflow(
            thread_id=args.thread_id,
            user_id=user_id,
            prompt=args.prompt,
            scheduled_at=scheduled_at,
            name=name[:100],
            agent_hint=None,
            timeout=args.timeout,
        )

        # Poke the scheduler
        activation = await activate_workflow(result["workflow_id"], None)

        output = {
            "status": "scheduled",
            "workflow_id": result["workflow_id"],
            "name": result["name"],
            "thread_id": args.thread_id,
            "scheduled_at": result["scheduled_at"],
            "delay": args.delay,
            "message": f"Follow-up scheduled for {result['scheduled_at']} (in {args.delay})",
        }
        if activation and "activation_error" in activation:
            output["activation_warning"] = activation["activation_error"]
        elif activation:
            output["activation"] = "ok"
        return output

    try:
        result = run_async(_followup())
    except ValueError as e:
        print_error(str(e))
    except Exception as e:
        print_error(f"Failed to schedule follow-up: {e}")

    if args.json:
        print_json(result)
    else:
        print_success(result["message"])
        print(f"  Workflow ID: {result['workflow_id']}")
        print(f"  Thread: {result['thread_id']}")
        if result.get("activation_warning"):
            print(f"  ⚠ Activation: {result['activation_warning']}")


def cmd_followup_list(args):
    """List pending one-shot followups."""
    from database.session import get_db_context
    from sqlalchemy import text

    user_id = _get_user_id()

    async def _list():
        async with get_db_context() as session:
            r = await session.execute(text(
                "SELECT id, name, enabled, scheduled_at, thread_id, last_run_at, run_count, prompt "
                "FROM workflow_definitions "
                "WHERE user_id = :user_id AND frequency = 'once' "
                "ORDER BY scheduled_at DESC LIMIT :limit"
            ), {"user_id": user_id, "limit": args.limit})
            return [
                {"id": row[0], "name": row[1], "enabled": row[2],
                 "scheduled_at": row[3].isoformat() if row[3] else None,
                 "thread_id": row[4],
                 "last_run_at": row[5].isoformat() if row[5] else None,
                 "run_count": row[6],
                 "prompt": (row[7][:150] + "...") if row[7] and len(row[7]) > 150 else row[7]}
                for row in r.fetchall()
            ]

    followups = run_async(_list())

    if args.json:
        print_json({"followups": followups, "count": len(followups)})
        return

    if not followups:
        print("No one-shot followups found.")
        return

    print(f"One-Shot Followups ({len(followups)})\n")
    for f in followups:
        status = "PENDING" if f["enabled"] and f["run_count"] == 0 else "DONE" if f["run_count"] > 0 else "OFF"
        icon = "⏳" if status == "PENDING" else "✓" if status == "DONE" else "✗"
        print(f"  #{f['id']}  [{icon} {status}]  {(f['name'] or '(unnamed)')[:40]}")
        print(f"     Scheduled: {f['scheduled_at'] or '—'}")
        if f.get("thread_id"):
            print(f"     Thread: {f['thread_id']}")
        print()


def cmd_followup_cancel(args):
    """Cancel (delete) a one-shot followup."""
    from database.session import get_db_context
    from sqlalchemy import text

    user_id = _get_user_id()

    async def _cancel():
        async with get_db_context() as session:
            # Verify ownership and that it's a one-shot
            r = await session.execute(text(
                "SELECT id, name FROM workflow_definitions "
                "WHERE id = :id AND user_id = :user_id"
            ), {"id": args.followup_id, "user_id": user_id})
            row = r.fetchone()
            if not row:
                return None

            # Delete it
            await session.execute(text(
                "DELETE FROM workflow_definitions WHERE id = :id AND user_id = :user_id"
            ), {"id": args.followup_id, "user_id": user_id})
            await session.commit()

            # Remove from scheduler
            try:
                from services.scheduler import get_scheduler
                sched = get_scheduler()
                if sched:
                    job_id = f"custom_workflow_{args.followup_id}"
                    if sched.scheduler.get_job(job_id):
                        sched.scheduler.remove_job(job_id)
            except Exception:
                pass

            return {"id": row[0], "name": row[1]}

    result = run_async(_cancel())

    if result is None:
        print_error(f"Followup #{args.followup_id} not found for user {user_id}")

    if args.json:
        print_json({"deleted": True, **result})
    else:
        print_success(f"Followup #{result['id']} '{result['name']}' cancelled")


