#!/usr/bin/env python3
"""View and manage the user's trading mandate for autonomous awakenings.

The mandate defines risk boundaries that recurring awakenings operate within:
risk per trade, daily loss cap, allowed instruments, cutoff time, etc.
"""

import argparse
import sys
import os
from datetime import datetime

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import print_error, print_json, print_success, run_async  # noqa: E402


def _get_user_id() -> int:
    return int(os.environ.get("NF_USER_ID", "999"))


def cmd_show(args):
    """Show the current trading mandate."""
    from database.session import get_db_context
    from database.models import User

    user_id = _get_user_id()

    async def _show():
        async with get_db_context() as session:
            user = await session.get(User, user_id)
            if not user:
                print_error(f"User {user_id} not found")
            return user.trading_mandate

    mandate = run_async(_show())

    if args.json:
        print_json({"mandate": mandate})
        return

    if not mandate:
        print("No trading mandate configured.")
        print("Use: nf-mandate set --risk-per-trade '₹5,000' --daily-loss-cap '₹10,000' ...")
        return

    print("📋 Trading Mandate\n")
    fields = [
        ("Risk per trade", "risk_per_trade"),
        ("Daily loss cap", "daily_loss_cap"),
        ("Allowed instruments", "allowed_instruments"),
        ("Cutoff time", "cutoff_time"),
        ("Auto-squareoff", "auto_squareoff_time"),
        ("Approved at", "approved_at"),
    ]
    for label, key in fields:
        value = mandate.get(key)
        if value:
            print(f"  {label}: {value}")

    custom = mandate.get("custom_instructions")
    if custom:
        print(f"\n  Custom Instructions:\n    {custom}")


def cmd_set(args):
    """Set or update the trading mandate."""
    from database.session import get_db_context
    from database.models import User, utc_now

    user_id = _get_user_id()

    # Build mandate from args
    updates = {}
    if args.risk_per_trade:
        updates["risk_per_trade"] = args.risk_per_trade
    if args.daily_loss_cap:
        updates["daily_loss_cap"] = args.daily_loss_cap
    if args.allowed_instruments:
        updates["allowed_instruments"] = args.allowed_instruments
    if args.cutoff_time:
        updates["cutoff_time"] = args.cutoff_time
    if args.auto_squareoff_time:
        updates["auto_squareoff_time"] = args.auto_squareoff_time
    if args.custom_instructions:
        updates["custom_instructions"] = args.custom_instructions

    if not updates:
        print_error("No fields provided. Use --risk-per-trade, --daily-loss-cap, etc.")

    async def _set():
        async with get_db_context() as session:
            user = await session.get(User, user_id)
            if not user:
                print_error(f"User {user_id} not found")

            # Merge with existing mandate (update, don't replace)
            mandate = user.trading_mandate or {}
            mandate.update(updates)
            mandate["approved_at"] = utc_now().isoformat()
            user.trading_mandate = mandate
            await session.commit()
            return mandate

    mandate = run_async(_set())

    if args.json:
        print_json({"mandate": mandate})
    else:
        print_success("Trading mandate updated")
        for key, value in updates.items():
            label = key.replace("_", " ").title()
            print(f"  {label}: {value}")


def cmd_clear(args):
    """Clear the trading mandate."""
    from database.session import get_db_context
    from database.models import User

    user_id = _get_user_id()

    async def _clear():
        async with get_db_context() as session:
            user = await session.get(User, user_id)
            if not user:
                print_error(f"User {user_id} not found")
            user.trading_mandate = None
            await session.commit()

    run_async(_clear())

    if args.json:
        print_json({"mandate": None})
    else:
        print_success("Trading mandate cleared")


