#!/usr/bin/env python3
"""nf-backtest-matrix — multi-axis backtest sweep with statistical ranking.

Runs a *grid* of scalp combos — (primary × confirm × interval × exit-variant ×
side) — against each symbol over a recent window, then ranks survivors with a
three-layer "best" definition that's honest about overfitting:

  1. HARD GATES   — too few trades / plausibility red flags / single-trade
                    dominance / a day the live force-squareoff would have
                    truncated / non-positive net. Fail any → dropped.
  2. SCORE        — t-stat of per-trade NET P&L (signal-to-noise), with day
                    consistency reported alongside (not collapsed into one number).
  3. WALK-FORWARD — select on the earlier ~2/3 of trading days, CONFIRM on the
                    held-out last ~1/3. The headline ₹/day is the OUT-OF-SAMPLE
                    validation figure, never the in-sample one.

This is a grid generalization of ``nf-backtest-scan`` (which ranks one indicator
per stock, in-sample). It runs the backtests in-process via the same engine
(``run_scalp_equity_backtest``), warm-up-faithful, fetching each (symbol, interval)
once. All the machinery lives in ``backtesting/sweep.py`` + ``backtesting/ranking.py``
so it's unit-tested without the network.

Usage examples:

  # Two symbols, solo primaries, one interval, JSON
  nf-backtest-matrix --symbols RELIANCE,INFY --days 15 --json

  # Add confirm pairs + a trail-percent grid, top-10 nifty50 morning-scan picks
  nf-backtest-matrix --universe nifty50 --top 10 --confirms all \\
      --trail-grid 0.8,1.0,1.2 --daily-loss-cap 5000

  # Long-only, RSI-confirmed UTBot/EMA only, 5+15min
  nf-backtest-matrix --symbols TCS --primaries utbot,ema_crossover \\
      --confirms macd --intervals 5minute,15minute --entry-side long

  # Regime-gate experiment: ungated baseline + all 3 daily-trend gates, 15min
  nf-backtest-matrix --symbols TECHM,SBIN --intervals 15minute --htf-gates all
"""
from __future__ import annotations

import argparse
import asyncio
import json
import os
import subprocess
import sys
from datetime import date

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import (  # noqa: E402
    init_market_data_client,
    print_error,
    print_json,
    run_async,
)
from backtesting.htf_trend import HTF_VARIANTS  # noqa: E402
from backtesting.sweep import (  # noqa: E402
    ALL_INDICATORS,
    _INTERVAL_TO_TIMEFRAME,
    assemble_symbol,
    expand_grid,
    sweep_symbol,
)

# Above this many engine runs, require --yes (or abort) — a runaway grid can
# spawn tens of thousands of backtests and saturate the box.
_RUN_COUNT_GUARD = 5000

# Human-readable labels for the categories ``ranking.gate_summary`` emits.
_GATE_CATEGORY_LABELS = {
    "net_pnl<=0": "unprofitable net",
    "single_trade_dominance": "single-trade dominance",
    "min_trades": "too few trades",
    "plausibility": "plausibility flag",
    "daily_loss_cap": "daily loss cap",
}


# ---------------------------------------------------------------------------
# Side handling (mirrors nf-backtest-scan)
# ---------------------------------------------------------------------------

def _sides_for(entry_side: str) -> list[str]:
    """Which entry sides to sweep per combo.

    ``auto`` (default) sweeps long-only AND short-only as separate combos, so the
    reported stats match the directional config that would be deployed. ``both``
    runs a combined long+short config. ``long``/``short`` force one side.
    """
    if entry_side == "auto":
        return ["long", "short"]
    if entry_side == "both":
        return ["both"]
    return [entry_side]


# ---------------------------------------------------------------------------
# Exit-variant grid (Cartesian of the SL / target / trail sweeps)
# ---------------------------------------------------------------------------

def _parse_float_list(raw: str | None) -> list[float | None]:
    """Parse a comma list of floats; ``None`` raw → ``[None]`` (engine default)."""
    if not raw:
        return [None]
    out: list[float | None] = []
    for part in raw.split(","):
        part = part.strip()
        if not part or part.lower() == "none":
            out.append(None)
        else:
            out.append(float(part))
    return out


def _build_exit_variants(args: argparse.Namespace) -> list[dict]:
    """Cartesian product of the trail/sl/target grids → exit-variant dicts."""
    variants = []
    for trail in _parse_float_list(args.trail_grid):
        for sl in _parse_float_list(args.sl_grid):
            for tgt in _parse_float_list(args.target_grid):
                variants.append({
                    "trail_percent": trail,
                    "sl_points": sl,
                    "target_points": tgt,
                })
    return variants


# ---------------------------------------------------------------------------
# Candidate sourcing (reuses the morning-scan subprocess, like nf-backtest-scan)
# ---------------------------------------------------------------------------

def _get_candidates_from_scan(universe: str, top: int, verbose: bool) -> list[dict]:
    """Run nf-morning-scan --json and return [{symbol, score}, ...]."""
    scan_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "nf-morning-scan")
    cmd = [sys.executable, scan_path, "--universe", universe, "--top", str(top), "--json"]
    if verbose:
        print(f"  running morning scan: {' '.join(cmd)}", file=sys.stderr)
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
    except subprocess.TimeoutExpired:
        print_error("morning scan timed out after 300s")
        return []
    if proc.returncode != 0:
        print_error(f"morning scan failed (exit {proc.returncode}): {proc.stderr[-500:]}")
        return []
    try:
        data = json.loads(proc.stdout)
    except json.JSONDecodeError:
        print_error("morning scan returned non-JSON output")
        return []
    return [{"symbol": c["symbol"], "score": c.get("score")}
            for c in data.get("candidates", [])[:top]]


# ---------------------------------------------------------------------------
# Output formatting (mirrors nf-backtest-scan's _format_human)
# Per-symbol assembly (gates → plateau → ranking) lives in sweep.assemble_symbol.
# ---------------------------------------------------------------------------

def _gate_summary_phrase(summary: dict, top_n: int = 3) -> str:
    """Render the top gate-reason categories as a compact human phrase, e.g.
    "13 unprofitable net, 4 single-trade dominance, 3 too few trades"."""
    parts = [
        f"{n} {_GATE_CATEGORY_LABELS.get(cat, cat)}"
        for cat, n in list(summary.items())[:top_n]
    ]
    return ", ".join(parts)


def _truncate(s: str, width: int = 72) -> str:
    """Trim a verbose gate reason to one compact line."""
    return s if len(s) <= width else s[: width - 1] + "…"

def _combo_label(r: dict) -> str:
    confirm = f"+{r['confirm']}" if r.get("confirm") else ""
    exits = []
    if r.get("trail_percent") is not None:
        exits.append(f"trail{r['trail_percent']}")
    if r.get("sl_points") is not None:
        exits.append(f"sl{r['sl_points']}")
    if r.get("target_points") is not None:
        exits.append(f"tgt{r['target_points']}")
    exit_s = (" " + "/".join(exits)) if exits else ""
    gate_s = f", gate={r['htf_gate']}" if r.get("htf_gate") else ""
    return f"{r['primary']}{confirm} ({r['entry_side']}, {r['interval']}{exit_s}{gate_s})"


def _format_human(payload: dict):
    lines = []
    add = lines.append
    s = payload["summary"]
    add("")
    add(f"  Backtest Matrix  |  {payload['scan_date']}  |  {payload['lookback_days']}d lookback")
    add("  " + "=" * 72)
    add(f"  Symbols: {s['symbols']}   Combos/symbol: {s['combos_per_symbol']}   "
        f"Engine runs: {s['total_engine_runs']}")
    add(f"  Tested: {s['tested']}   Gated out: {s['gated_out']}   "
        f"Failed validation: {s['failed_validation']}   Confirmed: {s['confirmed']}")
    add("  All ₹/day figures below are OUT-OF-SAMPLE (held-out validation slice).")
    add("")

    # Per-symbol detail
    for blk in payload["symbols"]:
        c = blk["counts"]
        add(f"  {blk['symbol']:<14} score={blk['scan_score']}  "
            f"[{c['confirmed']} confirmed / {c['tested']} tested, "
            f"{c['gated_out']} gated, {c['failed_validation']} failed val]")
        if not blk["confirmed_combos"]:
            # Always say WHY nothing survived — the top gate-reason categories
            # (and the failed-validation count) instead of a bare "0 confirmed".
            bits = []
            phrase = _gate_summary_phrase(blk.get("gate_summary") or {})
            if phrase:
                bits.append(phrase)
            if c["failed_validation"]:
                bits.append(f"{c['failed_validation']} failed validation")
            detail = f" ({'; '.join(bits)})" if bits else ""
            add(f"       → no combo survived{detail}")
        for r in blk["confirmed_combos"][:5]:
            wf = r["walk_forward"]
            tr = wf["train"]
            va = wf["validation"]
            add(f"       → {_combo_label(r):<46} {r['confidence']:<6} "
                f"val ₹{r['validation_per_day']:+,.0f}/day")
            add(f"           train: ₹{tr['net_pnl']:+,.0f} ({tr['n_trades']}t, "
                f"t={tr['tstat']})   "
                f"val: ₹{va['net_pnl']:+,.0f} ({va['n_trades']}t, t={va['tstat']})")
            if r.get("plateau_warning"):
                add(f"           ⚠ {r['plateau_warning']}")
        # --show-gated: a compact line per dropped combo so an all-gated run is
        # debuggable straight from the output.
        for r in blk.get("gated_combos") or []:
            reason = r["gate_reasons"][0] if r["gate_reasons"] else "?"
            add(f"       ✗ {_combo_label(r):<46} {r['total_trades']:>3}t "
                f"₹{r['total_pnl']:+,.0f}  {_truncate(reason)}")
        for r in blk.get("failed_validation_combos") or []:
            va = (r.get("walk_forward") or {}).get("validation") or {}
            add(f"       ~ {_combo_label(r):<46} {r['total_trades']:>3}t "
                f"₹{r['total_pnl']:+,.0f}  failed validation "
                f"(val ₹{va.get('net_pnl', 0):+,.0f} over {va.get('n_trades', 0)}t)")
    add("")

    # Top-level deployment plan
    add("  Deployment plan (best confirmed combo per symbol, by validation ₹/day)")
    add("  " + "-" * 72)
    plan = payload["deployment_plan"]
    if not plan:
        add("    (nothing confirmed out-of-sample — narrow the grid or extend --days)")
    for p in plan:
        add(f"    {p['symbol']:<14} {_combo_label(p):<46} {p['confidence']:<6} "
            f"₹{p['validation_per_day']:+,.0f}/day")
    add("    (figures are out-of-sample validation expectancy, not in-sample)")
    add("")
    print("\n".join(lines))


# ---------------------------------------------------------------------------
# Main
