        instrument_type = getattr(pos, 'instrument_type', '') or ''
        instrument_token = getattr(pos, 'instrument_token', '') or ''

        # F&O positions: exchange contains FO, or instrument_type is OPTIDX/OPTSTK/FUTIDX/FUTSTK
        is_fno = (
            'FO' in exchange
            or instrument_type in ('OPTIDX', 'OPTSTK', 'FUTIDX', 'FUTSTK')
            or 'NSE_FO' in instrument_token
        )
        if not is_fno:
            continue

        qty = getattr(pos, 'quantity', 0) or 0
        tradingsymbol = (getattr(pos, 'tradingsymbol', None) or getattr(pos, 'trading_symbol', '') or '').upper()
        avg_price = getattr(pos, 'average_price', 0) or getattr(pos, 'buy_price', 0) or 0
        last_price = getattr(pos, 'last_price', 0) or 0
        product = getattr(pos, 'product', '') or ''
