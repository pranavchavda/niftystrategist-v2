#!/usr/bin/env python3
"""Options trading tool for Index & Stock F&O.

Supports:
- Option chain lookup for indices (NIFTY, BANKNIFTY) AND individual stocks
  (RELIANCE, TCS, HDFCBANK, etc.) — ~200 F&O-eligible stocks on NSE
- Get option quotes
- Option greeks (delta, gamma, theta, vega, IV) via Upstox v3 API
- Live option chain with greeks via Upstox put/call API
- Place BUY/SELL option orders (index AND stock options)
- F&O charges estimation
- F&O positions viewer
- Trade planner (strike selection, lot sizing, affordability)

NOTE: place and cancel subcommands are HITL-protected — they require
user approval when called from the orchestrator via execute_bash.
"""

import argparse
import sys
import os
from datetime import datetime

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import format_inr, init_client, print_error, print_json, print_success, run_async

# Options instrument cache file (same as equity cache - it contains F&O too)
OPTIONS_CACHE = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), ".cache", "nse_instruments.csv")

_options_cache: dict = {}
# Maps short trading symbol prefix (e.g. "RELIANCE") to full company name
# (e.g. "RELIANCE INDUSTRIES LTD") used in the CSV "name" field for OPTSTK rows.
# For OPTIDX, name is already the short symbol (e.g. "NIFTY").
_symbol_to_name: dict = {}


def _load_options_cache():
    """Load options instruments from cache."""
    global _options_cache, _symbol_to_name
    if _options_cache:
        return _options_cache

    import csv, re
    if not os.path.exists(OPTIONS_CACHE):
        print_error("Instruments cache not found. Run nf-quote first to download.")

    options = {}
    sym_to_name = {}
    with open(OPTIONS_CACHE, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        for row in reader:
            # Only index options (OPTIDX) and stock options (OPTSTK)
            if row.get("instrument_type") in ("OPTIDX", "OPTSTK"):
                tradingsymbol = row.get("tradingsymbol", "")
                name = row.get("name", "")
                options[tradingsymbol] = {
                    "instrument_key": row.get("instrument_key"),
                    "exchange_token": row.get("exchange_token"),
                    "tradingsymbol": tradingsymbol,
                    "name": name,
                    "last_price": float(row.get("last_price") or 0),
                    "expiry": row.get("expiry"),
                    "strike": float(row.get("strike") or 0),
                    "tick_size": float(row.get("tick_size") or 0.05),
                    "lot_size": int(row.get("lot_size") or 1),
                    "instrument_type": row.get("instrument_type"),
                    "option_type": row.get("option_type"),
                    "exchange": row.get("exchange"),
                }
                # Build symbol prefix → full name mapping for OPTSTK
                # e.g. tradingsymbol "RELIANCE26MAR1650CE" → prefix "RELIANCE"
                if row.get("instrument_type") == "OPTSTK" and tradingsymbol:
                    m = re.match(r'^([A-Z&-]+?)\d', tradingsymbol)
                    if m:
                        prefix = m.group(1)
                        if prefix not in sym_to_name:
                            sym_to_name[prefix] = name
    _options_cache = options
    _symbol_to_name = sym_to_name
    return _options_cache


def _resolve_symbol(symbol: str) -> str:
    """Resolve a short symbol to the name used in the options cache.

    For index options (NIFTY, BANKNIFTY), the CSV "name" field is the short
    symbol itself.  For stock options (OPTSTK), the "name" is the full company
    name (e.g. "RELIANCE INDUSTRIES LTD").  This function maps "RELIANCE" →
    "RELIANCE INDUSTRIES LTD" so all lookup functions work uniformly.
    """
    _load_options_cache()
    symbol = symbol.upper()
    # If the symbol directly matches any cache entry's name, use it as-is
    for data in _options_cache.values():
        if data["name"] == symbol:
            return symbol
    # Otherwise, try the prefix → full name mapping
    return _symbol_to_name.get(symbol, symbol)


def find_option(symbol: str, expiry_date: str, strike: float, option_type: str):
    """Find an option instrument.

    Args:
        symbol: NIFTY, BANKNIFTY, RELIANCE, etc.
        expiry_date: DDMMMYY format (e.g., 17FEB26) or YYYY-MM-DD
        strike: Strike price
        option_type: CE (Call) or PE (Put)
    """
    cache = _load_options_cache()
    resolved_name = _resolve_symbol(symbol)
    symbol = symbol.upper()
    opt_type = option_type.upper()
    
    # Normalize expiry format
    expiry_normalized = expiry_date
    if "-" in expiry_date:
        # Convert YYYY-MM-DD to DDMMMYY
        dt = datetime.strptime(expiry_date, "%Y-%m-%d")
        expiry_normalized = dt.strftime("%d%b%y").upper()
    
    # Build tradingsymbol pattern: NIFTY2621725500PE
    # Format: SYMBOL + YY + DD + MM + STRIKE + OPTTYPE
    # Note: The actual format in cache is: NIFTY2621725500PE
    # Which seems to be: NIFTY + 26 (year) + 21 (day) + 7 (month digit?) + 25500 + PE
    
    # Let's search by pattern matching
    matching = []
    for ts, data in cache.items():
        if (data["name"] == resolved_name and
            data["strike"] == strike and
            data["option_type"] == opt_type):
            # Check expiry matches
            cache_expiry = data.get("expiry", "")
            if expiry_normalized in cache_expiry or cache_expiry.endswith(expiry_date[-2:]):
                matching.append(data)
    
    if not matching:
        # Try fuzzy match on tradingsymbol
        pattern = f"{symbol}{expiry_normalized[-5:-2]}{strike:.0f}{opt_type}"
        for ts, data in cache.items():
            if ts.startswith(symbol) and ts.endswith(f"{int(strike)}{opt_type}"):
                # Check if expiry is close
                cache_expiry = data.get("expiry", "")
                if expiry_date in cache_expiry or expiry_normalized[-4:] in ts:
                    matching.append(data)
    
    if not matching:
        return None
    
    # Return the nearest expiry match
    matching.sort(key=lambda x: x.get("expiry", ""))
    return matching[0]


def get_option_chain(symbol: str, expiry: str = None):
    """Get option chain for a symbol (index or stock)."""
    cache = _load_options_cache()
    resolved_name = _resolve_symbol(symbol)
    symbol = symbol.upper()

    chain = []
    for ts, data in cache.items():
        if data["name"] == resolved_name:
            if expiry:
                if expiry.upper() not in ts:
                    continue
            chain.append(data)
    
    # Group by strike
    strikes = {}
    for opt in chain:
        strike = opt["strike"]
        if strike not in strikes:
            strikes[strike] = {"strike": strike, "expiry": opt["expiry"]}
        strikes[strike][opt["option_type"].lower()] = opt
    
    return sorted(strikes.values(), key=lambda x: x["strike"])


def show_chain(symbol: str, expiry: str = None, as_json: bool = False):
    """Display option chain."""
    chain = get_option_chain(symbol, expiry)
    
    if not chain:
        print_error(f"No options found for {symbol}")
    
    if as_json:
        print_json({"symbol": symbol, "chain": chain})
        return
    
    print(f"📊 Option Chain: {symbol}\n")
    print(f"{'Strike':>10} {'CALL':>12} {'PUT':>12} {'Expiry':>12}")
    print("-" * 50)
    
    for item in chain[-20:]:  # Show last 20 strikes
        strike = item["strike"]
        ce_price = item.get("ce", {}).get("last_price", 0)
        pe_price = item.get("pe", {}).get("last_price", 0)
        expiry = item.get("expiry", "")
        print(f"{strike:>10.0f} {format_inr(ce_price):>12} {format_inr(pe_price):>12} {expiry:>12}")


def estimate_fno_charges(premium: float, quantity: int, side: str,
                         exit_premium: float = None) -> dict:
    """Estimate F&O charges using standard Upstox rate structure.

    F&O rates differ from equity:
    - Brokerage: flat Rs 20/order (Upstox, options)
    - STT: 0.0625% on sell-side premium (options)
    - Transaction charges (NSE F&O): ~0.053% of premium turnover
    - GST: 18% on (brokerage + transaction charges)
    - SEBI: 0.0001% of premium turnover
    - Stamp duty: 0.003% of buy-side premium
    """
    buy_value = premium * quantity if side == "BUY" else 0
    sell_value = premium * quantity if side == "SELL" else 0
    turnover = buy_value + sell_value

    brokerage = 20.0  # Per order, flat

    # STT on options: 0.0625% on sell premium only
    # For buyers, STT is charged only on exercise (not on square-off in some cases)
    # But for estimation, we charge on sell side
    stt = sell_value * 0.000625

    # NSE F&O transaction charges: ~0.053% of premium turnover
    txn_charges = turnover * 0.00053

    # GST: 18% on (brokerage + transaction charges)
    gst = (brokerage + txn_charges) * 0.18

    # SEBI fee: 0.0001% of turnover
    sebi = turnover * 0.000001

    # Stamp duty: 0.003% on buy side
    stamp = buy_value * 0.00003

    total = brokerage + stt + txn_charges + gst + sebi + stamp

    result = {
        "premium": premium,
        "quantity": quantity,
        "side": side,
        "turnover": round(turnover, 2),
        "brokerage": round(brokerage, 2),
        "stt": round(stt, 2),
        "transaction_charges": round(txn_charges, 2),
        "gst": round(gst, 2),
        "sebi": round(sebi, 2),
        "stamp_duty": round(stamp, 2),
        "total": round(total, 2),
        "cost_pct": round((total / turnover * 100) if turnover > 0 else 0, 4),
    }

    # Round-trip estimate if exit premium provided
    if exit_premium is not None:
        exit_result = estimate_fno_charges(exit_premium, quantity, "SELL" if side == "BUY" else "BUY")
        round_trip_total = total + exit_result["total"]
        result["round_trip"] = {
            "entry_charges": round(total, 2),
            "exit_charges": round(exit_result["total"], 2),
            "total_charges": round(round_trip_total, 2),
            "exit_premium": exit_premium,
        }

    return result


def show_charges(symbol: str, expiry: str, strike: float, option_type: str,
                 lots: int, side: str, price: float = None, exit_price: float = None,
                 as_json: bool = False):
    """Show estimated charges for an options trade."""
    option = find_option(symbol, expiry, strike, option_type)
    if not option:
        print_error(f"Option not found: {symbol} {expiry} {strike} {option_type}")

    lot_size = option["lot_size"]
    quantity = lots * lot_size

    # Use provided price or cache price
    premium = price or option.get("last_price", 0)
    if not premium:
        print_error("No premium available. Provide --price or ensure cache has last_price.")

    charges = estimate_fno_charges(premium, quantity, side.upper(), exit_price)

    # Add contract context
    charges["contract"] = {
        "underlying": symbol.upper(),
        "tradingsymbol": option["tradingsymbol"],
        "expiry": option["expiry"],
        "strike": strike,
        "option_type": option_type.upper(),
        "lot_size": lot_size,
        "lots": lots,
        "total_quantity": quantity,
    }

    if as_json:
        print_json({"ok": True, "data": charges, "warnings": [], "errors": []})
        return

    print(f"💰 F&O Charges Estimate\n")
    print(f"  {side.upper()} {lots} lot(s) = {quantity} units of {option['tradingsymbol']}")
    print(f"  Strike: {strike} {option_type.upper()} | Expiry: {option['expiry']}")
    print(f"  Premium: {format_inr(premium)} | Turnover: {format_inr(charges['turnover'])}")
    print()
    print(f"  Brokerage:            {format_inr(charges['brokerage'])}")
    print(f"  STT:                  {format_inr(charges['stt'])}")
    print(f"  Transaction Charges:  {format_inr(charges['transaction_charges'])}")
    print(f"  GST:                  {format_inr(charges['gst'])}")
    print(f"  SEBI Fee:             {format_inr(charges['sebi'])}")
    print(f"  Stamp Duty:           {format_inr(charges['stamp_duty'])}")
    print(f"  ── Total:             {format_inr(charges['total'])} ({charges['cost_pct']:.4f}%)")

    if "round_trip" in charges:
        rt = charges["round_trip"]
        print(f"\n  Round-trip ({format_inr(premium)} → {format_inr(exit_price)}):")
        print(f"  Entry charges:        {format_inr(rt['entry_charges'])}")
        print(f"  Exit charges:         {format_inr(rt['exit_charges'])}")
        print(f"  ── Total round-trip:  {format_inr(rt['total_charges'])}")
        # Break-even for long options
        if side.upper() == "BUY":
            be_premium = premium + rt['total_charges'] / quantity
            print(f"  Break-even premium:   {format_inr(be_premium)}")


def place_option_order(symbol: str, expiry: str, strike: float, option_type: str,
                       action: str, quantity_lots: int, price: float = None,
                       order_type: str = "MARKET", dry_run: bool = False, as_json: bool = False):
    """Place an option order."""
    option = find_option(symbol, expiry, strike, option_type)

    if not option:
        print_error(f"Option not found: {symbol} {expiry} {strike} {option_type}")

    lot_size = option["lot_size"]
    quantity = quantity_lots * lot_size
    instrument_key = option["instrument_key"]
    tradingsymbol = option["tradingsymbol"]

    client = init_client()

    # Try to get live LTP for better pricing
    live_ltp = None
    try:
        greeks = run_async(client.get_option_greeks([instrument_key]))
        if greeks:
            gdata = list(greeks.values())[0]
            live_ltp = gdata.get("last_price")
    except Exception:
        pass

    # Use provided price, or live LTP, or cache price
    if not price:
        price = live_ltp or option.get("last_price", 0)

    if dry_run:
        estimated_value = price * quantity
        charges = estimate_fno_charges(price, quantity, action.upper())

        # Check funds
        funds_info = None
        warnings = []
        try:
            funds = run_async(client.get_funds_and_margin())
            equity = funds.get("equity", {})
            available = equity.get("available_margin", 0)
            funds_info = {
                "available_margin": available,
                "used_margin": equity.get("used_margin", 0),
            }
            if action.upper() == "BUY" and estimated_value > available:
                warnings.append(f"Insufficient funds: need {format_inr(estimated_value)}, have {format_inr(available)}")
        except Exception:
            warnings.append("Could not fetch funds — unable to check sufficiency")

        # Break-even
        break_even = None
        if action.upper() == "BUY":
            break_even = price + charges["total"] / quantity if quantity > 0 else None
        elif action.upper() == "SELL":
            break_even = price - charges["total"] / quantity if quantity > 0 else None

        result = {
            "ok": True,
            "dry_run": True,
            "underlying": symbol.upper(),
            "tradingsymbol": tradingsymbol,
            "instrument_key": instrument_key,
            "expiry": option["expiry"],
            "strike": strike,
            "option_type": option_type.upper(),
            "action": action.upper(),
            "order_type": order_type,
            "lots": quantity_lots,
            "lot_size": lot_size,
            "quantity": quantity,
            "premium": price,
            "live_ltp": live_ltp,
            "estimated_value": round(estimated_value, 2),
            "estimated_charges": charges["total"],
            "charges_breakdown": {
                "brokerage": charges["brokerage"],
                "stt": charges["stt"],
                "transaction_charges": charges["transaction_charges"],
                "gst": charges["gst"],
                "sebi": charges["sebi"],
                "stamp_duty": charges["stamp_duty"],
            },
            "break_even_premium": round(break_even, 2) if break_even else None,
            "funds": funds_info,
            "max_loss": round(estimated_value + charges["total"], 2) if action.upper() == "BUY" else "unlimited (naked sell)",
            "warnings": warnings,
            "errors": [],
        }

        if as_json:
            print_json(result)
        else:
            print(f"🔍 Dry Run — order NOT placed\n")
            print(f"  {action.upper()} {quantity_lots} lot(s) = {quantity} units of {tradingsymbol}")
            print(f"  Instrument: {instrument_key}")
            print(f"  Strike: {strike} {option_type.upper()} | Expiry: {option['expiry']}")
            print(f"  Order Type: {order_type}")
            print(f"  Premium: {format_inr(price)}" + (f" (live)" if live_ltp else " (cached)"))
            print(f"  Est. Value: {format_inr(estimated_value)}")
            print(f"  Est. Charges: {format_inr(charges['total'])} ({charges['cost_pct']:.4f}%)")
            if break_even:
                print(f"  Break-even: {format_inr(break_even)}")
            if action.upper() == "BUY":
                print(f"  Max Loss: {format_inr(estimated_value + charges['total'])} (premium + charges)")
            else:
                print(f"  Max Loss: Unlimited (naked sell)")
            if funds_info:
                print(f"\n  Available Margin: {format_inr(funds_info['available_margin'])}")
                if action.upper() == "BUY":
                    sufficient = funds_info['available_margin'] >= estimated_value
                    label = "YES" if sufficient else "NO — insufficient funds"
                    print(f"  Funds Sufficient: {label}")
            for w in warnings:
                print(f"\n  ⚠️  {w}")
        return
    
    # Place live order
    if not client.access_token:
        print_error("No access token. Please connect Upstox account.")
    
    try:
        import upstox_client
        
        # Auto-detect AMO
        is_amo = not client._is_market_open()
        
        api_client = upstox_client.ApiClient(client._configuration)
        order_api = upstox_client.OrderApiV3(api_client)
        
        body = upstox_client.PlaceOrderV3Request(
            quantity=quantity,
            product="D",  # Delivery (for options carry forward)
            validity="DAY",
            price=price if order_type == "LIMIT" else 0,
            trigger_price=0,
            instrument_token=instrument_key,
            order_type=order_type,
            transaction_type=action.upper(),
            disclosed_quantity=0,
            is_amo=is_amo,
        )
        
        response = order_api.place_order(body)
        order_ids = response.data.order_ids if response.data else []
        order_id = order_ids[0] if order_ids else None
        
        amo_label = " [AMO]" if is_amo else ""
        mode = "Paper" if client.paper_trading else "🔴 LIVE"
        
        if as_json:
            print_json({
                "success": True,
                "order_id": order_id,
                "tradingsymbol": tradingsymbol,
                "instrument_key": instrument_key,
                "action": action,
                "quantity_lots": quantity_lots,
                "quantity_units": quantity,
                "lot_size": lot_size,
                "order_type": order_type,
                "price": price,
                "status": "PLACED",
                "mode": mode,
            })
        else:
            emoji = "🟢" if action.upper() == "BUY" else "🔴"
            print_success(f"Order Placed [{mode}]{amo_label}")
            print(f"\n  {emoji} {action.upper()} {quantity_lots} lot(s) = {quantity} units")
            print(f"  Symbol: {tradingsymbol}")
            print(f"  Strike: {strike} {option_type} | Expiry: {option['expiry']}")
            print(f"  Order ID: {order_id}")
            print(f"  Type: {order_type}")
            if price:
                print(f"  Price: {format_inr(price)}")
    
    except Exception as e:
        print_error(f"Order failed: {e}")


def show_expiries(symbol: str, as_json: bool = False):
    """Show upcoming expiry dates for a symbol (index or stock)."""
    cache = _load_options_cache()
    resolved_name = _resolve_symbol(symbol)
    symbol = symbol.upper()

    expiries = set()
    for ts, data in cache.items():
        if data["name"] == resolved_name and data.get("expiry"):
            expiries.add(data["expiry"])
    
    if not expiries:
        print_error(f"No options found for {symbol}")
    
    expiries = sorted(expiries)
    
    if as_json:
        print_json({"symbol": symbol, "expiries": expiries})
        return
    
    print(f"📅 Upcoming Expiries for {symbol}\n")
    for i, exp in enumerate(expiries[:10], 1):
        dt = datetime.strptime(exp, "%Y-%m-%d")
        day_name = dt.strftime("%A")
        print(f"  {i}. {exp} ({day_name})")


def show_greeks(symbol: str, expiry: str, strikes: list = None,
                option_type: str = None, as_json: bool = False):
    """Show option greeks for instruments (index or stock)."""
    cache = _load_options_cache()
    resolved_name = _resolve_symbol(symbol)
    symbol_upper = symbol.upper()

    # Find matching instruments
    instrument_keys = []
    key_to_info = {}
    for ts, data in cache.items():
        if data["name"] != resolved_name:
            continue
        if expiry:
            # Match against both tradingsymbol and the expiry field (YYYY-MM-DD)
            expiry_up = expiry.upper()
            cache_expiry = data.get("expiry", "")
            if expiry_up not in ts and cache_expiry != expiry and expiry_up not in cache_expiry:
                continue
        if option_type and data["option_type"] != option_type.upper():
            continue
        if strikes and data["strike"] not in strikes:
            continue
        inst_key = data["instrument_key"]
        if inst_key:
            instrument_keys.append(inst_key)
            key_to_info[inst_key] = data

    if not instrument_keys:
        print_error(f"No options found for {symbol_upper} with given filters")

    # Limit to 50 (API max)
    if len(instrument_keys) > 50:
        instrument_keys = instrument_keys[:50]

    client = init_client()
    try:
        greeks = run_async(client.get_option_greeks(instrument_keys))
    except Exception as e:
        print_error(f"Failed to get option greeks: {e}")

    if as_json:
        # Merge cache info with greeks
        result = []
        for key, gdata in greeks.items():
            info = key_to_info.get(key, {})
            result.append({
                "tradingsymbol": info.get("tradingsymbol", ""),
                "strike": info.get("strike", 0),
                "option_type": info.get("option_type", ""),
                "expiry": info.get("expiry", ""),
                "lot_size": info.get("lot_size", 0),
                **gdata,
            })
        print_json({"symbol": symbol_upper, "greeks": result})
        return

    print(f"📊 Option Greeks: {symbol_upper}\n")
    print(f"{'Strike':>8} {'Type':<4} {'LTP':>10} {'IV':>8} {'Delta':>8} {'Gamma':>8} {'Theta':>8} {'Vega':>8} {'OI':>10}")
    print("-" * 85)

    rows = []
    for key, gdata in greeks.items():
        info = key_to_info.get(key, {})
        rows.append((info.get("strike", 0), info.get("option_type", ""), gdata, info))
    rows.sort(key=lambda x: (x[0], x[1]))

    for strike, otype, gdata, info in rows:
        ltp = gdata.get("last_price") or 0
        iv_raw = gdata.get("iv") or 0
        iv_pct = iv_raw * 100 if iv_raw < 1 else iv_raw  # API returns decimal (0.20 = 20%)
        delta = gdata.get("delta") or 0
        gamma = gdata.get("gamma") or 0
        theta = gdata.get("theta") or 0
        vega = gdata.get("vega") or 0
        oi = gdata.get("oi") or 0
        print(
            f"{strike:>8.0f} {otype:<4} {format_inr(ltp):>10} {iv_pct:>6.1f}% "
            f"{delta:>+8.4f} {gamma:>8.4f} {theta:>+8.2f} {vega:>8.2f} {oi:>10,.0f}"
        )


def show_live_chain(symbol: str, expiry: str, as_json: bool = False):
    """Show live option chain with greeks from Upstox API."""
    client = init_client()
    try:
        chain = run_async(client.get_option_chain_live(symbol, expiry))
    except Exception as e:
        print_error(f"Failed to get live option chain: {e}")

