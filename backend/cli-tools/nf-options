        p.add_argument("--dry-run", action="store_true", help="Preview without executing")
        p.add_argument("--json", action="store_true", help="Output as JSON")

    # charges
    p_charges = sub.add_parser("charges", help="Estimate F&O charges for an options trade")
    p_charges.add_argument("symbol", help=_sym_help)
    p_charges.add_argument("expiry", help="Expiry date (DDMMMYY or YYYY-MM-DD)")
    p_charges.add_argument("strike", type=float, help="Strike price")
    p_charges.add_argument("option_type", choices=["CE", "PE", "ce", "pe"], help="Call (CE) or Put (PE)")
    p_charges.add_argument("lots", type=int, help="Number of lots")
    p_charges.add_argument("--side", default="BUY", choices=["BUY", "SELL"], help="Transaction side (default: BUY)")
    p_charges.add_argument("--price", type=float, help="Premium price (default: use cache/live price)")
    p_charges.add_argument("--exit-price", type=float, help="Exit premium for round-trip estimate")
    p_charges.add_argument("--json", action="store_true", help="Output as JSON")

    # positions
    p_positions = sub.add_parser("positions", help="Show all F&O positions (index + stock)")
    p_positions.add_argument("--json", action="store_true", help="Output as JSON")

    # plan
    p_plan = sub.add_parser("plan", help="Plan an options trade (strike selection, affordability)")
    p_plan.add_argument("symbol", help=_sym_help)
    p_plan.add_argument("--expiry", required=True, help="Expiry date (YYYY-MM-DD)")
    p_plan.add_argument("--side", default="buy", choices=["buy", "sell"], help="Trade side (default: buy)")
    p_plan.add_argument("--bias", choices=["bullish", "bearish"], help="Market bias (filters CE/PE)")
    p_plan.add_argument("--capital", type=float, help="Available capital in rupees")
    p_plan.add_argument("--lots", type=int, help="Desired number of lots")
    p_plan.add_argument("--json", action="store_true", help="Output as JSON")

    # spread — multi-leg basket order (strategy builder)
    p_spread = sub.add_parser("spread", help="Multi-leg spread/basket order with payoff analysis")
    p_spread.add_argument("symbol", help=_sym_help)
    p_spread.add_argument("--expiry", required=True, help="Expiry date (DDMMMYY or YYYY-MM-DD)")
    p_spread.add_argument("--legs", nargs="+", required=True, metavar="SIDE:STRIKE:TYPE",
                          help="Leg definitions. Format: SIDE:STRIKE:TYPE (e.g. BUY:24250:CE SELL:25000:CE)")
    p_spread.add_argument("--lots", type=int, default=1, help="Number of lots per leg (default: 1)")
    p_spread.add_argument("--product", default="D", choices=["D", "I"],
                          help="Product type: D=NRML, I=MIS (default: D)")
    p_spread.add_argument("--dry-run", action="store_true", help="Preview spread without placing orders")
    p_spread.add_argument("--json", action="store_true", help="Output as JSON")

    # fno-symbols — list all F&O-eligible stock symbols
    p_fno = sub.add_parser("fno-symbols", help="List all F&O-eligible stock symbols")
    p_fno.add_argument("--json", action="store_true", help="Output as JSON")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "chain":
        show_chain(args.symbol, args.expiry, args.json)
    elif args.command == "greeks":
        show_greeks(args.symbol, args.expiry, args.strikes, args.opt_type, args.json)
    elif args.command == "live-chain":
        show_live_chain(args.symbol, args.expiry, args.json)
    elif args.command == "expiries":
        show_expiries(args.symbol, args.json)
    elif args.command == "quote":
        option = find_option(args.symbol, args.expiry, args.strike, args.option_type)
        if not option:
            print_error(f"Option not found: {args.symbol} {args.expiry} {args.strike} {args.option_type}")
