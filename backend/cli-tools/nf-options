def plan_trade(symbol: str, expiry: str, side: str = "buy", bias: str = None,
               capital: float = None, lots: int = None, as_json: bool = False):
    """Plan an options trade — suggest strikes, compute affordability, show candidates."""
    cache = _load_options_cache()
    resolved_name = _resolve_symbol(symbol)
    symbol = symbol.upper()

    # Collect all options for this symbol and expiry
    matching = []
    for ts, data in cache.items():
        if data["name"] != resolved_name:
            continue
        if expiry:
            cache_expiry = data.get("expiry", "")
            if expiry not in cache_expiry and expiry.upper() not in ts:
                continue
        matching.append(data)

    if not matching:
        print_error(f"No options found for {symbol} expiry {expiry}. Run 'nf-options expiries {symbol}' to see valid expiries.")

    lot_size = matching[0]["lot_size"]

    # Get live spot price if possible
    client = init_client()
    spot = None
    try:
        chain = run_async(client.get_option_chain_live(symbol, expiry))
        if chain:
            spot = chain[0].get("underlying_spot_price")
    except Exception:
        pass

    # Group by strike and option type
    strikes_data = {}
    for opt in matching:
        key = (opt["strike"], opt["option_type"])
        strikes_data[key] = opt

    # Determine which option types to show based on bias
    if bias == "bullish":
        show_types = ["CE"]
    elif bias == "bearish":
        show_types = ["PE"]
    else:
        show_types = ["CE", "PE"]

    # Find ATM strike
    all_strikes = sorted(set(opt["strike"] for opt in matching))
    atm_strike = None
    if spot:
        atm_strike = min(all_strikes, key=lambda s: abs(s - spot))

    # Build candidate contracts
    candidates = []
    for opt_type in show_types:
        for s in all_strikes:
            data = strikes_data.get((s, opt_type))
            if not data:
                continue

            premium = data.get("last_price", 0)
            if premium <= 0:
                continue

            cost_per_lot = premium * lot_size
            max_lots = int(capital / cost_per_lot) if capital and cost_per_lot > 0 else None

            # Moneyness
            moneyness = "ATM"
            if spot:
                diff = s - spot
                if opt_type == "CE":
                    if diff < -spot * 0.005:
                        moneyness = "ITM"
                    elif diff > spot * 0.005:
                        moneyness = "OTM"
                else:  # PE
                    if diff > spot * 0.005:
                        moneyness = "ITM"
                    elif diff < -spot * 0.005:
                        moneyness = "OTM"

            # Charges for 1 lot
            charges = estimate_fno_charges(premium, lot_size, side.upper())

            candidate = {
                "strike": s,
                "option_type": opt_type,
                "premium": premium,
                "lot_size": lot_size,
                "cost_per_lot": round(cost_per_lot, 2),
                "charges_per_lot": charges["total"],
                "break_even": round(premium + charges["total"] / lot_size, 2) if side.upper() == "BUY" else round(premium - charges["total"] / lot_size, 2),
                "moneyness": moneyness,
                "max_lots_affordable": max_lots,
                "tradingsymbol": data["tradingsymbol"],
                "instrument_key": data["instrument_key"],
            }
            if max_lots is not None:
                candidate["total_cost"] = round(cost_per_lot * min(max_lots, lots or 1), 2)
            candidates.append(candidate)

    # Sort by distance from ATM
    if spot:
        candidates.sort(key=lambda c: abs(c["strike"] - spot))
    else:
        candidates.sort(key=lambda c: c["strike"])

    # Limit to reasonable range (10 strikes around ATM)
    candidates = candidates[:20]

    result = {
        "ok": True,
        "data": {
            "underlying": symbol,
            "expiry": expiry,
            "spot": spot,
            "atm_strike": atm_strike,
            "lot_size": lot_size,
            "side": side.upper(),
            "bias": bias,
            "capital": capital,
            "requested_lots": lots,
            "candidates": candidates,
        },
        "warnings": [],
        "errors": [],
    }

    if not spot:
        result["warnings"].append("Could not fetch live spot price — moneyness is approximate")
    if not candidates:
        result["errors"].append("No candidate contracts found with non-zero premium")

    if as_json:
        print_json(result)
        return

    print(f"📋 Options Trade Plan: {symbol} ({expiry})\n")
    if spot:
        print(f"  Spot: {format_inr(spot)}  |  ATM Strike: {atm_strike}  |  Lot Size: {lot_size}")
    else:
        print(f"  Spot: N/A (market may be closed)  |  Lot Size: {lot_size}")
    if capital:
        print(f"  Capital: {format_inr(capital)}  |  Side: {side.upper()}")
    if bias:
        print(f"  Bias: {bias.upper()}")
    print()

    print(f"{'Strike':>8} {'Type':<4} {'Moneyness':<5} {'Premium':>10} {'Cost/Lot':>12} {'Charges':>10} {'B/E':>10}", end="")
    if capital:
        print(f" {'Max Lots':>9}", end="")
    print()
    print("-" * (75 + (10 if capital else 0)))

    for c in candidates:
        print(
            f"{c['strike']:>8.0f} {c['option_type']:<4} {c['moneyness']:<5} "
            f"{format_inr(c['premium']):>10} {format_inr(c['cost_per_lot']):>12} "
            f"{format_inr(c['charges_per_lot']):>10} {format_inr(c['break_even']):>10}",
            end=""
        )
        if capital:
            ml = c.get("max_lots_affordable")
            print(f" {ml if ml is not None else '?':>9}", end="")
        print()

    # Highlight best picks
    if candidates and side.upper() == "BUY":
        affordable = [c for c in candidates if c.get("max_lots_affordable") and c["max_lots_affordable"] >= 1] if capital else candidates
        if affordable:
            atm_picks = [c for c in affordable if c["moneyness"] == "ATM"]
            if atm_picks:
                pick = atm_picks[0]
                print(f"\n  Suggested: {pick['tradingsymbol']} @ {format_inr(pick['premium'])}")
                print(f"  Cost: {format_inr(pick['cost_per_lot'])}/lot | Max loss: {format_inr(pick['cost_per_lot'] + pick['charges_per_lot'])}")


