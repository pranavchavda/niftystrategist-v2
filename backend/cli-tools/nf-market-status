#!/usr/bin/env python3
"""Check NSE market status — open/closed, time to next event.

Uses Upstox market status API as source of truth (handles holidays correctly).
Falls back to time-based calculation if no valid token is available.
"""

import argparse
import json
import sys
import os

# Add backend/ to sys.path
_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import init_client, run_async
from utils.market_status import get_market_status, format_duration, _ist_now


async def _get_upstox_status() -> str | None:
    """Try to get market status from Upstox API."""
    try:
        client = init_client()
        if not client.access_token:
            return None
        result = await client.get_market_status_api()
        if result and result.get("status"):
            return result["status"]
    except Exception:
        pass
    return None


def main():
    parser = argparse.ArgumentParser(
        prog="nf-market-status",
        description="Check NSE market status (open/closed, time to next event)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  nf-market-status              Human-readable status
  nf-market-status --json       JSON output for programmatic use
""",
    )
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    args = parser.parse_args()

    # Try Upstox API first, fall back to time-based
    upstox_status = run_async(_get_upstox_status())
    status = get_market_status(upstox_api_status=upstox_status)

    if args.json:
        print(json.dumps(status, indent=2))
        return

    # Human-readable output
    s = status["status"]
    if s == "open":
        print(f"📈 Market is OPEN (closes in {status['closes_in']})")
        print(f"   Close time: {status['close_time']}")
    elif s == "pre_open":
        print(f"🟡 Pre-open session (market opens in {status['next_event_in']})")
    elif s == "closed":
        reason = status.get("reason", "")
        if reason == "weekend":
            print("🔴 Market is CLOSED (weekend)")
        elif reason == "holiday_or_after_hours":
            # Upstox said closed on a weekday — could be holiday or after hours
            now = _ist_now()
            if now.hour < 9:
                print("🔴 Market is CLOSED (pre-market)")
            elif now.hour >= 16:
                print("🔴 Market is CLOSED (after hours)")
            else:
                print("🔴 Market is CLOSED (holiday)")
        elif reason == "before_hours":
            print(f"🔴 Market is CLOSED (pre-market starts in {status['next_event_in']})")
        elif reason == "after_hours":
            print("🔴 Market is CLOSED (after hours)")
        else:
            print("🔴 Market is CLOSED")

        if "next_open" in status:
            print(f"   Next open: {status['next_open']} (in {status['next_open_in']})")

    source = status.get("source", "unknown")
    source_label = "Upstox API" if source == "upstox_api" else "time-based (no token)"
    print(f"   Current time: {status.get('current_time_ist', 'N/A')}")
    print(f"   Source: {source_label}")


if __name__ == "__main__":
    main()
