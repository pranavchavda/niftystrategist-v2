def cmd_list(args):
    """List available strategy templates."""
    from strategies.templates import list_templates

    templates = list_templates()

    if args.json:
        print_json({"templates": templates})
        return

    print("Available Strategy Templates\n")
    for t in templates:
        print(f"  {t['name']:<20} {t['description']}")
        if t["required_params"]:
            print(f"    {'Required:':<12} {', '.join(t['required_params'])}")
        if t["optional_params"]:
            opts = [f"{k}={v}" for k, v in t["optional_params"].items()]
            print(f"    {'Defaults:':<12} {', '.join(opts)}")
        print()


def cmd_deploy(args):
    """Deploy a strategy — create all monitor rules from a template."""
    from strategies.templates import get_template
    from services.instruments_cache import get_instrument_key
    from database.session import get_db_context
    from monitor.crud import create_rule, update_rule

    template = get_template(args.template)
    if not template:
        from strategies.templates import list_templates
        names = [t["name"] for t in list_templates()]
        print_error(f"Unknown template: {args.template}. Available: {', '.join(names)}")

    is_fno = getattr(template, "category", "equity") == "fno"

    if is_fno:
        symbol = args.underlying or args.symbol
        if not symbol:
            print_error("F&O templates require --underlying or --symbol")
    else:
        if not args.symbol:
            print_error("--symbol is required for equity templates")
        symbol = validate_symbol(args.symbol)
    instrument_token = None
    if not is_fno:
        instrument_token = get_instrument_key(symbol)

    # Build params from CLI args
    params = {}
    if args.capital is not None:
        params["capital"] = args.capital
    if args.risk_percent is not None:
        params["risk_percent"] = args.risk_percent
    if args.rr_ratio is not None:
        params["rr_ratio"] = args.rr_ratio
    if args.entry is not None:
        params["entry"] = args.entry
    if args.sl is not None:
        params["sl"] = args.sl
    if args.target is not None:
        params["target"] = args.target
    if args.product is not None:
        params["product"] = args.product
    if args.trail_percent is not None:
        params["trail_percent"] = args.trail_percent
    if args.side is not None:
        params["side"] = args.side
    if args.squareoff_time is not None:
        params["squareoff_time"] = args.squareoff_time
    if args.max_entries is not None:
        params["max_entries"] = args.max_entries
    # ORB-specific
    if args.range_high is not None:
        params["range_high"] = args.range_high
    if args.range_low is not None:
        params["range_low"] = args.range_low
    if args.enable_reversal:
        params["enable_reversal"] = True
    # VWAP-specific
    if args.vwap is not None:
        params["vwap"] = args.vwap
    # Mean reversion
    if args.rsi_entry is not None:
        params["rsi_entry"] = args.rsi_entry
    if args.rsi_exit is not None:
        params["rsi_exit"] = args.rsi_exit
    if args.rsi_timeframe is not None:
        params["rsi_timeframe"] = args.rsi_timeframe
    if args.entry_price is not None:
        params["entry_price"] = args.entry_price
    # F&O-specific params
    if hasattr(args, "expiry") and args.expiry is not None:
        params["expiry"] = args.expiry
    if hasattr(args, "lots") and args.lots is not None:
        params["lots"] = args.lots
    if hasattr(args, "strike") and args.strike is not None:
        params["strike"] = args.strike
    if hasattr(args, "call_strike") and args.call_strike is not None:
        params["call_strike"] = args.call_strike
    if hasattr(args, "put_strike") and args.put_strike is not None:
        params["put_strike"] = args.put_strike
    if hasattr(args, "buy_strike") and args.buy_strike is not None:
        params["buy_strike"] = args.buy_strike
    if hasattr(args, "sell_strike") and args.sell_strike is not None:
        params["sell_strike"] = args.sell_strike
    if hasattr(args, "call_sell_strike") and args.call_sell_strike is not None:
        params["call_sell_strike"] = args.call_sell_strike
    if hasattr(args, "call_buy_strike") and args.call_buy_strike is not None:
        params["call_buy_strike"] = args.call_buy_strike
    if hasattr(args, "put_sell_strike") and args.put_sell_strike is not None:
        params["put_sell_strike"] = args.put_sell_strike
    if hasattr(args, "put_buy_strike") and args.put_buy_strike is not None:
        params["put_buy_strike"] = args.put_buy_strike
    if hasattr(args, "direction") and args.direction is not None:
        params["direction"] = args.direction
    if hasattr(args, "entry_time") and args.entry_time is not None:
        params["entry_time"] = args.entry_time
    # Renko-specific
    if hasattr(args, "brick_size") and args.brick_size is not None:
        params["brick_size"] = args.brick_size
    if hasattr(args, "sl_bricks") and args.sl_bricks is not None:
        params["sl_bricks"] = args.sl_bricks

    # Generate the plan
    try:
        plan = template.plan(symbol, params)
    except ValueError as e:
        print_error(str(e))

    # Dry run — just show what would be created
    if args.dry_run:
        rules_preview = []
        for spec in plan.rules:
            rules_preview.append({
                "name": spec.name,
                "role": spec.role,
                "trigger_type": spec.trigger_type,
                "trigger_config": spec.trigger_config,
                "action_type": spec.action_type,
                "action_config": spec.action_config,
                "max_fires": spec.max_fires,
                "expires": spec.expires,
            })
        output = {
            "dry_run": True,
            "template": plan.template_name,
            "symbol": plan.symbol,
            "group_id": plan.group_id,
            "summary": plan.summary,
            "rules_count": len(plan.rules),
            "rules": rules_preview,
        }
        if args.json:
            print_json(output)
        else:
            print(f"DRY RUN — {plan.summary}\n")
            print(f"  Template:  {plan.template_name}")
            print(f"  Group ID:  {plan.group_id}")
            print(f"  Rules to create: {len(plan.rules)}\n")
            for i, spec in enumerate(plan.rules, 1):
                print(f"  [{i}] {spec.name}")
                print(f"      Trigger: {spec.trigger_type} → {spec.trigger_config}")
                print(f"      Action:  {spec.action_type} → {spec.action_config}")
                if spec.max_fires:
                    print(f"      Max fires: {spec.max_fires}")
                print()
        return

    # Parse expires
    expires_at = None
    expires_val = args.expires or "today"
    expires_at = _parse_expires(expires_val)

    user_id = _get_user_id()

    async def _create_all():
        created = []
        async with get_db_context() as session:
            for spec in plan.rules:
                # For F&O, each rule may have its own instrument_token
                rule_instrument_token = instrument_token
                if is_fno:
                    rule_instrument_token = spec.action_config.get("instrument_token")

                rule = await create_rule(
                    session=session,
                    user_id=user_id,
                    name=spec.name,
                    trigger_type=spec.trigger_type,
                    trigger_config=spec.trigger_config,
                    action_type=spec.action_type,
                    action_config=spec.action_config,
                    instrument_token=rule_instrument_token,
                    symbol=symbol,
                    max_fires=spec.max_fires,
                    expires_at=expires_at,
                    group_id=plan.group_id,
                    strategy_name=plan.template_name,
                    enabled=spec.enabled,
                    role=spec.role,
                )
                created.append(rule)

            # Wire kill chains (also_cancel_rules) and activate chains
            # (also_enable_rules) by resolving role names → rule IDs.
            role_to_id = {}
            for spec, rule in zip(plan.rules, created):
                if spec.role:
                    role_to_id[spec.role] = rule.id

            for spec, rule in zip(plan.rules, created):
                updates = {}
                if spec.kills_roles:
                    cancel_ids = [role_to_id[r] for r in spec.kills_roles if r in role_to_id]
                    if cancel_ids:
                        updates["also_cancel_rules"] = cancel_ids
                if spec.activates_roles:
                    enable_ids = [role_to_id[r] for r in spec.activates_roles if r in role_to_id]
                    if enable_ids:
                        updates["also_enable_rules"] = enable_ids
                if updates:
                    merged = dict(rule.action_config or {})
                    merged.update(updates)
                    await update_rule(session, rule.id, action_config=merged)
                    rule.action_config = merged  # keep in-memory copy in sync

        return created

    rules = run_async(_create_all())

    if args.json:
        print_json({
            "deployed": True,
            "template": plan.template_name,
            "symbol": plan.symbol,
            "group_id": plan.group_id,
            "summary": plan.summary,
            "rules_count": len(rules),
            "rules": [
                {
                    "id": r.id,
                    "name": r.name,
                    "trigger_type": r.trigger_type,
                    "action_type": r.action_type,
                    "role": plan.rules[i].role,
                }
                for i, r in enumerate(rules)
            ],
            "expires": _fmt_ist(expires_at),
        })
    else:
        print_success(f"Strategy deployed: {plan.summary}")
        print(f"  Group ID:  {plan.group_id}")
        print(f"  Expires:   {_fmt_ist(expires_at)}")
        print(f"  Rules created: {len(rules)}\n")
        for i, r in enumerate(rules):
            role = plan.rules[i].role
            print(f"    #{r.id:<4} [{role:<12}] {r.name}")
        print(f"\n  Teardown: nf-strategy teardown --group-id {plan.group_id}")


def cmd_teardown(args):
    """Remove all rules belonging to a strategy group."""
    from database.session import get_db_context
    from monitor.crud import delete_rules_by_group, list_rules_by_group

    user_id = _get_user_id()

    async def _teardown():
        async with get_db_context() as session:
            rules = await list_rules_by_group(session, user_id, args.group_id)
            count = await delete_rules_by_group(session, user_id, args.group_id)
            return rules, count

    rules, count = run_async(_teardown())

    if args.json:
        print_json({
            "teardown": True,
            "group_id": args.group_id,
            "rules_deleted": count,
            "rule_ids": [r.id for r in rules],
        })
    else:
        if count == 0:
            print_error(f"No rules found for group {args.group_id}")
        else:
            print_success(f"Teardown complete: {count} rules deleted (group {args.group_id})")
            for r in rules:
                print(f"    #{r.id} {r.name}")


def cmd_status(args):
    """Show status of all deployed strategies."""
    from database.session import get_db_context
    from monitor.crud import list_rules

    user_id = _get_user_id()

    async def _status():
        async with get_db_context() as session:
            return await list_rules(session, user_id)

    all_rules = run_async(_status())

    # Group by group_id
    groups: dict[str, list] = {}
    ungrouped = []
    for r in all_rules:
        gid = getattr(r, "group_id", None)
        if gid:
            groups.setdefault(gid, []).append(r)
        else:
            ungrouped.append(r)

    if args.json:
        strategies = []
        for gid, rules in groups.items():
            strategies.append({
                "group_id": gid,
                "strategy_name": getattr(rules[0], "strategy_name", None),
                "symbol": rules[0].symbol,
                "rules_count": len(rules),
                "active_count": sum(1 for r in rules if r.enabled),
                "total_fires": sum(r.fire_count or 0 for r in rules),
                "rules": [
                    {"id": r.id, "name": r.name, "enabled": r.enabled, "fire_count": r.fire_count}
                    for r in rules
                ],
            })
        print_json({
            "strategies": strategies,
            "ungrouped_rules": len(ungrouped),
        })
        return

    if not groups:
        print("No deployed strategies found.")
        if ungrouped:
            print(f"({len(ungrouped)} standalone monitor rules exist)")
        return

    print("Deployed Strategies\n")
    for gid, rules in groups.items():
        strategy = getattr(rules[0], "strategy_name", "?")
        sym = rules[0].symbol or "?"
        active = sum(1 for r in rules if r.enabled)
        fires = sum(r.fire_count or 0 for r in rules)
        print(f"  {strategy} on {sym} ({active}/{len(rules)} active, {fires} fires)")
        print(f"    Group: {gid}")
        for r in rules:
            status = "ON " if r.enabled else "OFF"
            fire_str = f"{r.fire_count}" + (f"/{r.max_fires}" if r.max_fires else "")
            print(f"      #{r.id:<4} [{status}] {r.name:<40} fires: {fire_str}")
        print()

    if ungrouped:
        print(f"  + {len(ungrouped)} standalone rules (not part of any strategy)")


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="nf-strategy",
        description="Deploy pre-built trading strategy templates as monitor rule sets",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # List available templates
  nf-strategy list --json

  # Preview an ORB strategy (dry run)
  nf-strategy deploy orb --symbol RELIANCE --capital 50000 \\
    --range-high 2460 --range-low 2440 --dry-run --json

  # Deploy a breakout strategy
  nf-strategy deploy breakout --symbol HDFCBANK --capital 100000 \\
    --entry 1650 --sl 1630 --target 1690 --json

  # Deploy a mean reversion strategy
  nf-strategy deploy mean-reversion --symbol INFY --capital 50000 \\
    --sl 1850 --side long --json

  # Deploy a VWAP bounce strategy
  nf-strategy deploy vwap-bounce --symbol RELIANCE --capital 50000 \\
    --vwap 2450 --sl 2430 --json

  # Deploy a scalp strategy with multiple entries
  nf-strategy deploy scalp --symbol RELIANCE --capital 30000 \\
    --entry 2450 --sl 2445 --max-entries 5 --json

  # Deploy ORB with reversal (target hit re-enables opposite entry)
  nf-strategy deploy orb --symbol M&M --capital 100000 \\
    --range-high 3075 --range-low 3025 --enable-reversal --json

  # Deploy a Renko reversal strategy
  nf-strategy deploy renko --symbol RELIANCE --capital 50000 \\
    --brick-size 20 --sl-bricks 3 --direction long --json

  # Show deployed strategies
  nf-strategy status --json

  # Remove all rules from a strategy
  nf-strategy teardown --group-id <uuid> --json
""",
    )

    sub = parser.add_subparsers(dest="command", help="Command")

    # ---- list ----
    p_list = sub.add_parser("list", help="List available strategy templates")
    p_list.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- deploy ----
    p_deploy = sub.add_parser("deploy", help="Deploy a strategy template",
                              formatter_class=argparse.RawDescriptionHelpFormatter)
    p_deploy.add_argument("template", help="Strategy template name (orb, breakout, mean-reversion, vwap-bounce, scalp)")
    p_deploy.add_argument("--symbol", help="Stock symbol (required for equity, optional for F&O if --underlying is given)")

    # Common params
    p_deploy.add_argument("--capital", type=float, help="Capital to allocate (₹)")
    p_deploy.add_argument("--risk-percent", type=float, help="Risk %% of capital (default: varies by template)")
    p_deploy.add_argument("--rr-ratio", type=float, help="Reward:Risk ratio (default: varies)")
    p_deploy.add_argument("--entry", type=float, help="Entry price")
    p_deploy.add_argument("--sl", type=float, help="Stop-loss price")
    p_deploy.add_argument("--target", type=float, help="Target price (auto-calc if omitted)")
    p_deploy.add_argument("--product", choices=["D", "I"], help="D=Delivery, I=Intraday (default: I)")
    p_deploy.add_argument("--trail-percent", type=float, help="Trailing stop %% (default: varies)")
    p_deploy.add_argument("--side", choices=["long", "short", "both"], help="Trade direction")
    p_deploy.add_argument("--squareoff-time", help="Auto square-off time HH:MM IST (default: 15:15)")
    p_deploy.add_argument("--max-entries", type=int, help="Max entries for scalp template")
    p_deploy.add_argument("--expires", help="Expiry: 'today' (default) or ISO datetime")

    # ORB-specific
    p_deploy.add_argument("--range-high", type=float, help="ORB: opening range high")
    p_deploy.add_argument("--range-low", type=float, help="ORB: opening range low")
    p_deploy.add_argument("--enable-reversal", action="store_true",
                          help="ORB: when target hits, re-enable opposite direction entry for fade/reversal")

    # VWAP-specific
    p_deploy.add_argument("--vwap", type=float, help="VWAP bounce: current VWAP price")

    # Mean reversion
    p_deploy.add_argument("--rsi-entry", type=float, help="RSI entry threshold (default: 30 long, 70 short)")
    p_deploy.add_argument("--rsi-exit", type=float, help="RSI exit threshold (default: 70 long, 30 short)")
    p_deploy.add_argument("--rsi-timeframe", choices=["1m", "5m", "15m", "30m", "1h"], help="RSI timeframe")
    p_deploy.add_argument("--entry-price", type=float, help="Approximate entry price for sizing")

    # F&O-specific params
    p_deploy.add_argument("--underlying", type=str, help="F&O: underlying symbol (e.g. BANKNIFTY)")
    p_deploy.add_argument("--expiry", type=str, help="F&O: expiry date YYYY-MM-DD")
    p_deploy.add_argument("--lots", type=int, help="F&O: number of lots")
    p_deploy.add_argument("--strike", type=float, help="F&O: strike price (straddle)")
    p_deploy.add_argument("--call-strike", type=float, help="F&O: call strike (strangle)")
    p_deploy.add_argument("--put-strike", type=float, help="F&O: put strike (strangle)")
    p_deploy.add_argument("--buy-strike", type=float, help="F&O: buy strike (spreads)")
    p_deploy.add_argument("--sell-strike", type=float, help="F&O: sell strike (spreads)")
    p_deploy.add_argument("--call-sell-strike", type=float, help="F&O: call sell strike (iron condor)")
    p_deploy.add_argument("--call-buy-strike", type=float, help="F&O: call buy strike (iron condor)")
    p_deploy.add_argument("--put-sell-strike", type=float, help="F&O: put sell strike (iron condor)")
    p_deploy.add_argument("--put-buy-strike", type=float, help="F&O: put buy strike (iron condor)")
    p_deploy.add_argument("--direction", help="Direction: long/short/both (renko) or buy/sell (F&O)")
    p_deploy.add_argument("--entry-time", type=str, help="F&O: entry time HH:MM")

    # Renko-specific
    p_deploy.add_argument("--brick-size", type=float, help="Renko: brick size in ₹ (default: 15)")
    p_deploy.add_argument("--sl-bricks", type=int, help="Renko: SL distance in bricks (default: 2)")

    p_deploy.add_argument("--dry-run", action="store_true", help="Preview rules without creating them")
    p_deploy.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- status ----
    p_status = sub.add_parser("status", help="Show deployed strategy status")
    p_status.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- teardown ----
    p_teardown = sub.add_parser("teardown", help="Remove all rules from a strategy group")
    p_teardown.add_argument("--group-id", required=True, help="Strategy group ID (UUID)")
    p_teardown.add_argument("--json", action="store_true", help="Output as JSON")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "list":
        cmd_list(args)
    elif args.command == "deploy":
        cmd_deploy(args)
    elif args.command == "status":
        cmd_status(args)
    elif args.command == "teardown":
        cmd_teardown(args)


if __name__ == "__main__":
    main()
