        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # --- Equity ---
  nf-monitor add-rule --name "RELIANCE SL" --symbol RELIANCE \\
    --trigger price --condition lte --price 2400 \\
    --action place_order --side SELL --qty 10 --product I --json

  nf-monitor add-oco --symbol RELIANCE --qty 10 --product I \\
    --sl 2400 --target 2700 --expires today --json

  nf-monitor add-trailing --symbol RELIANCE --qty 10 --trail-percent 15 \\
    --product D --expires today --json

  # --- F&O Options (use --underlying/--expiry/--strike/--option-type) ---
  nf-monitor add-oco --underlying BANKNIFTY --expiry 2026-03-12 --strike 48000 \\
    --option-type CE --qty 30 --sl 180 --target 260 --product D --json

  nf-monitor add-trailing --underlying BANKNIFTY --expiry 2026-03-12 --strike 48000 \\
    --option-type CE --qty 30 --trail-percent 15 --product D --json

  nf-monitor add-rule --name "NIFTY PE SL" --underlying NIFTY --expiry 2026-03-13 \\
    --strike 25000 --option-type PE --trigger price --condition lte --price 100 \\
    --action place_order --side SELL --qty 75 --product D --json

  # --- Compound triggers (multiple conditions, AND/OR) ---
  nf-monitor add-rule --name "RELIANCE multi-condition entry" --symbol RELIANCE \\
    --trigger compound --operator and \\
    --sub-condition "price:gte:2450" \\
    --sub-condition "indicator:rsi:lte:30:5m" \\
    --action place_order --side BUY --qty 10 --product I --max-fires 1 --json

  nf-monitor add-rule --name "INFY time+price" --symbol INFY \\
    --trigger compound --operator and \\
    --sub-condition "time:14:30" \\
    --sub-condition "price:gte:1800" \\
    --action place_order --side BUY --qty 5 --product I --json

  nf-monitor add-rule --name "TCS any condition" --symbol TCS \\
    --trigger compound --operator or \\
    --sub-condition "price:lte:3500" \\
    --sub-condition "indicator:rsi:lte:25:15m" \\
    --action place_order --side BUY --qty 5 --product D --json

  # --- Management ---
  nf-monitor list --active --json
  nf-monitor enable 5
  nf-monitor disable 5
  nf-monitor delete 5
  nf-monitor logs --rule 5 --limit 10 --json
  nf-monitor start --paper            # Start daemon in paper mode
""",
    )

    sub = parser.add_subparsers(dest="command", help="Command")

    # ---- add-rule ----
    p_add = sub.add_parser("add-rule", help="Create a monitoring rule")
    p_add.add_argument("--name", required=True, help="Human-readable rule name")
    p_add.add_argument("--symbol", help="Stock symbol (for equity)")
    p_add.add_argument("--underlying", help="Option underlying (NIFTY, BANKNIFTY, etc.)")
    p_add.add_argument("--expiry", dest="expiry_date", help="Option expiry (YYYY-MM-DD)")
    p_add.add_argument("--strike", type=float, help="Option strike price")
    p_add.add_argument("--option-type", dest="opt_type", choices=["CE", "PE"], help="CE (Call) or PE (Put)")

    # Trigger
    p_add.add_argument("--trigger", required=True,
                       choices=["price", "time", "indicator", "order_status", "compound"],
                       help="Trigger type")
    # Compound trigger args
    p_add.add_argument("--operator", choices=["and", "or"], default="and",
                       help="Compound operator (default: and)")
    p_add.add_argument("--sub-condition", action="append", dest="sub_conditions",
                       help="Compound sub-condition (repeatable). Formats: "
                            "price:COND:PRICE[:REF], indicator:NAME:COND:VALUE[:TF], time:HH:MM")
    # Price trigger args
    p_add.add_argument("--condition", choices=["lte", "gte", "crosses_above", "crosses_below"],
                       help="Trigger condition")
    p_add.add_argument("--price", type=float, help="Trigger price level")
    p_add.add_argument("--reference", default="ltp",
                       choices=["ltp", "bid", "ask", "open", "high", "low"],
                       help="Price reference (default: ltp)")
    # Time trigger args
    p_add.add_argument("--at", help="Time in HH:MM IST (for time trigger)")
    p_add.add_argument("--on-days", help="Comma-separated days: mon,tue,wed,thu,fri")
    p_add.add_argument("--market-only", action="store_true", default=True,
                       help="Only fire when market is open (default: true)")
    # Indicator trigger args
    p_add.add_argument("--indicator", choices=["rsi", "macd", "ema_crossover", "volume_spike", "vwap", "bollinger", "supertrend"],
                       help="Indicator name")
    p_add.add_argument("--timeframe", choices=["1m", "5m", "15m", "30m", "1h", "1d"],
                       help="Candle timeframe (default: 5m)")
    p_add.add_argument("--ind-value", type=float, help="Indicator threshold value")
    # Order status trigger args
