    # ---- add-trailing ----
    p_trail = sub.add_parser("add-trailing", help="Create a trailing stop-loss rule",
                             formatter_class=argparse.RawDescriptionHelpFormatter,
                             epilog="""
Option contract example:
  nf-monitor add-trailing --underlying BANKNIFTY --expiry 2026-03-12 --strike 48000 \\
    --option-type CE --qty 30 --trail-percent 15 --product D --json
""")
    p_trail.add_argument("--symbol", help="Stock symbol (for equity)")
    p_trail.add_argument("--underlying", help="Option underlying (NIFTY, BANKNIFTY, etc.)")
    p_trail.add_argument("--expiry", dest="expiry_date", help="Option expiry (YYYY-MM-DD)")
    p_trail.add_argument("--strike", type=float, help="Option strike price")
    p_trail.add_argument("--option-type", dest="opt_type", choices=["CE", "PE"], help="CE (Call) or PE (Put)")
