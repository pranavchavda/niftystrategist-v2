if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import init_client, print_error, print_json, print_success, run_async, validate_symbol  # noqa: E402


def _resolve_option_instrument(underlying: str, expiry: str, strike: float,
                                option_type: str) -> tuple[str, str]:
    """Resolve an option contract to (tradingsymbol, instrument_key).

    Uses the nf-options cache. Returns (tradingsymbol, instrument_key) or
    calls print_error (exits) if not found.
    """
    # Import nf-options cache machinery
    sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

    # Load the options cache directly (same code as nf-options)
    import csv
    cache_path = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), ".cache", "nse_instruments.csv")
    if not os.path.exists(cache_path):
        print_error("Instruments cache not found. Run nf-quote first to download.")

    # Search for the option
    underlying = underlying.upper()
    option_type = option_type.upper()
    candidates = []

    with open(cache_path, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        for row in reader:
            if row.get("instrument_type") not in ("OPTIDX", "OPTSTK"):
                continue
            if row.get("name") != underlying:
                continue
            if float(row.get("strike") or 0) != strike:
                continue
            if row.get("option_type") != option_type:
                continue
            cache_expiry = row.get("expiry", "")
            # Match expiry: YYYY-MM-DD exact, or partial match
            if expiry in cache_expiry or cache_expiry == expiry:
                candidates.append(row)

    if not candidates:
        print_error(
            f"Option not found: {underlying} {expiry} {strike} {option_type}. "
            f"Run 'nf-options expiries {underlying}' to see valid expiries."
        )

    # Take first match (sorted by expiry proximity)
    candidates.sort(key=lambda r: r.get("expiry", ""))
    best = candidates[0]
    return best.get("tradingsymbol", ""), best.get("instrument_key", "")


def _parse_condition(s: str) -> dict:
    """Parse a compound condition string into a sub-trigger config dict.

    Formats:
      price:CONDITION:PRICE[:REFERENCE]
      indicator:NAME:CONDITION:VALUE[:TIMEFRAME]
      time:HH:MM
    """
    parts = s.split(":")
    if not parts:
        print_error(f"Empty condition string")

    ctype = parts[0].lower()

    if ctype == "price":
        # price:CONDITION:PRICE[:REFERENCE]
        if len(parts) < 3:
            print_error(f"Price condition needs at least 3 parts (price:CONDITION:PRICE), got: {s}")
        condition = parts[1]
        if condition not in ("lte", "gte", "crosses_above", "crosses_below"):
            print_error(f"Invalid price condition '{condition}' in: {s}")
        try:
            price = float(parts[2])
        except ValueError:
            print_error(f"Invalid price value '{parts[2]}' in: {s}")
        reference = parts[3] if len(parts) > 3 else "ltp"
        return {"type": "price", "condition": condition, "price": price, "reference": reference}

    elif ctype == "indicator":
        # indicator:NAME:CONDITION:VALUE[:TIMEFRAME]
        if len(parts) < 4:
            print_error(f"Indicator condition needs at least 4 parts (indicator:NAME:CONDITION:VALUE), got: {s}")
        indicator = parts[1]
        condition = parts[2]
        if condition not in ("lte", "gte", "crosses_above", "crosses_below"):
            print_error(f"Invalid indicator condition '{condition}' in: {s}")
        try:
            value = float(parts[3])
        except ValueError:
            print_error(f"Invalid indicator value '{parts[3]}' in: {s}")
        timeframe = parts[4] if len(parts) > 4 else "5m"
        return {"type": "indicator", "indicator": indicator, "condition": condition, "value": value, "timeframe": timeframe}

    elif ctype == "time":
        # time:HH:MM
        if len(parts) < 2:
            print_error(f"Time condition needs at least 2 parts (time:HH:MM), got: {s}")
        # Rejoin remaining parts in case HH:MM was split
        time_val = ":".join(parts[1:])
        return {"type": "time", "at": time_val}

    else:
        print_error(f"Unknown condition type '{ctype}' in: {s}. Must be price, indicator, or time.")


def _get_user_id() -> int:
    """Get user ID from environment."""
    return int(os.environ.get("NF_USER_ID", "999"))


def _parse_expires(value: str) -> datetime:
    """Parse --expires value into a naive UTC datetime.

    Accepts:
      - "today" → today at 15:30 IST (= 10:00 UTC), or next day if past
      - ISO datetime string (assumed UTC if no timezone)
    """
    if value.lower() == "today":
        now = datetime.utcnow()
        # IST is UTC+5:30. Market close is 15:30 IST = 10:00 UTC
        today_close_utc = now.replace(hour=10, minute=0, second=0, microsecond=0)
        if now > today_close_utc:
            today_close_utc += timedelta(days=1)
        return today_close_utc
    else:
        try:
            return datetime.fromisoformat(value)
        except ValueError:
            print_error(f"Invalid expires value: {value}. Use 'today' or ISO datetime (e.g. 2025-01-15T10:00:00)")


def _fmt_ist(dt: datetime | None) -> str | None:
    """Format a naive UTC datetime as an IST string for display."""
    if dt is None:
        return None
    ist = dt + timedelta(hours=5, minutes=30)
    return f"{ist.strftime('%Y-%m-%d %H:%M')} IST"


def _rule_to_dict(rule) -> dict:
    """Convert a DB rule object to a JSON-serializable dict."""
    d = {
        "id": rule.id,
        "name": rule.name,
        "enabled": rule.enabled,
        "trigger_type": rule.trigger_type,
        "trigger_config": rule.trigger_config,
        "action_type": rule.action_type,
        "action_config": rule.action_config,
        "symbol": rule.symbol,
        "linked_trade_id": rule.linked_trade_id,
        "linked_order_id": rule.linked_order_id,
        "group_id": getattr(rule, "group_id", None),
        "strategy_name": getattr(rule, "strategy_name", None),
        "fire_count": rule.fire_count,
        "max_fires": rule.max_fires,
        "expires_at": _fmt_ist(rule.expires_at) if rule.expires_at else None,
        "fired_at": _fmt_ist(rule.fired_at) if rule.fired_at else None,
        "created_at": _fmt_ist(rule.created_at) if rule.created_at else None,
    }
    # Add computed fields for trailing stop rules
    if rule.trigger_type == "trailing_stop":
        tc = rule.trigger_config or {}
        tp = tc.get("trail_percent", 0)
        direction = tc.get("direction", "long")
        if direction == "short":
            lp = tc.get("lowest_price", tc.get("initial_price", 0))
            d["stop_price"] = round(lp * (1 + tp / 100), 2) if lp else None
            d["lowest_price"] = lp
        else:
            hp = tc.get("highest_price", 0)
            d["stop_price"] = round(hp * (1 - tp / 100), 2) if hp else None
            d["highest_price"] = hp
        d["direction"] = direction
    return d


def _log_to_dict(log) -> dict:
    """Convert a DB log object to a JSON-serializable dict."""
    return {
        "id": log.id,
        "rule_id": log.rule_id,
        "trigger_snapshot": log.trigger_snapshot,
        "action_taken": log.action_taken,
        "action_result": log.action_result,
        "created_at": _fmt_ist(log.created_at) if log.created_at else None,
    }


