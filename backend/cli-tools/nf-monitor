def cmd_add_rule(args):
    """Create a single monitoring rule."""
    from database.session import get_db_context
    from monitor.crud import create_rule
    from services.instruments_cache import get_instrument_key

    user_id = _get_user_id()

    # Validate symbol if provided — support both equity and option contracts
    symbol = None
    instrument_token = None
    is_option = bool(getattr(args, 'underlying', None) and getattr(args, 'strike', None) and getattr(args, 'opt_type', None))

    if is_option:
        tradingsymbol, instrument_token = _resolve_option_instrument(
            args.underlying, getattr(args, 'expiry_date', '') or '', args.strike, args.opt_type
        )
        symbol = tradingsymbol
        if not instrument_token:
            print_error(f"Could not resolve instrument key for {args.underlying} {getattr(args, 'expiry_date', '')} {args.strike} {args.opt_type}")
    elif args.symbol:
        symbol = validate_symbol(args.symbol)
        # Look up instrument token for price/indicator triggers (needed for WebSocket subscription)
        instrument_token = get_instrument_key(symbol)

    # Build trigger config
    trigger_type = args.trigger
    trigger_config = {}

    if trigger_type == "price":
        if not args.condition or args.price is None:
            print_error("Price trigger requires --condition and --price")
        trigger_config = {
            "condition": args.condition,
            "price": args.price,
            "reference": args.reference or "ltp",
        }

    elif trigger_type == "time":
        if not args.at:
            print_error("Time trigger requires --at HH:MM")
        on_days = ["mon", "tue", "wed", "thu", "fri"]
        if args.on_days:
            on_days = [d.strip().lower() for d in args.on_days.split(",")]
        trigger_config = {
            "at": args.at,
            "on_days": on_days,
            "market_only": args.market_only,
        }

    elif trigger_type == "indicator":
        if not args.indicator or not args.condition or args.ind_value is None:
            print_error("Indicator trigger requires --indicator, --condition, and --ind-value")
        trigger_config = {
            "indicator": args.indicator,
            "timeframe": args.timeframe or "5m",
            "condition": args.condition,
            "value": args.ind_value,
        }

    elif trigger_type == "order_status":
        if not args.order_id or not args.status:
            print_error("Order status trigger requires --order-id and --status")
        trigger_config = {
            "order_id": args.order_id,
            "status": args.status,
        }

    elif trigger_type == "compound":
        conditions = getattr(args, "sub_conditions", None) or []
        if len(conditions) < 2:
            print_error("Compound trigger requires at least 2 --sub-condition flags")
        parsed = []
        for c in conditions:
            parsed.append(_parse_condition(c))
        trigger_config = {
            "operator": args.operator or "and",
            "conditions": parsed,
        }

    else:
        print_error(f"Unknown trigger type: {trigger_type}")

    # Build action config
    action_type = args.action
    action_config = {}

    if action_type == "place_order":
        if not symbol:
            print_error("place_order action requires --symbol or --underlying/--strike/--option-type")
        if not args.side or not args.qty:
            print_error("place_order action requires --side and --qty")
        action_config = {
            "symbol": symbol,
            "transaction_type": args.side.upper(),
            "quantity": args.qty,
            "order_type": args.order_type or "MARKET",
            "product": args.product or "I",
        }
        if args.limit_price is not None:
            action_config["price"] = args.limit_price
        if is_option:
            action_config["instrument_token"] = instrument_token

    elif action_type == "cancel_order":
        if not args.cancel_order_id:
            print_error("cancel_order action requires --cancel-order-id")
        action_config = {"order_id": args.cancel_order_id}

    elif action_type == "cancel_rule":
        if not args.cancel_rule_id:
            print_error("cancel_rule action requires --cancel-rule-id")
        action_config = {"rule_id": args.cancel_rule_id}

    else:
        print_error(f"Unknown action type: {action_type}")

    # Parse expires
    expires_at = None
    if args.expires:
        expires_at = _parse_expires(args.expires)

    async def _create():
        async with get_db_context() as session:
            rule = await create_rule(
                session=session,
                user_id=user_id,
                name=args.name,
                trigger_type=trigger_type,
                trigger_config=trigger_config,
                action_type=action_type,
                action_config=action_config,
                instrument_token=instrument_token,
                symbol=symbol,
                linked_trade_id=args.linked_trade,
                linked_order_id=args.linked_order,
                max_fires=args.max_fires,
                expires_at=expires_at,
            )
            return rule

    rule = run_async(_create())

    if args.json:
        print_json({"created": _rule_to_dict(rule)})
    else:
        print_success(f"Rule #{rule.id} created: {rule.name}")
        print(f"  Trigger: {trigger_type} → {trigger_config}")
        print(f"  Action:  {action_type} → {action_config}")
        if expires_at:
            print(f"  Expires: {_fmt_ist(expires_at)}")
        if args.max_fires:
            print(f"  Max fires: {args.max_fires}")


def cmd_add_oco(args):
    """Create a stop-loss + target OCO pair (two linked rules).

    Supports both LONG and SHORT positions via --side:
      --side SELL (default): Exit a LONG position. SL fires when price drops (lte), target fires when price rises (gte).
      --side BUY:            Exit a SHORT position. SL fires when price rises (gte), target fires when price drops (lte).

    For option contracts, use --underlying/--expiry/--strike/--option-type instead of --symbol.
    The monitor will track the option PREMIUM price, not the underlying spot price.
    """
    from database.session import get_db_context
    from monitor.crud import create_rule, update_rule
    from services.instruments_cache import get_instrument_key

    user_id = _get_user_id()

    # Determine if this is an option contract or equity
    is_option = bool(args.underlying and args.strike and args.opt_type)

    if is_option:
        tradingsymbol, instrument_token = _resolve_option_instrument(
            args.underlying, args.expiry_date or "", args.strike, args.opt_type
        )
        symbol = tradingsymbol  # Use tradingsymbol as the rule symbol
        if not instrument_token:
            print_error(f"Could not resolve instrument key for {args.underlying} {args.expiry_date} {args.strike} {args.opt_type}")
    else:
        if not args.symbol:
            print_error("Either --symbol (for equity) or --underlying/--strike/--option-type (for options) is required")
        symbol = validate_symbol(args.symbol)
        instrument_token = get_instrument_key(symbol)
        if not instrument_token:
            print_error(f"Could not find instrument key for {symbol}")

    # Determine exit side and trigger directions
    exit_side = (args.side or "SELL").upper()
    if exit_side == "SELL":
        # Exiting a LONG: SL fires below entry (price drops), target fires above (price rises)
        sl_condition = "lte"
        target_condition = "gte"
    elif exit_side == "BUY":
        # Exiting a SHORT: SL fires above entry (price rises), target fires below (price drops)
        sl_condition = "gte"
        target_condition = "lte"
    else:
        print_error(f"Invalid --side: {exit_side}. Must be BUY or SELL.")

    expires_at = None
    if args.expires:
        expires_at = _parse_expires(args.expires)

    # Build action_config — include instrument_token for F&O contracts
    base_action_config = {
        "symbol": symbol,
        "transaction_type": exit_side,
        "quantity": args.qty,
        "order_type": "MARKET",
        "product": args.product,
    }
    if is_option:
        base_action_config["instrument_token"] = instrument_token

    async def _create_oco():
        async with get_db_context() as session:
            # Step 1: Create the SL rule (placeholder cancel_rule target)
            sl_rule = await create_rule(
                session=session,
                user_id=user_id,
                name=f"{symbol} OCO Stop-Loss @ {args.sl}",
                trigger_type="price",
                trigger_config={
                    "condition": sl_condition,
                    "price": args.sl,
                    "reference": "ltp",
                },
                action_type="place_order",
                action_config=base_action_config.copy(),
                instrument_token=instrument_token,
                symbol=symbol,
                linked_trade_id=args.linked_trade,
                max_fires=1,
                expires_at=expires_at,
            )

            # Step 2: Create the target rule (cancels SL rule on fire)
            target_action = base_action_config.copy()
            target_action["also_cancel_rule"] = sl_rule.id
            target_rule = await create_rule(
                session=session,
                user_id=user_id,
                name=f"{symbol} OCO Target @ {args.target}",
                trigger_type="price",
                trigger_config={
                    "condition": target_condition,
                    "price": args.target,
                    "reference": "ltp",
                },
                action_type="place_order",
                action_config=target_action,
                instrument_token=instrument_token,
                symbol=symbol,
                linked_trade_id=args.linked_trade,
                max_fires=1,
                expires_at=expires_at,
            )

            # Step 3: Update SL rule action to also cancel target rule
            sl_action = sl_rule.action_config.copy()
            sl_action["also_cancel_rule"] = target_rule.id
            await update_rule(session, sl_rule.id, action_config=sl_action)

            # Refresh SL rule to get updated data
            from monitor.crud import get_rule
            sl_rule = await get_rule(session, sl_rule.id)

            return sl_rule, target_rule

    sl_rule, target_rule = run_async(_create_oco())

    sl_cond_str = "≤" if sl_condition == "lte" else "≥"
    tgt_cond_str = "≥" if target_condition == "gte" else "≤"

    if args.json:
        print_json({
            "oco": True,
            "exit_side": exit_side,
            "sl_rule": _rule_to_dict(sl_rule),
            "target_rule": _rule_to_dict(target_rule),
        })
    else:
        position_type = "LONG" if exit_side == "SELL" else "SHORT"
        print_success(f"OCO pair created for {symbol} ({position_type} exit)")
        print(f"  SL Rule     #{sl_rule.id}: price {sl_cond_str} {args.sl} → {exit_side} {args.qty}")
        print(f"  Target Rule #{target_rule.id}: price {tgt_cond_str} {args.target} → {exit_side} {args.qty}")
        if expires_at:
            print(f"  Expires: {_fmt_ist(expires_at)}")
        if args.linked_trade:
            print(f"  Linked trade: #{args.linked_trade}")


def cmd_add_trailing(args):
    """Create a trailing stop-loss rule that auto-adjusts as price moves.

    Supports both LONG and SHORT positions via --side:
      --side SELL (default): Exit a LONG. Trail tracks highest price, fires when price drops below trail.
      --side BUY:            Exit a SHORT. Trail tracks lowest price, fires when price rises above trail.

    For option contracts, use --underlying/--expiry/--strike/--option-type instead of --symbol.
    The monitor will trail the option PREMIUM price, not the underlying spot price.
    """
    from database.session import get_db_context
    from monitor.crud import create_rule
    from services.instruments_cache import get_instrument_key

    user_id = _get_user_id()

    # Determine if this is an option contract or equity
    is_option = bool(args.underlying and args.strike and args.opt_type)

    if is_option:
        tradingsymbol, instrument_token = _resolve_option_instrument(
            args.underlying, args.expiry_date or "", args.strike, args.opt_type
        )
        symbol = tradingsymbol
        if not instrument_token:
            print_error(f"Could not resolve instrument key for {args.underlying} {args.expiry_date} {args.strike} {args.opt_type}")
    else:
        if not args.symbol:
            print_error("Either --symbol (for equity) or --underlying/--strike/--option-type (for options) is required")
        symbol = validate_symbol(args.symbol)
        instrument_token = get_instrument_key(symbol)
        if not instrument_token:
            print_error(f"Could not find instrument key for {symbol}")

    exit_side = (args.side or "SELL").upper()
    if exit_side not in ("BUY", "SELL"):
        print_error(f"Invalid --side: {exit_side}. Must be BUY or SELL.")

    # Fetch current LTP to set initial_price and highest/lowest price
    client = init_client()

    async def _get_ltp():
        if is_option:
            # For F&O, use greeks API with the instrument_key
            greeks = await client.get_option_greeks([instrument_token])
            if greeks:
                gdata = list(greeks.values())[0]
                return gdata.get("last_price")
            return None
        else:
            quote = await client.get_quote(symbol)
            return quote["ltp"]

    ltp = run_async(_get_ltp())
    if ltp is None:
        print_error(f"Could not fetch LTP for {symbol}")

    trail_pct = args.trail_percent

    if exit_side == "SELL":
        # LONG exit: track highest price, stop below
        stop_price = ltp * (1 - trail_pct / 100)
        name = args.name or f"{symbol} Trailing SL {trail_pct}%"
        trigger_config = {
            "trail_percent": trail_pct,
            "initial_price": ltp,
            "highest_price": ltp,
            "direction": "long",
            "reference": args.reference or "ltp",
        }
    else:
        # SHORT exit: track lowest price, stop above
        stop_price = ltp * (1 + trail_pct / 100)
        name = args.name or f"{symbol} Trailing SL (short) {trail_pct}%"
        trigger_config = {
            "trail_percent": trail_pct,
            "initial_price": ltp,
            "lowest_price": ltp,
            "direction": "short",
            "reference": args.reference or "ltp",
        }

    action_config = {
        "symbol": symbol,
        "transaction_type": exit_side,
        "quantity": args.qty,
        "order_type": "MARKET",
        "product": args.product or "I",
    }
    if is_option:
        action_config["instrument_token"] = instrument_token

    expires_at = None
    if args.expires:
        expires_at = _parse_expires(args.expires)

    async def _create():
        async with get_db_context() as session:
            rule = await create_rule(
                session=session,
                user_id=user_id,
                name=name,
                trigger_type="trailing_stop",
                trigger_config=trigger_config,
                action_type="place_order",
                action_config=action_config,
                instrument_token=instrument_token,
                symbol=symbol,
                max_fires=args.max_fires or 1,
                expires_at=expires_at,
            )
            return rule

    rule = run_async(_create())

    if args.json:
        print_json({
            "created": _rule_to_dict(rule),
            "stop_price": round(stop_price, 2),
            "ltp_at_creation": ltp,
            "exit_side": exit_side,
        })
    else:
        pos_type = "LONG" if exit_side == "SELL" else "SHORT"
        print_success(f"Trailing SL rule #{rule.id}: {name} ({pos_type} exit)")
        print(f"  Symbol:       {symbol}")
        print(f"  Current LTP:  {ltp}")
        print(f"  Trail:        {trail_pct}%")
        print(f"  Initial Stop: {stop_price:.2f}")
        print(f"  Exit:         {exit_side} {args.qty} ({args.product or 'I'})")
        if expires_at:
            print(f"  Expires:      {_fmt_ist(expires_at)}")


def cmd_list(args):
    """List monitoring rules."""
    from database.session import get_db_context
    from monitor.crud import list_rules

    user_id = _get_user_id()

    async def _list():
        async with get_db_context() as session:
            return await list_rules(session, user_id, enabled_only=args.active)

    rules = run_async(_list())

    if args.json:
        print_json({"rules": [_rule_to_dict(r) for r in rules]})
        return

    if not rules:
        print("No monitor rules found.")
        return

    label = "Active Rules" if args.active else "All Rules"
    print(f"{label}\n")
    print(f"{'ID':>4}  {'Status':<8}  {'Name':<30}  {'Trigger':<14}  {'Action':<14}  {'Fires':>7}")
    print("-" * 85)

    for r in rules:
        status = "ON" if r.enabled else "OFF"
        fires = f"{r.fire_count}" + (f"/{r.max_fires}" if r.max_fires else "")
        name = r.name[:28] + ".." if len(r.name) > 30 else r.name
        print(f"{r.id:>4}  {status:<8}  {name:<30}  {r.trigger_type:<14}  {r.action_type:<14}  {fires:>7}")


def cmd_enable(args):
    """Enable a rule."""
    from database.session import get_db_context
    from monitor.crud import enable_rule

    async def _enable():
        async with get_db_context() as session:
            return await enable_rule(session, args.rule_id)

    rule = run_async(_enable())
    if not rule:
        print_error(f"Rule #{args.rule_id} not found")

    if args.json:
        print_json({"enabled": _rule_to_dict(rule)})
    else:
        print_success(f"Rule #{rule.id} enabled: {rule.name}")


