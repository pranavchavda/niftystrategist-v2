#!/usr/bin/env python3
"""Place, view, modify, and cancel stock orders.

NOTE: place, cancel, modify, exit-all, and cancel-all subcommands are HITL-protected —
they require user approval when called from the orchestrator via execute_bash.
When called directly from the terminal, they execute immediately.
"""

import argparse
import sys
import os

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import SYMBOLS, format_inr, init_client, print_error, print_json, print_success, run_async, validate_symbol  # noqa: E402
from services.order_node_proxy import init_order_client  # noqa: E402


def place_order(symbol: str, action: str, quantity: int, order_type: str,
                price: float | None, stop_loss: float | None, target: float | None,
                dry_run: bool, as_json: bool, amo: bool = False, product: str = "D"):
    """Place a buy or sell order."""
    sym = validate_symbol(symbol)
    act = action.upper()
    if act not in ("BUY", "SELL"):
        print_error(f"Action must be BUY or SELL, got: {act}")
    if order_type == "LIMIT" and price is None:
        print_error("Limit orders require --price.")
    if quantity < 1:
        print_error("Quantity must be at least 1.")

    client = init_client()

    # Get current price for context
    try:
        quote = run_async(client.get_quote(sym))
        ltp = quote["ltp"]
    except Exception:
        ltp = None

    if dry_run:
        result = {
            "dry_run": True,
            "symbol": sym,
            "action": act,
            "quantity": quantity,
            "order_type": order_type,
            "price": price,
            "product": product,
            "current_ltp": ltp,
            "stop_loss": stop_loss,
            "target": target,
            "estimated_value": (price or ltp or 0) * quantity,
        }
        if as_json:
            print_json(result)
        else:
            print(f"🔍 Dry Run — order NOT placed\n")
            print(f"  {act} {quantity}x {sym} @ {order_type}")
            print(f"  Product:   {'Intraday (MIS)' if product == 'I' else 'Delivery (CNC)'}")
            if price:
                print(f"  Limit Price: {format_inr(price)}")
            if ltp:
                print(f"  Current LTP: {format_inr(ltp)}")
            print(f"  Est. Value:  {format_inr(result['estimated_value'])}")
            if stop_loss:
                print(f"  Stop Loss:   {format_inr(stop_loss)}")
            if target:
                print(f"  Target:      {format_inr(target)}")
        return

    # Resolve instrument key locally (needed for order node proxy)
    instrument_token = client._get_instrument_key(sym)

    # Route through order node if configured
    order_client = init_order_client()
    if order_client:
        try:
            result = order_client.place_order(
                symbol=sym,
                instrument_token=instrument_token,
                transaction_type=act,
                quantity=quantity,
                order_type=order_type,
                price=price if price else 0,
                product=product,
                is_amo=True if amo else None,
            )
        except Exception as e:
            print_error(f"Order failed: {e}")

        if not result.success:
            print_error(f"Order failed: {result.message}")

        if as_json:
            print_json({
                "success": True,
                "order_id": result.order_id,
                "symbol": sym,
                "action": act,
                "quantity": quantity,
                "order_type": order_type,
                "status": result.status,
                "mode": "live",
            })
        else:
            print_success(f"Order Placed [🔴 LIVE]")
            print(f"\n  {'🟢' if act == 'BUY' else '🔴'} {act} {quantity}x {sym}")
            print(f"  Order ID: {result.order_id}")
            print(f"  Type:     {order_type}")
            print(f"  Status:   {result.status}")
        return

    # Direct path (no order node configured)
    try:
        order_result = run_async(client.place_order(
            symbol=sym,
            transaction_type=act,
            quantity=quantity,
            order_type=order_type,
            price=price if price else 0,
            is_amo=True if amo else None,  # True=force AMO, None=auto-detect
            product=product,
        ))
    except Exception as e:
        print_error(f"Order failed: {e}")

    if not order_result.success:
        print_error(f"Order failed: {order_result.message}")

    if as_json:
        print_json({
            "success": True,
            "order_id": order_result.order_id,
            "symbol": sym,
            "action": act,
            "quantity": quantity,
            "order_type": order_type,
            "executed_price": order_result.executed_price,
            "status": order_result.status,
            "mode": "paper" if client.paper_trading else "live",
        })
    else:
        mode = "Paper" if client.paper_trading else "🔴 LIVE"
        emoji = "🟢" if act == "BUY" else "🔴"
        print_success(f"Order Placed [{mode}]")
        print(f"\n  {emoji} {act} {quantity}x {sym}")
        print(f"  Order ID: {order_result.order_id}")
        print(f"  Type:     {order_type}")
        if order_result.executed_price:
            print(f"  Price:    {format_inr(order_result.executed_price)}")
        print(f"  Status:   {order_result.status}")


def modify_order(order_id: str, quantity: int | None, price: float | None,
                 order_type: str | None, trigger_price: float | None, as_json: bool):
    """Modify an existing pending order."""
    if not any([quantity, price, order_type, trigger_price]):
        print_error("Must specify at least one of: --quantity, --price, --type, --trigger-price")

    order_client = init_order_client()
    if order_client:
        try:
            result = order_client.modify_order(
                order_id=order_id,
                quantity=quantity,
                price=price,
                order_type=order_type,
                trigger_price=trigger_price,
            )
        except Exception as e:
            print_error(f"Failed to modify order: {e}")

        if as_json:
            print_json({"success": result.success, "order_id": result.order_id, "message": result.message})
        elif result.success:
            print_success(f"Order {order_id} modified.")
            if quantity:
                print(f"  New quantity: {quantity}")
            if price:
                print(f"  New price:    {format_inr(price)}")
            if order_type:
                print(f"  New type:     {order_type}")
            if trigger_price:
                print(f"  New trigger:  {format_inr(trigger_price)}")
        else:
            print_error(f"Modify failed: {result.message}")
        return

    client = init_client()
    try:
        result = run_async(client.modify_order(
            order_id=order_id,
            quantity=quantity,
            price=price,
            order_type=order_type,
            trigger_price=trigger_price,
        ))
    except Exception as e:
        print_error(f"Failed to modify order: {e}")

    if as_json:
        print_json(result)
    elif result.get("success"):
        print_success(f"Order {order_id} modified.")
        if quantity:
            print(f"  New quantity: {quantity}")
        if price:
            print(f"  New price:    {format_inr(price)}")
        if order_type:
            print(f"  New type:     {order_type}")
        if trigger_price:
            print(f"  New trigger:  {format_inr(trigger_price)}")
    else:
        print_error(f"Modify failed: {result.get('message', 'Unknown error')}")


def show_order_detail(order_id: str, as_json: bool):
    """Show details for a specific order."""
    client = init_client()
    try:
        order = run_async(client.get_order_details(order_id))
    except Exception as e:
        print_error(f"Failed to get order details: {e}")

    if not order:
        print_error(f"No details found for order {order_id}")

    if as_json:
        print_json(order)
        return

    print(f"📋 Order Details — {order_id}\n")
    fields = [
        ("Symbol", order.get("symbol")),
        ("Action", order.get("transaction_type")),
        ("Quantity", order.get("quantity")),
        ("Filled", order.get("filled_quantity")),
        ("Pending", order.get("pending_quantity")),
        ("Type", order.get("order_type")),
        ("Price", format_inr(order["price"]) if order.get("price") else "MARKET"),
        ("Avg Price", format_inr(order["average_price"]) if order.get("average_price") else "-"),
        ("Trigger", format_inr(order["trigger_price"]) if order.get("trigger_price") else "-"),
        ("Status", order.get("status")),
        ("Message", order.get("status_message") or "-"),
        ("Product", order.get("product")),
        ("Validity", order.get("validity")),
        ("Exchange", order.get("exchange")),
        ("Placed", order.get("order_timestamp") or "-"),
        ("Exchange TS", order.get("exchange_timestamp") or "-"),
    ]
    for label, val in fields:
        if val is not None:
            print(f"  {label:<14} {val}")


def show_order_history(order_id: str, as_json: bool):
    """Show state transition history for an order."""
    client = init_client()
    try:
        history = run_async(client.get_order_history(order_id))
    except Exception as e:
        print_error(f"Failed to get order history: {e}")

    if not history:
        print_error(f"No history found for order {order_id}")

    if as_json:
        print_json({"order_id": order_id, "transitions": history})
        return

    print(f"📜 Order History — {order_id}\n")
    print(f"{'#':<4} {'Status':<16} {'Qty':>6} {'Price':>12} {'Avg Price':>12} {'Timestamp':<22}")
    print("-" * 76)

    for i, h in enumerate(history, 1):
        status = h.get("status", "?")
        qty = h.get("quantity", "")
        price = format_inr(h["price"]) if h.get("price") else "-"
        avg = format_inr(h["average_price"]) if h.get("average_price") else "-"
        ts = h.get("order_timestamp") or h.get("exchange_timestamp") or "-"
        msg = h.get("status_message") or ""
        print(f"{i:<4} {status:<16} {qty:>6} {price:>12} {avg:>12} {ts:<22}")
        if msg:
            print(f"     └─ {msg}")


def show_order_trades(order_id: str, as_json: bool):
    """Show trade fills for a specific order."""
    client = init_client()
    try:
        trades = run_async(client.get_order_trades(order_id))
    except Exception as e:
        print_error(f"Failed to get order trades: {e}")

    if not trades:
        if as_json:
            print_json({"order_id": order_id, "trades": []})
        else:
            print(f"📭 No trade fills found for order {order_id}.")
        return

    if as_json:
        print_json({"order_id": order_id, "trades": trades})
        return

    print(f"📊 Trade Fills — Order {order_id}\n")
    print(f"{'Trade ID':<14} {'Symbol':<12} {'Action':<6} {'Qty':>6} {'Price':>12} {'Exchange':<8} {'Time':<20}")
    print("-" * 82)

    for t in trades:
        tid = str(t.get("trade_id", ""))[:12]
        sym = t.get("symbol", "?")
        action = t.get("transaction_type", "?")
        qty = t.get("quantity", "")
        price = format_inr(t["price"]) if t.get("price") else "-"
        exch = t.get("exchange", "")
        ts = t.get("exchange_timestamp") or "-"
        print(f"{tid:<14} {sym:<12} {action:<6} {qty:>6} {price:>12} {exch:<8} {ts:<20}")


def show_orders(open_only: bool, limit: int, as_json: bool):
    """Show open or recent orders."""
    client = init_client()
    try:
        orders = run_async(client.get_orders())
    except Exception as e:
        print_error(f"Failed to get orders: {e}")

    if not orders:
        if as_json:
            print_json({"orders": [], "message": "No orders found"})
        else:
            print("📭 No orders found.")
        return

    if open_only:
        orders = [o for o in orders if o.get("status") in ("open", "pending", "trigger_pending")]

    orders = orders[:limit]

    if as_json:
        print_json({"orders": orders})
        return

    label = "Open Orders" if open_only else "Order History"
    print(f"📋 {label}\n")
    print(f"{'Order ID':<12} {'Symbol':<12} {'Action':<6} {'Qty':>5} {'Type':<8} {'Price':>12} {'Status':<12}")
    print("-" * 72)

    status_emoji = {
        "complete": "✅", "executed": "✅", "rejected": "❌",
        "cancelled": "🚫", "open": "⏳", "pending": "⏳",
    }

    for o in orders:
        oid = str(o.get("order_id", ""))[:10]
        price_str = format_inr(o.get("average_price") or o.get("price")) if o.get("average_price") or o.get("price") else "MARKET"
        status = o.get("status", "unknown")
        emoji = status_emoji.get(status.lower(), "❓")
        print(
            f"{oid:<12} {o.get('symbol', '?'):<12} {o.get('transaction_type', '?'):<6} "
            f"{o.get('quantity', 0):>5} {o.get('order_type', '?'):<8} {price_str:>12} {emoji} {status:<10}"
        )


def cancel_order(order_id: str, as_json: bool):
    """Cancel an open order."""
    order_client = init_order_client()
    if order_client:
        try:
            result = order_client.cancel_order(order_id)
        except Exception as e:
            print_error(f"Failed to cancel order: {e}")

        if as_json:
            print_json({"success": result.success, "order_id": result.order_id, "message": result.message})
        elif result.success:
            print_success(f"Order {order_id} cancelled.")
        else:
            print_error(f"Cancel failed: {result.message}")
        return

    client = init_client()
    try:
        result = run_async(client.cancel_order(order_id))
    except Exception as e:
        print_error(f"Failed to cancel order: {e}")

    if as_json:
        print_json(result)
    elif result.get("success"):
        print_success(f"Order {order_id} cancelled.")
    else:
        print_error(f"Cancel failed: {result.get('message', 'Unknown error')}")


def cancel_all_orders(tag: str | None, segment: str | None, as_json: bool):
    """Cancel all open orders."""
    order_client = init_order_client()
    if order_client:
        try:
            result = order_client.cancel_multi_order(tag=tag, segment=segment)
        except Exception as e:
            print_error(f"Failed to cancel orders: {e}")

        if as_json:
            print_json({"success": result.success, "message": result.message})
        elif result.success:
            label = ""
            if tag:
                label += f" with tag '{tag}'"
            if segment:
                label += f" in {segment} segment"
            print_success(f"All open orders{label} cancelled.")
        else:
            print_error(f"Cancel-all failed: {result.message}")
        return

    client = init_client()
    try:
        result = run_async(client.cancel_multi_order(tag=tag, segment=segment))
    except Exception as e:
        print_error(f"Failed to cancel orders: {e}")

    if as_json:
        print_json(result)
    elif result.get("success"):
        label = ""
        if tag:
            label += f" with tag '{tag}'"
        if segment:
            label += f" in {segment} segment"
        print_success(f"All open orders{label} cancelled.")
    else:
        print_error(f"Cancel-all failed: {result.get('message', 'Unknown error')}")


def exit_all_positions(as_json: bool):
    """Exit all open positions."""
    order_client = init_order_client()
    if order_client:
        try:
            result = order_client.exit_all_positions()
        except Exception as e:
            print_error(f"Failed to exit positions: {e}")

        if as_json:
            print_json({"success": result.success, "message": result.message})
        elif result.success:
            print_success("All positions exit orders placed.")
        else:
            print_error(f"Exit-all failed: {result.message}")
        return

    client = init_client()
    try:
        result = run_async(client.exit_all_positions())
    except Exception as e:
        print_error(f"Failed to exit positions: {e}")

    if as_json:
        print_json(result)
    elif result.get("success"):
        print_success("All positions exit orders placed.")
    else:
        print_error(f"Exit-all failed: {result.get('message', 'Unknown error')}")


def main():
    parser = argparse.ArgumentParser(
        prog="nf-order",
        description="Place, view, modify, and cancel stock orders",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  nf-order buy RELIANCE 10                     Market buy 10 shares
  nf-order buy RELIANCE 10 --type LIMIT --price 1450   Limit buy
  nf-order buy RELIANCE 10 --dry-run           Preview without executing
  nf-order sell TCS 5                           Market sell (AMO auto-detected)
  nf-order sell TCS 5 --amo                     Force after-market order
  nf-order list                                 Show open orders
  nf-order list --all --limit 20                Show all recent orders
  nf-order cancel ORDER_ID                      Cancel an order
  nf-order cancel-all                           Cancel all open orders
  nf-order cancel-all --segment EQ              Cancel equity orders only
  nf-order modify ORDER_ID --price 1500         Modify order price
  nf-order modify ORDER_ID --quantity 20        Modify order quantity
  nf-order detail ORDER_ID                      Show order details
  nf-order history ORDER_ID                     Show order state transitions
  nf-order trades ORDER_ID                      Show trade fills for an order
  nf-order exit-all                             Exit ALL open positions (panic)
  nf-order buy RELIANCE 10 --json               JSON output
""",
    )

    sub = parser.add_subparsers(dest="command", help="Command")

    # buy / sell
    for cmd in ("buy", "sell"):
        p = sub.add_parser(cmd, help=f"{cmd.title()} shares")
        p.add_argument("symbol", help="Stock symbol")
        p.add_argument("quantity", type=int, help="Number of shares")
        p.add_argument("--type", dest="order_type", default="MARKET", choices=["MARKET", "LIMIT"], help="Order type")
        p.add_argument("--price", type=float, help="Limit price (required for LIMIT orders)")
        p.add_argument("--sl", type=float, help="Stop loss price")
        p.add_argument("--target", type=float, help="Target price")
        p.add_argument("--product", default="D", choices=["D", "I"],
                       help="Product type: D=Delivery/CNC, I=Intraday/MIS (default: D)")
        p.add_argument("--amo", action="store_true", help="Force after-market order (auto-detected if omitted)")
        p.add_argument("--dry-run", action="store_true", help="Preview order without executing")
        p.add_argument("--json", action="store_true", help="Output as JSON")

    # list
    p_list = sub.add_parser("list", help="Show orders")
    p_list.add_argument("--all", action="store_true", help="Show all orders (not just open)")
    p_list.add_argument("--limit", type=int, default=10, help="Max orders to show (default: 10)")
    p_list.add_argument("--json", action="store_true", help="Output as JSON")

    # cancel
    p_cancel = sub.add_parser("cancel", help="Cancel an open order")
    p_cancel.add_argument("order_id", help="Order ID to cancel")
    p_cancel.add_argument("--json", action="store_true", help="Output as JSON")

    # cancel-all
    p_cancel_all = sub.add_parser("cancel-all", help="Cancel all open orders")
    p_cancel_all.add_argument("--tag", help="Only cancel orders with this tag")
    p_cancel_all.add_argument("--segment", choices=["EQ", "FO"], help="Only cancel orders in this segment")
    p_cancel_all.add_argument("--json", action="store_true", help="Output as JSON")

    # modify
    p_modify = sub.add_parser("modify", help="Modify a pending order")
    p_modify.add_argument("order_id", help="Order ID to modify")
    p_modify.add_argument("--quantity", type=int, help="New quantity")
    p_modify.add_argument("--price", type=float, help="New price")
    p_modify.add_argument("--type", dest="order_type", choices=["MARKET", "LIMIT"], help="New order type")
    p_modify.add_argument("--trigger-price", type=float, help="New trigger price (for SL orders)")
    p_modify.add_argument("--json", action="store_true", help="Output as JSON")

    # detail
    p_detail = sub.add_parser("detail", help="Show details for a specific order")
    p_detail.add_argument("order_id", help="Order ID")
    p_detail.add_argument("--json", action="store_true", help="Output as JSON")

    # history
    p_history = sub.add_parser("history", help="Show order state transitions")
    p_history.add_argument("order_id", help="Order ID")
    p_history.add_argument("--json", action="store_true", help="Output as JSON")

    # trades (fills for a specific order)
    p_trades = sub.add_parser("trades", help="Show trade fills for a specific order")
    p_trades.add_argument("order_id", help="Order ID")
    p_trades.add_argument("--json", action="store_true", help="Output as JSON")

    # exit-all
    p_exit = sub.add_parser("exit-all", help="Exit ALL open positions (panic button)")
    p_exit.add_argument("--json", action="store_true", help="Output as JSON")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command in ("buy", "sell"):
        place_order(
            symbol=args.symbol,
            action=args.command.upper(),
            quantity=args.quantity,
            order_type=args.order_type,
            price=args.price,
            stop_loss=args.sl,
            target=args.target,
            dry_run=args.dry_run,
            as_json=args.json,
            amo=args.amo,
            product=args.product,
        )
    elif args.command == "list":
        show_orders(open_only=not args.all, limit=args.limit, as_json=args.json)
    elif args.command == "cancel":
        cancel_order(args.order_id, as_json=args.json)
    elif args.command == "cancel-all":
        cancel_all_orders(tag=args.tag, segment=args.segment, as_json=args.json)
    elif args.command == "modify":
        modify_order(
            order_id=args.order_id,
            quantity=args.quantity,
            price=args.price,
            order_type=args.order_type,
            trigger_price=args.trigger_price,
            as_json=args.json,
        )
    elif args.command == "detail":
        show_order_detail(args.order_id, as_json=args.json)
    elif args.command == "history":
        show_order_history(args.order_id, as_json=args.json)
    elif args.command == "trades":
        show_order_trades(args.order_id, as_json=args.json)
    elif args.command == "exit-all":
        exit_all_positions(as_json=args.json)


if __name__ == "__main__":
    main()
