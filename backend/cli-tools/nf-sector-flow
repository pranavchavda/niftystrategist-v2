#!/usr/bin/env python3
"""Intraday sector-flow sensor — two layers (read-only market measurement).

WHAT IT ANSWERS
  1. Is the whole TAPE rolling over / ripping intraday, and accelerating? (regime
     layer — the thing NS otherwise only reads at the 9:20 pulse.)
  2. Which sectors are the persistent LAGGARDS / LEADERS net of the market — i.e.
     what to SHORT / LONG to express a regime call — and is any sector DECOUPLING
     from the tape right now? (relative layer — strips market beta.)

WHY RELATIVE: on a broad-down day every sector reads "decisive down" (just beta).
The sector edge only survives net of the market. Validated against the 06-24/06-25
tape: the market layer flagged the 06-25 back-half roll-over; the relative layer
pegged IT as the laggard inside it and isolated Realty decoupling on the flat 06-24
tape. See services/sector_flow.py.

DATA SOURCE: by default reads the CACHED snapshot written by the ~5-min cron
(services/sector_flow_cache.py) — instant, no inline fetch. The live full-universe
fetch trips Upstox's per-token rate limit, so it's precomputed. `--date` replays a
past session inline; `--fresh` forces an inline recompute of the latest session
(slower, may rate-limit).

This tool MEASURES — it never places an order. Thresholds are PROVISIONAL; treat
the numbers as situational awareness, not a standalone entry trigger.

Examples:
  nf-sector-flow                         # latest cached: market state + sector ranking
  nf-sector-flow --sector it --full      # one sector's full relative timeline
  nf-sector-flow --date 2026-06-25       # replay a past session (inline)
  nf-sector-flow --fresh                 # force inline recompute of latest session
  nf-sector-flow --json                  # structured output
"""
import argparse
import asyncio
import os
import sys

_BACKEND = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
for _p in (_BACKEND, os.path.join(_BACKEND, "cli-tools")):
    if _p not in sys.path:
        sys.path.insert(0, _p)

from base import print_json, print_error, run_async  # noqa: E402
from services import instruments_cache as ic  # noqa: E402
from services.sector_flow_cache import (  # noqa: E402
    compute_snapshot, get_latest_snapshot, MARKET_ROLL_DECIS, DECOUPLE_DECIS,
)

# Cached snapshot is "fresh" within this age for default reads (cron runs ~5 min).
CACHE_MAX_AGE_S = 15 * 60


def _resolve_snapshot(args):
    """Return (snapshot, source_note). Cache by default; inline for --date/--fresh."""
    if args.date or args.fresh:
        snap = run_async(compute_snapshot(args.universe, date=args.date,
                                          threshold=args.threshold, window=args.window))
        return snap, ("inline replay" if args.date else "inline fresh")
    snap, age = run_async(get_latest_snapshot(args.universe, CACHE_MAX_AGE_S))
    if snap is None:
        # No fresh cache (cron hasn't run / off-hours / dev). Fall back to inline,
        # but tell the user it may be slow + rate-limited.
        print_error("No fresh cached snapshot — computing inline (may be slow / rate-limited). "
                    "The ~5-min cron populates the cache during market hours.")
        snap = run_async(compute_snapshot(args.universe, threshold=args.threshold, window=args.window))
        return snap, "inline fallback (no cache)"
    return snap, f"cache age {int(age)}s"


def _fmt_market(m, as_of, date, source):
    arrow = "▼" if m["direction"] == "down" else "▲"
    state = (f"ROLLING {m['direction'].upper()}" if m["rolling"] else "quiet")
    gap = "" if m.get("gap") is None else f" · gapped {m['gap']:+.2f}% at open"
    peaked = (f"; day peak {m['peak_decisiveness']:.3f}@{m['peak_at']}"
              if m.get("peak_decisiveness", 0) >= MARKET_ROLL_DECIS and not m["rolling"] else "")
    print(f"\n══ MARKET {date} (as of {as_of}) ══   [{source}]")
    print(f"   {arrow} median {m['median_move']:+.2f}%  net {m['net_breadth']:+.2f}  "
          f"({m['n']} names){gap}")
    print(f"   regime: {state}  (decisiveness {m['decisiveness']:.3f}, roll≥{MARKET_ROLL_DECIS}{peaked})")
    if m.get("gap") is not None and m["gap"] > 0.3 and m["median_move"] < 0:
        print(f"   ⚠ gapped UP then bled — a short-from-open tape even if it closes green")


def _fmt_sectors(sectors):
    ranked = sorted(sectors.items(), key=lambda kv: kv[1]["avg_rel_median"], reverse=True)
    print(f"\n── SECTORS (relative to market, ranked by persistent bias) ──")
    print(f"   {'sector':30} {'n':>3} {'bias':>8} {'avgRel':>7} {'nowRel':>7} {'decouple':>9}")
    for label, d in ranked:
        dc = (f"▲{d['peak_rel_decisiveness']:.2f}@{d['peak_rel_at']}" if d["decoupling_now"]
              else f"(pk {d['peak_rel_decisiveness']:.2f})")
        tag = "  ⟵ LEADER" if d["bias"] == "leader" else ("  ⟵ laggard" if d["bias"] == "laggard" else "")
        print(f"   {label:30} {d['n']:>3} {d['bias']:>8} {d['avg_rel_median']:>+7.2f} "
              f"{d['last_rel_median']:>+7.2f} {dc:>9}{tag}")
    print(f"\n   laggards = short vehicles for a down tape · leaders = long vehicles for an up tape")
    print(f"   (relative strips beta; persistent bias = selection, decoupling = a live event)")


def _fmt_market_full(market_timeline):
    print(f"\n── MARKET: full timeline ──")
    print(f"   {'time':>5}  {'n':>3}  {'net':>6}  {'med%':>6}  {'Δmed':>6}  {'decis':>6}")
    for s in market_timeline:
        dmed = "" if s.get("d_median") is None else f"{s['d_median']:+.2f}"
        dec = "" if s.get("decisiveness") is None else f"{s['decisiveness']:.3f}"
        mark = "  ⟵ roll" if (s.get("decisiveness") or 0) >= MARKET_ROLL_DECIS else ""
        print(f"   {s['as_of']:>5}  {s['n']:>3}  {s['net_breadth']:+.2f}  {s['median_move']:+.2f}  "
              f"{dmed:>6}  {dec:>6}{mark}")


def _fmt_full_sector(label, timeline):
    print(f"\n── {label}: full relative timeline ──")
    print(f"   {'time':>5}  {'secMed':>7} {'mktMed':>7} {'rel':>6} {'Δrel':>6} {'relDec':>6}")
    for s in timeline:
        drel = "" if s.get("d_rel_median") is None else f"{s['d_rel_median']:+.2f}"
        dec = "" if s.get("rel_decisiveness") is None else f"{s['rel_decisiveness']:.3f}"
        mark = "  ⟵ decoupling" if (s.get("rel_decisiveness") or 0) >= DECOUPLE_DECIS else ""
        print(f"   {s['as_of']:>5}  {s['sector_median']:>+7.2f} {s['market_median']:>+7.2f} "
              f"{s['rel_median']:>+6.2f} {drel:>6} {dec:>6}{mark}")


def main():
    p = argparse.ArgumentParser(
        description="Intraday sector-flow sensor (market regime-roll + sector relative strength)",
        formatter_class=argparse.RawDescriptionHelpFormatter, epilog=__doc__,
    )
    p.add_argument("--sector", help="Focus one sector (term like 'it','bank','pharma').")
    p.add_argument("--date", help="Replay a past session YYYY-MM-DD (inline compute).")
    p.add_argument("--fresh", action="store_true", help="Force inline recompute of the latest session.")
    p.add_argument("--universe", default="nifty500", help="nifty50|nifty100|nifty500|niftytotal.")
    p.add_argument("--threshold", type=float, default=0.3, help="Per-name move threshold %% (inline only).")
    p.add_argument("--window", type=int, default=2, help="Acceleration window in bars (inline only).")
    p.add_argument("--full", action="store_true", help="Print full timelines, not just the summary.")
    p.add_argument("--json", action="store_true", help="Structured JSON output.")
    args = p.parse_args()

    snapshot, source = _resolve_snapshot(args)
    if not snapshot or "error" in snapshot:
        msg = (snapshot or {}).get("error", "No snapshot available.")
        if args.json:
            print_json({"error": msg})
        else:
            print_error(msg)
        sys.exit(1)

    focus = None
    if args.sector:
        matched = ic.match_sectors(args.sector)
        focus = next((lbl for lbl in matched if lbl in snapshot["sectors"]), None)
        if not focus:
            avail = ", ".join(sorted(snapshot["sectors"]))
            print_error(f"No readable sector matched '{args.sector}'. Available: {avail}")
            sys.exit(1)

    if args.json:
        out = dict(snapshot)
        out["source"] = source
        if not args.full:
            # Drop the bulky timelines from the default JSON (summaries only).
            out.pop("market_timeline", None)
            out["sectors"] = {lbl: {k: v for k, v in d.items() if k != "timeline"}
                              for lbl, d in snapshot["sectors"].items()}
        print_json(out)
        return

    _fmt_market(snapshot["market"], snapshot["as_of"], snapshot["date"], source)
    if focus:
        _fmt_full_sector(focus, snapshot["sectors"][focus].get("timeline", []))
    else:
        _fmt_sectors(snapshot["sectors"])
    if args.full:
        _fmt_market_full(snapshot.get("market_timeline", []))
        if not focus:
            for lbl, d in snapshot["sectors"].items():
                _fmt_full_sector(lbl, d.get("timeline", []))


if __name__ == "__main__":
    main()
