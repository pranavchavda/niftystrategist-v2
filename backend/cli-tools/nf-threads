#!/usr/bin/env python3
"""Search past conversations and list recent threads.

Enables cross-thread awareness — the orchestrator can find context
from previous conversations when users reference past discussions.
"""

import argparse
import sys
import os

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import print_error, print_json, run_async  # noqa: E402


def _get_user_id() -> str:
    """Get user email from environment (conversations use email as user_id)."""
    return os.environ.get("NF_USER_EMAIL", "")


def _get_user_id_int() -> int:
    """Get numeric user ID for DB queries that use integer user_id."""
    return int(os.environ.get("NF_USER_ID", "999"))


def _fmt_ts(dt) -> str:
    if dt is None:
        return "—"
    from zoneinfo import ZoneInfo
    from datetime import timezone
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    ist = dt.astimezone(ZoneInfo("Asia/Kolkata"))
    return ist.strftime("%b %d %I:%M %p")


def cmd_search(args):
    """Semantic search across past conversation threads."""

    async def _search():
        from database.session import get_db_context
        from sqlalchemy import text as sa_text
        from services.thread_embedder import search_threads

        user_email = _get_user_id()
        if not user_email:
            async with get_db_context() as session:
                r = await session.execute(
                    sa_text("SELECT email FROM users WHERE id = :uid"),
                    {"uid": _get_user_id_int()},
                )
                row = r.fetchone()
                user_email = row[0] if row else None

        if not user_email:
            return None

        return await search_threads(
            user_id=user_email,
            query=args.query,
            limit=args.limit,
        )

    try:
        results = run_async(_search())
    except Exception as e:
        print_error(f"Search failed: {e}")
        return

    if results is None:
        print_error("Could not determine user email. Set NF_USER_EMAIL.")
        return

    if args.json:
        print_json({"query": args.query, "results": results, "count": len(results)})
        return

    if not results:
        print(f"No matching threads found for: \"{args.query}\"")
        return

    print(f"Thread Search: \"{args.query}\" ({len(results)} results)\n")
    for i, r in enumerate(results, 1):
        sim = f"{r['similarity']:.0%}"
        title = r["title"]
        content = r["turn_content"].replace("\n", " ")[:150]
        print(f"  {i}. [{sim}] {title}")
        print(f"     {content}...")
        print(f"     Thread: {r['conversation_id']}")
        print()


def cmd_recent(args):
    """List recent conversation threads with titles."""
    from database.session import get_db_context
    from sqlalchemy import text

    user_email = _get_user_id()
    if not user_email:
        async def _get_email():
            async with get_db_context() as session:
                r = await session.execute(
                    text("SELECT email FROM users WHERE id = :uid"),
                    {"uid": _get_user_id_int()},
                )
                row = r.fetchone()
                return row[0] if row else None
        user_email = run_async(_get_email())

    async def _recent():
        async with get_db_context() as session:
            r = await session.execute(text(
                "SELECT id, title, updated_at, "
                "(SELECT count(*) FROM messages WHERE conversation_id = c.id) as msg_count "
                "FROM conversations c "
                "WHERE user_id = :user_id AND is_archived = false "
                "ORDER BY updated_at DESC LIMIT :limit"
            ), {"user_id": user_email, "limit": args.limit})
            return [
                {"id": row[0], "title": row[1] or "(untitled)",
                 "updated_at": _fmt_ts(row[2]), "messages": row[3]}
                for row in r.fetchall()
            ]

    threads = run_async(_recent())

    if args.json:
        print_json({"threads": threads, "count": len(threads)})
        return

    if not threads:
        print("No recent threads found.")
        return

    print(f"Recent Threads ({len(threads)})\n")
    for t in threads:
        title = t["title"][:50]
        print(f"  {t['updated_at']:<18}  {title:<50}  ({t['messages']} msgs)")
        print(f"  └─ {t['id']}")


def cmd_read(args):
    """Read full conversation messages from a thread."""
    from database.session import get_db_context
    from sqlalchemy import text

    async def _read():
        async with get_db_context() as session:
            t = await session.execute(
                text("SELECT title, user_id, created_at, updated_at FROM conversations WHERE id = :tid"),
                {"tid": args.thread_id},
            )
            thread_info = t.fetchone()
            if not thread_info:
                return None

            r = await session.execute(text(
                "SELECT role, content, timestamp FROM messages "
                "WHERE conversation_id = :tid AND role IN ('user', 'assistant') "
                "AND content IS NOT NULL AND LENGTH(TRIM(content)) > 0 "
                "ORDER BY timestamp ASC"
            ), {"tid": args.thread_id})
            messages = r.fetchall()

            if args.tail and len(messages) > args.tail:
                messages = messages[-args.tail:]

            return {
                "thread_id": args.thread_id,
                "title": thread_info[0] or "(untitled)",
                "created_at": str(thread_info[2]),
                "updated_at": str(thread_info[3]),
                "message_count": len(messages),
                "messages": [
                    {
                        "role": row[0],
                        "content": row[1][:args.max_length] if args.max_length else row[1],
                        "timestamp": _fmt_ts(row[2]),
                    }
                    for row in messages
                ],
            }

    result = run_async(_read())

    if result is None:
        print_error(f"Thread not found: {args.thread_id}")
        return

    if args.json:
        import json
        print(json.dumps(result, indent=2, default=str))
        return

    print(f"Thread: {result['title']}")
    print(f"ID: {result['thread_id']}")
    print(f"Messages: {result['message_count']}")
    print(f"Updated: {result['updated_at']}")
    print("-" * 60)
    for msg in result["messages"]:
        role_label = "USER" if msg["role"] == "user" else "ASSISTANT"
        print(f"\n[{msg['timestamp']}] {role_label}:")
        print(msg["content"])


def main():
    parser = argparse.ArgumentParser(
        prog="nf-threads",
        description="Search and browse past conversations for cross-thread context",
    )
    sub = parser.add_subparsers(dest="command")

    p_search = sub.add_parser("search", help="Semantic search across past threads")
    p_search.add_argument("query", help="Search query")
    p_search.add_argument("--limit", type=int, default=5, help="Max results (default: 5)")
    p_search.add_argument("--json", action="store_true", help="Output as JSON")

    p_recent = sub.add_parser("recent", help="List recent conversation threads")
    p_recent.add_argument("--limit", type=int, default=20, help="Max threads (default: 20)")
    p_recent.add_argument("--json", action="store_true", help="Output as JSON")

    p_read = sub.add_parser("read", help="Read full conversation from a thread")
    p_read.add_argument("thread_id", help="Thread/conversation ID")
    p_read.add_argument("--tail", type=int, default=None, help="Only show last N messages")
    p_read.add_argument("--max-length", type=int, default=2000, help="Max chars per message (default: 2000, 0=unlimited)")
    p_read.add_argument("--json", action="store_true", help="Output as JSON")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "search":
        cmd_search(args)
    elif args.command == "recent":
        cmd_recent(args)
    elif args.command == "read":
        cmd_read(args)


if __name__ == "__main__":
    main()
