    if not hist:
        print_json(data)
        return
    print(f"  {'Period':<12} {'Total Assets':>18} {'Total Liabilities':>20}")
    for row in hist[-5:]:
        p = row.get("period") or "?"
        ta = row.get("total_asset") or row.get("total_assets")
        tl = row.get("total_liability") or row.get("total_liabilities")
        ta_s = f"₹{float(ta):,.0f} cr" if ta is not None else "n/a"
        tl_s = f"₹{float(tl):,.0f} cr" if tl is not None else "n/a"
        print(f"  {p:<12} {ta_s:>18} {tl_s:>20}")


