#!/usr/bin/env python3
"""Fundamentals data for NSE equities — profile, ratios, statements, corporate actions.

All endpoints key off ISIN, which is derived from the instruments cache. Pass
the symbol as you'd type it for any other CLI (RELIANCE, TCS, HDFCBANK, etc.).

Use for:
  - Morning scan candidate vetting (ratios vs sector, recent earnings posture)
  - Ex-date gating (don't enter a swing the day before ex-dividend)
  - Peer comparison (competitors → comparable instrument_keys)
  - Chart overlay data (key ratios, shareholding trend)
"""

import argparse
import sys
import os

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import format_inr, init_market_data_client, print_error, print_json, run_async  # noqa: E402
from services.instruments_cache import get_isin, get_company_name  # noqa: E402


def _resolve_isin(symbol: str) -> tuple[str, str]:
    """Resolve a user-typed symbol to (ISIN, company_name). Errors if not found."""
    isin = get_isin(symbol)
    if not isin:
        print_error(
            f"No ISIN for '{symbol}'. Fundamentals are available for NSE equities only "
            f"(not indices, ETFs without an ISIN, or F&O contracts)."
        )
    return isin, get_company_name(symbol) or symbol.upper()


def _pct(val) -> str:
    """Format a percentage-shaped value, tolerating None."""
    if val is None:
        return "n/a"
    try:
        return f"{float(val):+.2f}%"
    except (TypeError, ValueError):
        return str(val)


def show_profile(symbol: str, as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_company_profile(isin))
    except Exception as e:
        print_error(f"Profile fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"🏢 {name} ({symbol.upper()}) — ISIN {isin}\n")
    sector = data.get("sector") or "n/a"
    print(f"  Sector: {sector}")
    smc = data.get("sector_market_cap") or {}
    if smc:
        inr = smc.get("inr_cr")
        usd_bn = smc.get("usd_bn")
        if inr is not None:
            print(f"  Sector mkt cap: ₹{inr:,.0f} cr"
                  + (f" (US$ {usd_bn:.1f} bn)" if usd_bn else ""))
    desc = data.get("business_description") or data.get("description") or ""
    if desc:
        print(f"\n  {desc.strip()[:500]}")


def show_ratios(symbol: str, as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_key_ratios(isin))
    except Exception as e:
        print_error(f"Ratios fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"📊 Key Ratios: {name} ({symbol.upper()})\n")
    # Schema varies; try common shapes
    ratios = data.get("ratios") or data.get("key_ratios") or []
    if isinstance(ratios, dict):
        ratios = [{"name": k, **(v if isinstance(v, dict) else {"value": v})}
                  for k, v in ratios.items()]
    if not ratios:
        # Fallback: pretty-print whatever's there
        print_json(data)
        return

    print(f"  {'Ratio':<14} {'Company':>10} {'Sector':>10}")
    print("  " + "-" * 38)
    for r in ratios:
        rname = r.get("name") or r.get("ratio") or "?"
        company = r.get("value") or r.get("company_value") or r.get("company")
        sector = r.get("sector_value") or r.get("sector") or r.get("sector_benchmark")
        cv = f"{float(company):.2f}" if isinstance(company, (int, float)) else (str(company) if company is not None else "n/a")
        sv = f"{float(sector):.2f}" if isinstance(sector, (int, float)) else (str(sector) if sector is not None else "n/a")
        print(f"  {rname:<14} {cv:>10} {sv:>10}")


def show_shareholding(symbol: str, as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_shareholding(isin))
    except Exception as e:
        print_error(f"Shareholding fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"📊 Shareholding: {name} ({symbol.upper()})\n")
    holdings = data.get("share_holdings") or data.get("history") or data
    if not isinstance(holdings, dict):
        print_json(data)
        return

    categories = ["promoters", "fii", "mutual_funds", "other_dii", "retail_and_other"]
    # Gather all periods across categories
    periods: set[str] = set()
    for cat in categories:
        series = holdings.get(cat) or []
        for row in series:
            p = row.get("period")
            if p:
                periods.add(p)
    periods_sorted = sorted(periods, reverse=True)[:6]  # last 6 quarters

    if not periods_sorted:
        print_json(data)
        return

    print(f"  {'Quarter':<10}" + "".join(f" {c[:10]:>10}" for c in categories))
    print("  " + "-" * (10 + 11 * len(categories)))
    for p in periods_sorted:
        row_vals = []
        for cat in categories:
            series = holdings.get(cat) or []
            match = next((r for r in series if r.get("period") == p), None)
            v = (match or {}).get("value")
            row_vals.append(f"{float(v):>10.2f}" if v is not None else f"{'n/a':>10}")
        print(f"  {p:<10}" + " ".join(row_vals))


def show_income(symbol: str, type_: str = "consolidated",
                quarterly: bool = False, full_statement: bool = False,
                as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    period = "quarterly" if quarterly else "yearly"
    try:
        data = run_async(client.get_income_statement(isin, type_, period, full_statement))
    except Exception as e:
        print_error(f"Income statement fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"📊 Income Statement ({period}, {type_}): {name} ({symbol.upper()})\n")
    cats = data.get("income_statement") or data.get("history") or data
    if not isinstance(cats, dict):
        print_json(data)
        return

    for cat_name in ("revenue", "operating_profit", "net_profit", "eps"):
        series = cats.get(cat_name)
        if not series:
            continue
        print(f"\n  {cat_name.replace('_', ' ').title()}:")
        for row in series[-5:]:
            p = row.get("period") or "?"
            v = row.get("value")
            chg = row.get("change")
            v_str = f"₹{float(v):,.0f} cr" if v is not None else "n/a"
            print(f"    {p:<12} {v_str:>20} {_pct(chg):>10}")


