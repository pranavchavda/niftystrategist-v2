#!/usr/bin/env python3
"""Fundamentals data for NSE equities — profile, ratios, statements, corporate actions.

All endpoints key off ISIN, which is derived from the instruments cache. Pass
the symbol as you'd type it for any other CLI (RELIANCE, TCS, HDFCBANK, etc.).

Use for:
  - Morning scan candidate vetting (ratios vs sector, recent earnings posture)
  - Ex-date gating (don't enter a swing the day before ex-dividend)
  - Peer comparison (competitors → comparable instrument_keys)
  - Chart overlay data (key ratios, shareholding trend)
"""

import argparse
import sys
import os

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import format_inr, init_market_data_client, print_error, print_json, run_async  # noqa: E402
from services.instruments_cache import get_isin, get_instrument_key, get_company_name  # noqa: E402


def _resolve_isin(symbol: str) -> tuple[str, str]:
    """Resolve a user-typed symbol to (ISIN, company_name). Errors if not found."""
    isin = get_isin(symbol)
    if not isin:
        print_error(
            f"No ISIN for '{symbol}'. Fundamentals are available for NSE equities only "
            f"(not indices, ETFs without an ISIN, or F&O contracts)."
        )
    return isin, get_company_name(symbol) or symbol.upper()


def _pct(val) -> str:
    """Format a percentage-shaped value, tolerating None."""
    if val is None:
        return "n/a"
    try:
        return f"{float(val):+.2f}%"
    except (TypeError, ValueError):
        return str(val)


def show_profile(symbol: str, as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_company_profile(isin))
    except Exception as e:
        print_error(f"Profile fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"🏢 {name} ({symbol.upper()}) — ISIN {isin}\n")
    sector = data.get("sector") or "n/a"
    print(f"  Sector: {sector}")
    smc_inr = data.get("sector_market_cap_inr") or {}
    smc_usd = data.get("sector_market_cap_usd") or {}
    if smc_inr.get("formatted"):
        suffix = f" (US$ {smc_usd.get('formatted')})" if smc_usd.get("formatted") else ""
        print(f"  Sector mkt cap: ₹{smc_inr['formatted']}{suffix}")
    desc = data.get("company_profile") or data.get("business_description") or ""
    if desc:
        print(f"\n  {desc.strip()[:600]}")


def show_ratios(symbol: str, as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_key_ratios(isin))
    except Exception as e:
        print_error(f"Ratios fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"📊 Key Ratios: {name} ({symbol.upper()})\n")
    # Endpoint returns a list of {name, company_value, sector_value}.
    # Values are strings ("19.21" or "4.39%") — print as-is.
    ratios = data if isinstance(data, list) else (data.get("ratios") or data.get("key_ratios") or [])
    if not ratios:
        print_json(data)
        return

    print(f"  {'Ratio':<14} {'Company':>12} {'Sector':>12}")
    print("  " + "-" * 42)
    for r in ratios:
        rname = r.get("name") or r.get("ratio") or "?"
        cv = r.get("company_value") if r.get("company_value") is not None else r.get("value")
        sv = r.get("sector_value") if r.get("sector_value") is not None else r.get("sector")
        cv_s = str(cv) if cv is not None else "n/a"
        sv_s = str(sv) if sv is not None else "n/a"
        print(f"  {rname:<14} {cv_s:>12} {sv_s:>12}")


def show_shareholding(symbol: str, as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_shareholding(isin))
    except Exception as e:
        print_error(f"Shareholding fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"📊 Shareholding: {name} ({symbol.upper()})\n")
    # Endpoint returns a list of {category, history: [{value, period}]}
    series_list = data if isinstance(data, list) else (data.get("share_holdings") or [])
    if not series_list:
        print_json(data)
        return

    by_category = {row.get("category"): row.get("history") or [] for row in series_list}
    categories = list(by_category.keys())

    # Gather periods (preserve any chronological order the API returns)
    period_order: list[str] = []
    seen: set = set()
    for cat in categories:
        for row in by_category[cat]:
            p = row.get("period")
            if p and p not in seen:
                seen.add(p)
                period_order.append(p)
    periods_to_show = period_order[:6]

    if not periods_to_show:
        print_json(data)
        return

    col_w = 12
    print(f"  {'Period':<10}" + "".join(f" {c[:col_w]:>{col_w}}" for c in categories))
    print("  " + "-" * (10 + (col_w + 1) * len(categories)))
    for p in periods_to_show:
        row_vals = []
        for cat in categories:
            match = next((r for r in by_category[cat] if r.get("period") == p), None)
            v = (match or {}).get("value")
            row_vals.append(f"{float(v):>{col_w}.2f}" if v is not None else f"{'n/a':>{col_w}}")
        print(f"  {p:<10}" + " ".join(row_vals))


def show_income(symbol: str, type_: str = "consolidated",
                quarterly: bool = False, full_statement: bool = False,
                as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    period = "quarterly" if quarterly else "yearly"
    try:
        data = run_async(client.get_income_statement(isin, type_, period, full_statement))
    except Exception as e:
        print_error(f"Income statement fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    units = data.get("units_in", "crore") if isinstance(data, dict) else "crore"
    print(f"📊 Income Statement ({period}, {type_}, units: {units}): {name} ({symbol.upper()})\n")
    # Endpoint returns dict with `income_statement` as list of {category, history: [...]}
    cats_list = data.get("income_statement") if isinstance(data, dict) else []
    if not cats_list:
        print_json(data)
        return

    by_category = {row.get("category"): row.get("history") or [] for row in cats_list}
    for cat_name in ("revenue", "operating_profit", "net_profit", "eps"):
        series = by_category.get(cat_name)
        if not series:
            continue
        print(f"\n  {cat_name.replace('_', ' ').title()}:")
        # API returns most-recent-first; show 5 most recent in that order
        for row in series[:5]:
            p = row.get("period") or "?"
            v = row.get("value")
            chg = row.get("change")
            v_str = f"₹{float(v):,.0f}" if v is not None else "n/a"
            chg_str = str(chg) if chg else "n/a"
            print(f"    {p:<12} {v_str:>16} {chg_str:>10}")


def show_balance_sheet(symbol: str, type_: str = "consolidated",
                       full_statement: bool = False, as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_balance_sheet(isin, type_, full_statement))
    except Exception as e:
        print_error(f"Balance sheet fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    units = data.get("units_in", "crore") if isinstance(data, dict) else "crore"
    print(f"📊 Balance Sheet ({type_}, units: {units}): {name} ({symbol.upper()})\n")
    hist = data.get("history") if isinstance(data, dict) else []
    if not hist:
        print_json(data)
        return
    print(f"  {'Period':<12} {'Total Assets':>16} {'Total Liabilities':>20}")
    # API returns most-recent-first; show 5 most recent
    for row in hist[:5]:
        p = row.get("period") or "?"
        ta = row.get("total_asset") or row.get("total_assets")
        tl = row.get("total_liability") or row.get("total_liabilities")
        ta_s = f"₹{float(ta):,.0f}" if ta is not None else "n/a"
        tl_s = f"₹{float(tl):,.0f}" if tl is not None else "n/a"
        print(f"  {p:<12} {ta_s:>16} {tl_s:>20}")


