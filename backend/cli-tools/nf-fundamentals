    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_competitors(isin))
    except Exception as e:
        print_error(f"Competitors fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"🤝 Competitors: {name} ({symbol.upper()})\n")
    peers = data.get("competitors") or data.get("peers") or []
    if not peers:
        print_json(data)
        return
    print(f"  {'Name':<32} {'Sector':<24} {'Mkt Cap (₹ cr)':>16}")
    for p in peers[:20]:
        pname = (p.get("name") or "?")[:32]
        psec = (p.get("sector") or "?")[:24]
        smc = p.get("sector_market_cap") or {}
        inr = smc.get("inr_cr") if isinstance(smc, dict) else None
        cap_s = f"{float(inr):,.0f}" if inr is not None else "n/a"
        print(f"  {pname:<32} {psec:<24} {cap_s:>16}")


def main():
    parser = argparse.ArgumentParser(
        prog="nf-fundamentals",
        description="Fundamentals data for NSE equities (ISIN-keyed via Upstox)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  nf-fundamentals profile RELIANCE              Company profile + sector market cap
  nf-fundamentals ratios RELIANCE               P/E, P/B, ROE, ROCE vs sector
  nf-fundamentals shareholding RELIANCE         Promoter / FII / MF % quarterly trend
  nf-fundamentals income TCS                    Yearly P&L: revenue, profit, EPS
  nf-fundamentals income TCS --quarterly        Quarterly cut
  nf-fundamentals balance-sheet INFY            Total assets/liabilities history
  nf-fundamentals cash-flow INFY                Operating/investing/financing CFs
  nf-fundamentals corp-actions HDFCBANK         Upcoming dividends, splits, bonuses
  nf-fundamentals competitors RELIANCE          Peer companies + market caps

All commands accept --json for structured output.
""",
    )
    sub = parser.add_subparsers(dest="command", help="Command")

    common_type = ("--type", {"default": "consolidated",
                              "choices": ["consolidated", "standalone"],
                              "help": "Statement type (default: consolidated)"})

    for cmd, help_str, extra in [
        ("profile", "Company profile + sector market cap", []),
        ("ratios", "Key valuation/profitability ratios vs sector", []),
        ("shareholding", "Quarterly shareholding by category", []),
        ("corp-actions", "Dividends, splits, bonuses, rights with ex-dates", []),
        ("competitors", "Peer companies with instrument_keys", []),
    ]:
        p = sub.add_parser(cmd, help=help_str)
        p.add_argument("symbol", help="NSE equity symbol (e.g. RELIANCE, TCS)")
        p.add_argument("--json", action="store_true", help="Output as JSON")

    # income (extra flags)
    p_inc = sub.add_parser("income", help="P&L: revenue, operating profit, net profit, EPS")
    p_inc.add_argument("symbol", help="NSE equity symbol")
    p_inc.add_argument(common_type[0], **common_type[1])
    p_inc.add_argument("--quarterly", action="store_true", help="Quarterly cut (default: yearly)")
    p_inc.add_argument("--full", action="store_true", help="Full statement with line items")
    p_inc.add_argument("--json", action="store_true", help="Output as JSON")

    # balance-sheet
    p_bs = sub.add_parser("balance-sheet", help="Historical balance sheet")
    p_bs.add_argument("symbol", help="NSE equity symbol")
    p_bs.add_argument(common_type[0], **common_type[1])
    p_bs.add_argument("--full", action="store_true", help="Full statement with line items")
    p_bs.add_argument("--json", action="store_true", help="Output as JSON")

    # cash-flow
    p_cf = sub.add_parser("cash-flow", help="Cash flow by Operating/Investing/Financing")
    p_cf.add_argument("symbol", help="NSE equity symbol")
    p_cf.add_argument(common_type[0], **common_type[1])
    p_cf.add_argument("--full", action="store_true", help="Full statement with line items")
    p_cf.add_argument("--json", action="store_true", help="Output as JSON")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "profile":
        show_profile(args.symbol, args.json)
    elif args.command == "ratios":
        show_ratios(args.symbol, args.json)
    elif args.command == "shareholding":
        show_shareholding(args.symbol, args.json)
    elif args.command == "income":
        show_income(args.symbol, args.type, args.quarterly, args.full, args.json)
    elif args.command == "balance-sheet":
        show_balance_sheet(args.symbol, args.type, args.full, args.json)
    elif args.command == "cash-flow":
        show_cash_flow(args.symbol, args.type, args.full, args.json)
    elif args.command == "corp-actions":
        show_corporate_actions(args.symbol, args.json)
    elif args.command == "competitors":
        show_competitors(args.symbol, args.json)


if __name__ == "__main__":
    main()
