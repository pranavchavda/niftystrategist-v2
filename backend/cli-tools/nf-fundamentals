def show_corporate_actions(symbol: str, as_json: bool = False):
    isin, name = _resolve_isin(symbol)
    client = init_market_data_client()
    try:
        data = run_async(client.get_corporate_actions(isin))
    except Exception as e:
        print_error(f"Corporate actions fetch failed: {e}")

    if as_json:
        print_json({"symbol": symbol.upper(), "isin": isin, **data})
        return

    print(f"📅 Corporate Actions: {name} ({symbol.upper()})\n")
    actions = data.get("corporate_actions") or data.get("actions") or data
    if not isinstance(actions, list):
        # Try as dict-of-lists keyed by action type
        if isinstance(actions, dict):
            actions = [a for v in actions.values() if isinstance(v, list) for a in v]
        else:
            print_json(data)
            return
    if not actions:
        print("  (no recent or upcoming corporate actions)")
        return

    for a in actions[:20]:
        nm = a.get("name") or a.get("action") or "?"
        exd = a.get("expiry_date") or a.get("ex_date") or a.get("date") or "?"
        amt = a.get("amount")
        ratio = a.get("ratio")
        suffix = ""
        if amt is not None:
            try:
                suffix = f" ₹{float(amt):.2f}"
            except (TypeError, ValueError):
                suffix = f" {amt}"
        elif ratio:
            suffix = f" ratio {ratio}"
        print(f"  {exd:<12} {nm}{suffix}")


