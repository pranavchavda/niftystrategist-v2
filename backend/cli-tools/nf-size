#!/usr/bin/env python3
"""Position-size calculator for intraday equity (and F&O options).

Tells the orchestrator how many shares/lots to take so that a stop-loss
hit equals at most `risk_pct` of available capital. Removes the "guess"
from sizing — the agent runs this and uses the recommended_qty.

Equity:
    nf-size RELIANCE --sl-points 15
    nf-size HDFCBANK --sl-points 8 --risk-pct 1.5 --capital 50000

F&O option (premium-side SL):
    nf-size NIFTY26MAY24500CE --option --sl-premium 12
    nf-size BANKNIFTY26MAY52000PE --option --sl-premium 20 --lots-cap 5

The binding constraint is reported so the agent can explain its sizing:
  - "risk"     → SL × qty hit the risk budget first
  - "capital"  → qty × entry hit the capital wall first
  - "lot_cap"  → user-supplied lot cap binds (F&O only)
"""

import argparse
import math
import os
import re
import sys

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import init_client, print_error, print_json, run_async  # noqa: E402


DEFAULT_RISK_PCT = 2.0


def _resolve_capital(client, requested) -> float:
    """Resolve --capital: number, 'auto', or default to auto."""
    if requested is None or str(requested).lower() == "auto":
        funds = run_async(client.get_funds_and_margin())
        eq = funds.get("equity") or {}
        return float(eq.get("available_margin") or 0)
    return float(requested)


def size_equity(args) -> dict:
    client = init_client()
    symbol = args.symbol.upper()

    quote = run_async(client.get_quote(symbol))
    entry = float(quote.get("ltp") or 0)
    if entry <= 0:
        return {"error": f"Could not fetch live price for {symbol}"}

    sl_points = float(args.sl_points)
    if sl_points <= 0:
        return {"error": "--sl-points must be > 0"}

    risk_pct = float(args.risk_pct or DEFAULT_RISK_PCT)
    capital = _resolve_capital(client, args.capital)
    if capital <= 0:
        return {"error": "Available capital is 0 — fund the account or pass --capital."}

    max_risk_amount = capital * (risk_pct / 100.0)
    qty_by_risk = math.floor(max_risk_amount / sl_points)

    # Capital constraint: rough cash needed to enter. For MIS the broker
    # gives leverage but it varies per scrip; we treat capital as the
    # hard wall and let the agent decide if MIS leverage gives more room.
    # `effective_capital` lets the user override when they know MIS lets
    # them go bigger (e.g. 5x intraday margin).
    leverage = float(args.leverage or 1.0)
    effective_capital = capital * leverage
    qty_by_capital = math.floor(effective_capital / entry) if entry > 0 else 0

    qty = max(0, min(qty_by_risk, qty_by_capital))
    binding = "risk" if qty_by_risk <= qty_by_capital else "capital"

    actual_risk = qty * sl_points
    capital_required = qty * entry

    warnings = []
    if qty == 0:
        warnings.append(
            f"No qty recommended — even 1 share risks ₹{sl_points:.2f} or "
            f"costs ₹{entry:.2f}, exceeding limits."
        )
    if leverage > 1.0:
        warnings.append(
            f"Using {leverage}x leverage assumption — verify with broker MIS margin."
        )

    return {
        "kind": "equity",
        "symbol": symbol,
        "entry_price": round(entry, 2),
        "sl_distance": round(sl_points, 2),
        "risk_pct": round(risk_pct, 2),
        "available_capital": round(capital, 2),
        "leverage": leverage,
        "max_risk_amount": round(max_risk_amount, 2),
        "qty_by_risk": qty_by_risk,
        "qty_by_capital": qty_by_capital,
        "recommended_qty": qty,
        "actual_risk_amount": round(actual_risk, 2),
        "capital_required": round(capital_required, 2),
        "binding_constraint": binding,
        "product": args.product,
        "warnings": warnings,
    }


def _fetch_atr14(client, symbol: str, *, interval: str = "15minute", days: int = 10):
    """Intraday ATR-14 via the same TA engine / candle source nf-analyze uses.

    Returns (atr_14, n_candles) or (None, n) when data is too thin (<50 candles)
    or the fetch fails — caller turns that into a clear error.
    """
    from services.technical_analysis import TechnicalAnalysisService
    try:
        candles = run_async(client.get_historical_data(symbol, interval=interval, days=days))
    except Exception:
        return None, 0
    n = len(candles or [])
    if n < 50:
        return None, n
    ind = TechnicalAnalysisService().calculate_indicators(candles)
    atr = getattr(ind, "atr_14", None)
    return (atr if (atr and atr > 0) else None), n


def _auto_regime() -> tuple[str, str]:
    """Best-effort market regime via nf-regime --json. Returns (regime, source).

    Falls back to 'mixed' on any failure/timeout — NS should normally pass
    --regime explicitly (it has it from the regime-gate pulse), this is the
    convenience path. nf-regime runs a market scan, so it is not free.
    """
    import json as _json
    import subprocess
    try:
        out = subprocess.run(
            [sys.executable, os.path.join(_backend_dir, "cli-tools", "nf-regime"), "--json"],
            capture_output=True, text=True, timeout=30, cwd=_backend_dir,
        )
        data = _json.loads(out.stdout)
        reg = data.get("regime")
        if reg:
            return reg, "nf-regime"
    except Exception:
        pass
    return "mixed", "fallback"


def _build_add_trailing_command(result: dict) -> str | None:
    """Emit the ready-to-paste `nf-monitor add-trailing` command for an
    --atr-trail result, with the trail width + provenance flags pre-filled.

    Collapses "run the tool → copy a width → separately stamp provenance" into
    one action. Pasting the line as-is creates a trail-only stop whose
    `width_provenance` is COMPLETE (tuned=false). To TUNE the width, edit ONLY
    `--trail-percent` and leave `--baseline-trail` at the nf-size value — the
    provenance then records tuned=true with the baseline preserved. Either way
    `width_provenance` can never come back null (the Post-Close audit's false-
    positive source).

    Returns None when there's no qty to deploy (the caller surfaces a warning
    instead of a broken command).
    """
    qty = result.get("recommended_qty") or 0
    if qty <= 0:
        return None
    # Long position exits on a SELL; short position exits on a BUY.
    side = "SELL" if result.get("direction") == "long" else "BUY"
    trail = result["trail_percent"]
    parts = [
        "nf-monitor add-trailing",
        f"--symbol {result['symbol']}",
        f"--qty {qty}",
        f"--side {side}",
        f"--trail-percent {trail}",
        f"--product {result.get('product') or 'I'}",
        # provenance — pre-filled from this same computation so the rule's
        # width_provenance is always populated (atr/k/regime + baseline anchor).
        f"--atr {result['atr_14']}",
        f"--k {result['k']}",
        f"--regime {result['regime']}",
        f"--baseline-trail {trail}",
    ]
    return " ".join(parts)


def size_atr_trail(args) -> dict:
    """ATR/regime-aware trail width + risk-invariant sizing (spec 2026-06-22)."""
    from services.atr_trail import compute_atr_trail

    client = init_client()
    symbol = args.symbol.upper()

    # Entry: explicit --entry or live LTP.
    if args.entry and str(args.entry).lower() != "auto":
        entry = float(args.entry)
    else:
        quote = run_async(client.get_quote(symbol))
        entry = float(quote.get("ltp") or 0)
    if entry <= 0:
        return {"error": f"Could not resolve entry price for {symbol}"}

    atr, n_candles = _fetch_atr14(client, symbol)
    if atr is None:
        return {"error": (f"No stable ATR-14 for {symbol} "
                          f"({n_candles} candles; need ≥50). Cannot size a trail.")}

    # Regime: explicit wins; 'auto'/omitted falls back to nf-regime.
    regime_source = "explicit"
    regime = args.regime
    if not regime or str(regime).lower() == "auto":
        regime, regime_source = _auto_regime()

    # Risk budget: --risk (absolute ₹) or risk-pct of capital.
    if args.risk is not None:
        risk_budget = float(args.risk)
        capital = None
    else:
        risk_pct = float(args.risk_pct or DEFAULT_RISK_PCT)
        capital = _resolve_capital(client, args.capital)
        if capital <= 0:
            return {"error": "Available capital is 0 — fund the account or pass --capital/--risk."}
        risk_budget = capital * (risk_pct / 100.0)

    leverage = float(args.leverage or 1.0)
    try:
        res = compute_atr_trail(
            atr=atr, entry_price=entry, setup=args.setup, regime=regime,
            risk_budget=risk_budget, capital=capital, leverage=leverage,
            opening=bool(args.opening), k_override=args.k,
        )
    except ValueError as e:
        return {"error": str(e)}

    warnings = []
    if regime_source == "fallback":
        warnings.append("Regime auto-detect failed → assumed 'mixed'. Pass --regime for accuracy.")
    elif regime_source == "nf-regime":
        warnings.append("Regime auto-detected via nf-regime (slower). Pass --regime to skip.")
    if res["recommended_qty"] == 0:
        warnings.append("No qty — even 1 unit exceeds the risk/capital limit at this trail width.")
    if res["clamped"]:
        warnings.append(f"Trail width clamped to [{res['trail_percent']}%] bound.")

    result = {
        "kind": "equity_atr_trail",
        "symbol": symbol,
        "entry_price": round(entry, 2),
        "direction": args.direction,
        "candles": n_candles,
        "regime_source": regime_source,
        "risk_budget": round(risk_budget, 2),
        "available_capital": round(capital, 2) if capital is not None else None,
        "leverage": leverage,
        "product": args.product,
        "warnings": warnings,
        **res,
    }
    # Ready-to-paste deploy command (provenance pre-filled) — see helper docstring.
    result["add_trailing_command"] = _build_add_trailing_command(result)
    return result


def _lookup_option(tradingsymbol: str) -> dict | None:
    """Look up an option contract from the F&O instruments cache."""
    sys.path.insert(0, os.path.join(_backend_dir, "cli-tools"))
    # Reuse nf-options' loader rather than reimplementing CSV parsing.
    import importlib.util
    spec = importlib.util.spec_from_file_location(
        "nf_options_mod", os.path.join(_backend_dir, "cli-tools", "nf-options")
    )
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    cache = mod._load_options_cache()
    return cache.get(tradingsymbol.upper())


def size_option(args) -> dict:
    client = init_client()
    tradingsymbol = args.symbol.upper()

    option = _lookup_option(tradingsymbol)
    if not option:
        return {"error": f"Option {tradingsymbol} not found in F&O cache."}

    lot_size = int(option["lot_size"])
    instrument_key = option["instrument_key"]

    # Live premium via greeks/quote — get_quote works for options too.
    try:
        quote = run_async(client.get_quote(tradingsymbol))
        premium = float(quote.get("ltp") or option.get("last_price") or 0)
    except Exception:
        premium = float(option.get("last_price") or 0)
    if premium <= 0:
        return {"error": f"Could not fetch live premium for {tradingsymbol}"}

    sl_premium = float(args.sl_premium)
    if sl_premium <= 0:
        return {"error": "--sl-premium must be > 0"}

    risk_pct = float(args.risk_pct or DEFAULT_RISK_PCT)
    capital = _resolve_capital(client, args.capital)
    if capital <= 0:
        return {"error": "Available capital is 0 — fund the account or pass --capital."}

    max_risk_amount = capital * (risk_pct / 100.0)
    risk_per_lot = sl_premium * lot_size
    if risk_per_lot <= 0:
        return {"error": "Risk per lot computed to 0 — check --sl-premium and lot_size."}

    lots_by_risk = math.floor(max_risk_amount / risk_per_lot)

    # Capital wall: premium × lot_size × lots ≤ capital (long options pay
    # full premium upfront; sells require margin which we don't compute here).
    cost_per_lot = premium * lot_size
    lots_by_capital = math.floor(capital / cost_per_lot) if cost_per_lot > 0 else 0

    lots = max(0, min(lots_by_risk, lots_by_capital))
    binding = "risk" if lots_by_risk <= lots_by_capital else "capital"

    if args.lots_cap is not None:
        cap = int(args.lots_cap)
        if cap < lots:
            lots = cap
            binding = "lot_cap"

    qty = lots * lot_size
    actual_risk = lots * risk_per_lot
    capital_required = lots * cost_per_lot

    warnings = []
    if lots == 0:
        warnings.append(
            f"No lots recommended — one lot risks ₹{risk_per_lot:.2f} or "
            f"costs ₹{cost_per_lot:.2f}, exceeding limits."
        )

    return {
        "kind": "option",
        "symbol": tradingsymbol,
        "instrument_key": instrument_key,
        "lot_size": lot_size,
        "premium": round(premium, 2),
        "sl_premium": round(sl_premium, 2),
        "risk_pct": round(risk_pct, 2),
        "available_capital": round(capital, 2),
        "max_risk_amount": round(max_risk_amount, 2),
        "risk_per_lot": round(risk_per_lot, 2),
        "cost_per_lot": round(cost_per_lot, 2),
        "lots_by_risk": lots_by_risk,
        "lots_by_capital": lots_by_capital,
        "recommended_lots": lots,
        "recommended_qty": qty,
        "actual_risk_amount": round(actual_risk, 2),
        "capital_required": round(capital_required, 2),
        "binding_constraint": binding,
        "warnings": warnings,
    }


def _print_human(result: dict) -> None:
    if "error" in result:
        print_error(result["error"])
        return

    if result["kind"] == "equity_atr_trail":
        print(f"\n📐 ATR trail size — {result['symbol']} ({result['direction']})")
        print(f"   Entry:      ₹{result['entry_price']:.2f}")
        print(f"   ATR-14:     {result['atr_14']} ({result['atr_pct']}% of price)")
        print(f"   Regime:     {result['regime']} · setup {result['setup_class']} "
              f"→ k={result['k']} ({result['k_source']})")
        print(f"   ➜ trail = {result['trail_percent']}%  "
              f"(stop ~₹{result['sl_points']} away)")
        print(f"   ➜ qty   = {result['recommended_qty']}  "
              f"(risk ₹{result['actual_risk_amount']:,.0f} of ₹{result['risk_budget']:,.0f}, "
              f"binds on {result['binding_constraint']})")
        print(f"   ℹ baseline to TUNE — a floor against blind flat-%, not a verdict. "
              f"The width judgment is yours (esp. runners in trending).")
        for w in result.get("warnings", []):
            print(f"   ⚠ {w}")
        cmd = result.get("add_trailing_command")
        if cmd:
            print(f"\n   ▶ Deploy (provenance pre-filled — paste as-is, or TUNE by editing")
            print(f"     ONLY --trail-percent; --baseline-trail stays as the anchor):")
            print(f"       {cmd}")
        return

    print(f"\n📐 Position size — {result['symbol']}")
    print(f"   Risk:       {result['risk_pct']}% of ₹{result['available_capital']:,.0f} "
          f"= ₹{result['max_risk_amount']:,.0f}")

    if result["kind"] == "equity":
        print(f"   Entry:      ₹{result['entry_price']:.2f}")
        print(f"   SL points:  {result['sl_distance']}")
        if result["leverage"] > 1:
            print(f"   Leverage:   {result['leverage']}x ({result['product']})")
        print(f"\n   ➜ qty = {result['recommended_qty']}  "
              f"(risk ₹{result['actual_risk_amount']:,.0f} / "
              f"cost ₹{result['capital_required']:,.0f})")
    else:
        print(f"   Premium:    ₹{result['premium']:.2f}")
        print(f"   SL premium: {result['sl_premium']}")
        print(f"   Lot size:   {result['lot_size']}")
        print(f"\n   ➜ lots = {result['recommended_lots']}  "
              f"(qty {result['recommended_qty']}, "
              f"risk ₹{result['actual_risk_amount']:,.0f} / "
              f"cost ₹{result['capital_required']:,.0f})")

    print(f"   Limited by: {result['binding_constraint']}")
    for w in result.get("warnings", []):
        print(f"   ⚠ {w}")


def main():
    p = argparse.ArgumentParser(
        description="Position-size calculator (intraday equity + F&O options)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  nf-size RELIANCE --sl-points 15\n"
            "  nf-size HDFCBANK --sl-points 8 --risk-pct 1.5\n"
            "  nf-size NIFTY26MAY24500CE --option --sl-premium 12\n"
        ),
    )
    p.add_argument("symbol", help="Equity symbol or option tradingsymbol")
    p.add_argument("--option", action="store_true",
                   help="Treat symbol as an option contract (use --sl-premium).")
    p.add_argument("--atr-trail", action="store_true",
                   help="ATR/regime-aware trail width + sizing (computes trail_percent "
                        "from intraday ATR-14 × setup × regime; see docs/plans/"
                        "2026-06-22-atr-regime-trail-width.md).")
    p.add_argument("--direction", choices=["long", "short"], default="long",
                   help="--atr-trail: trade direction (default long).")
    p.add_argument("--setup", default=None,
                   help="--atr-trail: setup (e.g. 'gap_fade', 'ORB breakout', 'vwap_pullback'). "
                        "Maps to a noise-tolerance class.")
    p.add_argument("--regime", default=None,
                   help="--atr-trail: trending|mixed|range_bound (or 'auto' → nf-regime). "
                        "Pass explicitly (from the regime gate) to skip the auto scan.")
    p.add_argument("--k", type=float, default=None,
                   help="--atr-trail: override the ATR multiple (skips the k-table).")
    p.add_argument("--risk", type=float, default=None,
                   help="--atr-trail: absolute risk budget in ₹ (else --risk-pct of capital).")
    p.add_argument("--entry", default=None,
                   help="--atr-trail: entry price, or 'auto' (default) for live LTP.")
    p.add_argument("--opening", action="store_true",
                   help="--atr-trail: flag the first ~30 min (opening-volatility k nudge).")
    p.add_argument("--sl-points", type=float, default=None,
                   help="Equity stop-loss distance in points.")
    p.add_argument("--sl-premium", type=float, default=None,
                   help="Option stop-loss distance in premium points.")
    p.add_argument("--risk-pct", type=float, default=None,
                   help=f"Max %% of capital to risk per trade (default {DEFAULT_RISK_PCT}%%).")
    p.add_argument("--capital", default=None,
                   help="Available capital in ₹, or 'auto' (default) to fetch from broker.")
    p.add_argument("--leverage", type=float, default=None,
                   help="Equity-only: MIS leverage assumption (default 1x).")
    p.add_argument("--product", choices=["I", "D"], default="I",
                   help="Equity product: I=intraday/MIS, D=delivery (default I).")
    p.add_argument("--lots-cap", type=int, default=None,
                   help="Option-only: hard cap on lots regardless of math.")
    p.add_argument("--json", action="store_true", help="Output JSON.")
    args = p.parse_args()

    if args.atr_trail:
        result = size_atr_trail(args)
    elif args.option:
        if args.sl_premium is None:
            print_error("--sl-premium required for --option")
            sys.exit(2)
        result = size_option(args)
    else:
        if args.sl_points is None:
            print_error("--sl-points required (or use --option for F&O)")
            sys.exit(2)
        result = size_equity(args)

    if args.json:
        print_json(result)
    else:
        _print_human(result)

    if "error" in result:
        sys.exit(1)


if __name__ == "__main__":
    main()
