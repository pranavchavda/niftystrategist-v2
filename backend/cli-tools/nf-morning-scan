# Phase 3: News context via Perplexity Sonar API
# ---------------------------------------------------------------------------

def _get_perplexity_key() -> str | None:
    """Get Perplexity API key from env (try both common names)."""
    return os.environ.get("PERPLEXITY_API_KEY") or os.environ.get("PPLX_API_KEY")


def fetch_news_context(
    top_symbols: list[str],
    nifty_pct: float,
    verbose: bool = False,
) -> dict | None:
    """Query Perplexity Sonar for market news relevant to today's top movers.

    Returns dict with keys: market_context, stock_news, catalysts
    or None if API unavailable.
    """
    api_key = _get_perplexity_key()
    if not api_key:
        if verbose:
            print("  Skipping news: no PERPLEXITY_API_KEY or PPLX_API_KEY set", file=sys.stderr)
        return None

    symbols_str = ", ".join(top_symbols[:5])
    market_dir = "up" if nifty_pct > 0 else "down" if nifty_pct < 0 else "flat"

    prompt = f"""Today the Indian stock market (Nifty 50) is {market_dir} {abs(nifty_pct):.1f}%.

The top momentum stocks this morning are: {symbols_str}

In 3-5 concise bullet points, provide:
1. Key market-moving news for Indian markets today (global cues, RBI, macro, geopolitics)
2. Any specific news or catalysts for these stocks: {symbols_str}
3. Sector themes driving today's action

Be specific and factual. Focus only on today's and last night's developments. No generic advice."""

    try:
        if verbose:
            print("Phase 3: Fetching market news context...", file=sys.stderr)

        response = requests.post(
            "https://api.perplexity.ai/chat/completions",
            headers={
                "Authorization": f"Bearer {api_key}",
                "Content-Type": "application/json",
            },
            json={
                "model": "sonar",
                "messages": [
                    {
                        "role": "system",
                        "content": "You are a concise Indian stock market analyst. "
                        "Provide brief, factual news context. No disclaimers or investment advice.",
                    },
                    {"role": "user", "content": prompt},
                ],
            },
            timeout=15,
        )
        response.raise_for_status()
        result = response.json()

        content = ""
        citations = []
        if "choices" in result and result["choices"]:
            content = result["choices"][0].get("message", {}).get("content", "")
        if "citations" in result:
            citations = result["citations"]

        if verbose:
            print("  News context fetched.", file=sys.stderr)

        return {"content": content, "citations": citations}

    except Exception as e:
        if verbose:
            print(f"  News fetch failed: {e}", file=sys.stderr)
        return None


# ---------------------------------------------------------------------------
# Output formatters
# ---------------------------------------------------------------------------

def format_json_output(
    results: list[dict],
    nifty_quote: dict | None,
    nifty_pct: float,
    elapsed: float,
    news: dict | None = None,
):
    """Format scan results as JSON."""
    output = {
        "scan_time": datetime.now().strftime("%Y-%m-%d %H:%M:%S IST"),
        "elapsed_seconds": round(elapsed, 1),
        "market_context": {
            "nifty_50": nifty_quote.get("ltp") if nifty_quote else None,
            "nifty_change_pct": nifty_pct,
        },
        "candidates": [],
    }

    if news:
        output["news"] = news.get("content", "")
        if news.get("citations"):
            output["news_citations"] = news["citations"]

    for r in results:
        q = r["quote"]
        candidate = {
            "symbol": r["symbol"],
            "price": q["ltp"],
            "score": r["total_score"],
            "gap_pct": r["gap_pct"],
            "rel_strength_pct": r["rel_strength"],
            "change_pct": q["pct_change"],
            "volume": q["volume"],
            "rsi": r.get("rsi"),
            "vwap": r.get("vwap"),
            "above_vwap": r.get("above_vwap"),
            "rvol_t": r.get("rvol_t"),
            "vol_expansion": r.get("vol_expansion"),
            "setup": r.get("setup"),
        }
        if r.get("opening_range"):
            candidate["opening_range"] = r["opening_range"]
        output["candidates"].append(candidate)

    print_json(output)


def format_human_output(
    results: list[dict],
    nifty_quote: dict | None,
    nifty_pct: float,
    elapsed: float,
    news: dict | None = None,
):
    """Format scan results for human reading."""
    now = datetime.now().strftime("%H:%M IST")

    print(f"\n{'=' * 65}")
    print(f"  Morning Momentum Scan  |  {now}")
    print(f"{'=' * 65}")

    # Market context
    nifty_val = format_inr(nifty_quote["ltp"]) if nifty_quote else "N/A"
    nifty_chg = format_change(nifty_pct)
    print(f"\n  Nifty 50: {nifty_val}  {nifty_chg}")
    print()

    if not results:
        print("  No candidates found matching your criteria.")
        print(f"\n  Scan completed in {elapsed:.1f}s")
        return

    # Top 3 watchlist
    top3 = results[:3]
    print("  Suggested Watchlist")
    print("  " + "-" * 50)
    for i, r in enumerate(top3, 1):
        setup = r.get("setup", "Watching")
        score = r["total_score"]
        print(f"  {i}. {r['symbol']:<12} Score: {score}  |  {setup}")
    print()

    # Full table
    print(f"  {'Symbol':<12} {'Price':>10} {'Score':>6} {'Gap':>7} {'RS':>7} "
          f"{'RVOL-T':>7} {'RSI':>5} {'VWAP':>6} {'Setup'}")
    print("  " + "-" * 85)

    for r in results:
        q = r["quote"]
        sym = r["symbol"]
        price = format_inr(q["ltp"])
        score = r["total_score"]
        gap = f"{r['gap_pct']:+.1f}%"
        rs = f"{r['rel_strength']:+.1f}%"

        rvol = r.get("rvol_t")
        vol_exp = r.get("vol_expansion")
        if rvol is not None:
            vol_str = f"{rvol:.1f}x"
        elif vol_exp is not None:
            vol_str = f"{vol_exp:.1f}x*"
        else:
            vol_str = "  —"

        rsi = r.get("rsi")
        rsi_str = f"{rsi:.0f}" if rsi is not None else " —"

        above_vwap = r.get("above_vwap")
        if above_vwap is True:
            vwap_str = "Above"
        elif above_vwap is False:
            vwap_str = "Below"
        else:
            vwap_str = "  —"

        setup = r.get("setup", "")

        print(f"  {sym:<12} {price:>10} {score:>6} {gap:>7} {rs:>7} "
              f"{vol_str:>7} {rsi_str:>5} {vwap_str:>6}  {setup}")

    print()
    print(f"  * = basic volume expansion (RVOL-T unavailable)")

    # News context
    if news and news.get("content"):
        print()
        print(f"  {'=' * 65}")
        print(f"  Market News Context")
        print(f"  {'=' * 65}")
        # Indent each line of the news content
        for line in news["content"].strip().split("\n"):
            print(f"  {line}")
        if news.get("citations"):
            print()
            print(f"  Sources:")
            for i, cite in enumerate(news["citations"][:5], 1):
                print(f"    [{i}] {cite}")

    print()
    print(f"  Scan completed in {elapsed:.1f}s")
    print()


