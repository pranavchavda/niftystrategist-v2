def format_json_output(
    results: list[dict],
    nifty_quote: dict | None,
    nifty_pct: float,
    elapsed: float,
    news: dict | None = None,
):
    """Format scan results as JSON."""
    output = {
        "scan_time": datetime.now().strftime("%Y-%m-%d %H:%M:%S IST"),
        "elapsed_seconds": round(elapsed, 1),
        "market_context": {
            "nifty_50": nifty_quote.get("ltp") if nifty_quote else None,
            "nifty_change_pct": nifty_pct,
        },
        "candidates": [],
    }

    if news:
        if news.get("market_overview"):
            output["market_news"] = news["market_overview"].get("content", "")
            if news["market_overview"].get("citations"):
                output["market_news_citations"] = news["market_overview"]["citations"]
        if news.get("stock_reports"):
            output["stock_news"] = [
                {
                    "symbol": sr["symbol"],
                    "analysis": sr.get("content", ""),
                    "citations": sr.get("citations", []),
                }
                for sr in news["stock_reports"]
            ]

    for r in results:
        q = r["quote"]
        candidate = {
            "symbol": r["symbol"],
            "price": q["ltp"],
            "score": r["total_score"],
            "gap_pct": r["gap_pct"],
            "rel_strength_pct": r["rel_strength"],
            "change_pct": q["pct_change"],
            "volume": q["volume"],
            "rsi": r.get("rsi"),
            "vwap": r.get("vwap"),
            "above_vwap": r.get("above_vwap"),
            "rvol_t": r.get("rvol_t"),
            "vol_expansion": r.get("vol_expansion"),
            "setup": r.get("setup"),
        }
        if r.get("opening_range"):
            candidate["opening_range"] = r["opening_range"]
        output["candidates"].append(candidate)

    print_json(output)


