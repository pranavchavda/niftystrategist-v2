def main():
    parser = argparse.ArgumentParser(
        prog="nf-morning-scan",
        description="Morning Momentum Scanner — find high-probability intraday trade candidates",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  nf-morning-scan                     Full scan, top 10 candidates
  nf-morning-scan --news              Include market news context
  nf-morning-scan --top 5             Show only top 5
  nf-morning-scan --min-score 4       Only show strong candidates
  nf-morning-scan --json              Machine-readable output
  nf-morning-scan --verbose           Show scan progress
  nf-morning-scan --debug TATAMOTORS  Debug indicators for one stock

  # Auto-deploy ORB strategy on top 3 candidates
  nf-morning-scan --auto-deploy orb --capital 50000 --top 3

  # Dry-run auto-deploy (preview only)
  nf-morning-scan --auto-deploy breakout --capital 100000 --top 5 --dry-run

Scans Nifty 500 stocks by default. Use --universe to narrow scope.

Scoring (0-8):
  Gap:     +1 (>=1%), +2 (>=2%)
  RelStr:  +1 (>=0.5% vs Nifty), +2 (>=1%)
  Volume:  +1 (RVOL-T >=1.5x), +2 (>=2x)
  RSI:     +1 (>=60 or <=40)
  VWAP:    +1 (price above VWAP)
  Align:   +1 (gap and move in same direction)

Requires NF_ACCESS_TOKEN or UPSTOX_ACCESS_TOKEN env var.
""",
    )
    parser.add_argument("--universe", choices=["nifty50", "nifty100", "nifty500"], default="nifty500",
                        help="Stock universe to scan (default: nifty500)")
    parser.add_argument("--top", type=int, default=10, metavar="N", help="Number of top candidates to show (default: 10)")
    parser.add_argument("--min-score", type=int, default=0, metavar="N", help="Minimum total score to display (default: 0)")
    parser.add_argument("--deep", type=int, default=15, metavar="N", help="Number of stocks to deep-analyze (default: 15)")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--verbose", action="store_true", help="Show scan progress to stderr")
    parser.add_argument("--debug", metavar="SYMBOL", help="Debug mode: show all indicators for one stock")
    parser.add_argument("--news", action="store_true", help="Include market news context via Perplexity Sonar API")

    # Auto-deploy options
    parser.add_argument("--auto-deploy", metavar="TEMPLATE",
                        choices=VALID_TEMPLATES,
                        help="Deploy this strategy on top candidates (orb, breakout, mean-reversion, vwap-bounce, scalp)")
    parser.add_argument("--capital", type=float, metavar="AMOUNT",
                        help="Capital per strategy deployment (required with --auto-deploy)")
    parser.add_argument("--risk-percent", type=float, default=2.0, metavar="PCT",
                        help="Risk %% per trade (default: 2.0)")
    parser.add_argument("--dry-run", action="store_true",
                        help="Preview strategy rules without creating them (used with --auto-deploy)")

    args = parser.parse_args()

    # Validate auto-deploy requirements
    if args.auto_deploy and not args.capital:
        parser.error("--capital is required when using --auto-deploy")

    try:
        results, nifty_quote, nifty_pct, elapsed = asyncio.run(
            run_scan(
                top_n=args.top,
                min_score=args.min_score,
                deep_count=args.deep,
                as_json=args.json,
                verbose=args.verbose or bool(args.debug),
                debug_symbol=args.debug,
                universe_name=args.universe,
            )
        )
    except Exception as e:
        print_error(f"Scan failed: {e}")

    # Phase 3: News context (runs after scan, doesn't slow down the core scan)
    news = None
    if args.news:
        top_symbols = [r["symbol"] for r in results[:5]]
        news = fetch_news_context(
            top_symbols, nifty_pct, verbose=args.verbose or bool(args.debug)
        )

    if args.json:
        format_json_output(results, nifty_quote, nifty_pct, elapsed, news=news)
    else:
        format_human_output(results, nifty_quote, nifty_pct, elapsed, news=news)

    # Phase 4: Auto-deploy strategies on top candidates
    if args.auto_deploy:
        deployments = auto_deploy_strategies(
            results=results,
            template=args.auto_deploy,
            capital=args.capital,
            risk_percent=args.risk_percent,
            top_n=args.top,
            dry_run=args.dry_run,
            as_json=args.json,
            verbose=args.verbose or bool(args.debug),
        )

        if args.json:
            # Re-output with deployments included — print as separate JSON object
            print_json({
                "auto_deploy": {
                    "template": args.auto_deploy,
                    "capital_per_strategy": args.capital,
                    "risk_percent": args.risk_percent,
                    "dry_run": args.dry_run,
                    "deployments": deployments,
                    "succeeded": len([d for d in deployments if "error" not in d]),
                    "failed": len([d for d in deployments if "error" in d]),
                }
            })
        else:
            format_deploy_summary(deployments, args.auto_deploy, dry_run=args.dry_run)


if __name__ == "__main__":
    main()
