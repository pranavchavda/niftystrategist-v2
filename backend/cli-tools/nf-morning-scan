            vwap_str = "  —"

        setup = r.get("setup", "")

        print(f"  {sym:<12} {price:>10} {score:>6} {gap:>7} {rs:>7} "
              f"{vol_str:>7} {rsi_str:>5} {vwap_str:>6}  {setup}")

    print()
    print(f"  * = basic volume expansion (RVOL-T unavailable)")

    # News context
    if news:
        # Market overview
        overview = news.get("market_overview")
        if overview and overview.get("content"):
            print()
            print(f"  {'=' * 65}")
            print(f"  Market Overview")
            print(f"  {'=' * 65}")
            for line in overview["content"].strip().split("\n"):
                print(f"  {line}")
            if overview.get("citations"):
                print()
                print(f"  Sources:")
                for i, cite in enumerate(overview["citations"][:5], 1):
                    print(f"    [{i}] {cite}")

        # Per-stock reports
        for sr in news.get("stock_reports", []):
            if sr.get("content"):
                print()
                print(f"  {'-' * 65}")
                print(f"  {sr['symbol']} — News & Analysis")
                print(f"  {'-' * 65}")
                for line in sr["content"].strip().split("\n"):
                    print(f"  {line}")
                if sr.get("citations"):
                    print()
                    print(f"  Sources:")
                    for i, cite in enumerate(sr["citations"][:5], 1):
                        print(f"    [{i}] {cite}")

    print()
    print(f"  Scan completed in {elapsed:.1f}s")
    print()


