# CLI entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="nf-morning-scan",
        description="Morning Momentum Scanner — find high-probability intraday trade candidates",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  nf-morning-scan                     Full scan, top 10 candidates
  nf-morning-scan --news              Include market news context
  nf-morning-scan --top 5             Show only top 5
  nf-morning-scan --min-score 4       Only show strong candidates
  nf-morning-scan --json              Machine-readable output
  nf-morning-scan --verbose           Show scan progress
  nf-morning-scan --debug TATAMOTORS  Debug indicators for one stock

Scans all Nifty 100 stocks (Nifty 50 + Nifty Next 50).

Scoring (0-8):
  Gap:     +1 (>=1%), +2 (>=2%)
  RelStr:  +1 (>=0.5% vs Nifty), +2 (>=1%)
  Volume:  +1 (RVOL-T >=1.5x), +2 (>=2x)
  RSI:     +1 (>=60 or <=40)
  VWAP:    +1 (price above VWAP)
  Align:   +1 (gap and move in same direction)

Requires NF_ACCESS_TOKEN or UPSTOX_ACCESS_TOKEN env var.
""",
    )
    parser.add_argument("--top", type=int, default=10, metavar="N", help="Number of top candidates to show (default: 10)")
    parser.add_argument("--min-score", type=int, default=0, metavar="N", help="Minimum total score to display (default: 0)")
    parser.add_argument("--deep", type=int, default=15, metavar="N", help="Number of stocks to deep-analyze (default: 15)")
    parser.add_argument("--json", action="store_true", help="Output as JSON")
    parser.add_argument("--verbose", action="store_true", help="Show scan progress to stderr")
    parser.add_argument("--debug", metavar="SYMBOL", help="Debug mode: show all indicators for one stock")
    parser.add_argument("--news", action="store_true", help="Include market news context via Perplexity Sonar API")

    args = parser.parse_args()

    try:
        results, nifty_quote, nifty_pct, elapsed = asyncio.run(
            run_scan(
                top_n=args.top,
                min_score=args.min_score,
                deep_count=args.deep,
                as_json=args.json,
                verbose=args.verbose or bool(args.debug),
                debug_symbol=args.debug,
            )
        )
    except Exception as e:
        print_error(f"Scan failed: {e}")

    # Phase 3: News context (runs after scan, doesn't slow down the core scan)
    news = None
    if args.news:
        top_symbols = [r["symbol"] for r in results[:5]]
        news = fetch_news_context(
            top_symbols, nifty_pct, verbose=args.verbose or bool(args.debug)
        )

    if args.json:
        format_json_output(results, nifty_quote, nifty_pct, elapsed, news=news)
    else:
        format_human_output(results, nifty_quote, nifty_pct, elapsed, news=news)


if __name__ == "__main__":
    main()
