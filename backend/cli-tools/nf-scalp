def cmd_delete(args):
    """Delete a scalp session."""
    from database.session import get_db_context
    from monitor import scalp_crud

    async def _delete():
        async with get_db_context() as session:
            return await scalp_crud.delete_session(session, args.session_id)

    deleted = run_async(_delete())
    if not deleted:
        print_error(f"Session #{args.session_id} not found")

    if args.json:
        print_json({"deleted": args.session_id})
    else:
        print_success(f"Session #{args.session_id} deleted")


def cmd_manual_exit(args):
    """Force session to IDLE and disable it (daemon picks up on next poll)."""
    from database.session import get_db_context
    from monitor import scalp_crud

    async def _exit():
        async with get_db_context() as session:
            return await scalp_crud.update_session(
                session, args.session_id,
                state="IDLE",
                enabled=False,
                current_option_type=None,
                current_strike=None,
                current_instrument_token=None,
                current_tradingsymbol=None,
                entry_price=None,
                entry_time=None,
                highest_premium=None,
            )

    row = run_async(_exit())
    if not row:
        print_error(f"Session #{args.session_id} not found")

    if args.json:
        print_json({"manual_exit": _session_to_dict(row)})
    else:
        print_success(f"Session #{row.id} set to IDLE and disabled: {row.name}")
        print("  The daemon will not re-enter. Re-enable manually when ready.")


def cmd_logs(args):
    """Show event log for a scalp session."""
    from database.session import get_db_context
    from monitor import scalp_crud

    async def _logs():
        async with get_db_context() as session:
            if args.session_id:
                return await scalp_crud.get_session_logs(session, args.session_id, limit=args.limit)
            else:
                user_id = _get_user_id()
                return await scalp_crud.get_user_logs(session, user_id, limit=args.limit)

    logs = run_async(_logs())

    if args.json:
        print_json({"logs": [_log_to_dict(l) for l in logs]})
        return

    if not logs:
        print("No scalp session logs found.")
        return

    header = f"Logs for Session #{args.session_id}" if args.session_id else "All Scalp Logs"
    print(f"{header}\n")
    print(f"{'ID':>5}  {'Sess':>5}  {'Event':<18}  {'Type':<4}  {'Strike':>8}  {'Entry':>8}  {'Exit':>8}  {'P&L':>10}  {'Time':<20}")
    print("-" * 110)

    for l in logs:
        time_str = _fmt_ist(l.created_at) or "?"
        ot = l.option_type or ""
        strike_str = f"{l.strike:.0f}" if l.strike else ""
        entry_str = f"{l.entry_price:.2f}" if l.entry_price else ""
        exit_str = f"{l.exit_price:.2f}" if l.exit_price else ""
        pnl_str = ""
        if l.pnl_amount is not None:
            sign = "+" if l.pnl_amount >= 0 else ""
            pnl_str = f"{sign}{l.pnl_amount:.2f}"
        print(f"{l.id:>5}  {l.session_id:>5}  {l.event_type:<18}  {ot:<4}  {strike_str:>8}  {entry_str:>8}  {exit_str:>8}  {pnl_str:>10}  {time_str:<20}")


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------


def main():
    parser = argparse.ArgumentParser(
        prog="nf-scalp",
        description="Manage scalp sessions (stateful options scalping via UT Bot signals)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Create a session
  nf-scalp create --name "NIFTY morning scalp" --underlying NIFTY \\
    --expiry 2026-04-17 --lots 1 --sl-points 20 --target-points 30 \\
    --trail-percent 15 --timeframe 1m --period 10 --sensitivity 1.0 --json

  # List sessions
  nf-scalp list --active --json

  # Show session detail + P&L + recent logs
  nf-scalp status 1 --json

  # Enable / disable
  nf-scalp enable 1
  nf-scalp disable 1

  # Force exit and disable (daemon stops managing it)
  nf-scalp manual-exit 1

  # View logs
  nf-scalp logs --session 1 --limit 30 --json
  nf-scalp logs --limit 50         # all sessions for this user

  # Delete
  nf-scalp delete 1
""",
    )

    sub = parser.add_subparsers(dest="command", help="Command")

    # ---- create ----
    p_create = sub.add_parser("create", help="Create a new scalp session")
    p_create.add_argument("--name", required=True, help="Human-readable session name")
    p_create.add_argument("--underlying", required=True,
                          help="Index underlying (NIFTY, BANKNIFTY, FINNIFTY, MIDCPNIFTY)")
    p_create.add_argument("--expiry", required=True,
                          help="Option expiry date (YYYY-MM-DD)")
    p_create.add_argument("--lots", type=int, default=1,
                          help="Number of lots per trade (default: 1)")
    p_create.add_argument("--sl-points", type=float, default=None,
                          help="Stop-loss in premium points")
    p_create.add_argument("--target-points", type=float, default=None,
                          help="Target in premium points")
    p_create.add_argument("--trail-percent", type=float, default=None,
                          help="Trailing stop percentage on premium (legacy; prefer --trail-points)")
    p_create.add_argument("--trail-points", type=float, default=None,
                          help="Trailing stop in absolute premium points (preferred over --trail-percent)")
    p_create.add_argument("--trail-arm-points", type=float, default=None,
                          help="Points of profit required before the trail activates (default: arm immediately)")
    p_create.add_argument("--timeframe", default="1m",
                          choices=["1m", "5m", "15m", "30m", "1h"],
                          help="UT Bot candle timeframe (default: 1m)")
    p_create.add_argument("--period", type=int, default=10,
                          help="UT Bot ATR period (default: 10)")
    p_create.add_argument("--sensitivity", type=float, default=1.0,
                          help="UT Bot sensitivity / key value (default: 1.0)")
    p_create.add_argument("--squareoff", default="15:15",
                          help="Auto squareoff time in HH:MM IST (default: 15:15)")
    p_create.add_argument("--max-trades", type=int, default=20,
                          help="Max trades per session day (default: 20)")
    p_create.add_argument("--cooldown", type=int, default=60,
                          help="Cooldown seconds between trades (default: 60)")
    p_create.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- list ----
    p_list = sub.add_parser("list", help="List scalp sessions")
    p_list.add_argument("--active", action="store_true",
                        help="Show only enabled sessions")
    p_list.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- status ----
    p_status = sub.add_parser("status", help="Show detail for a session")
    p_status.add_argument("session_id", type=int, help="Session ID")
    p_status.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- enable ----
    p_enable = sub.add_parser("enable", help="Enable a session")
    p_enable.add_argument("session_id", type=int, help="Session ID to enable")
    p_enable.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- disable ----
    p_disable = sub.add_parser("disable", help="Disable a session")
    p_disable.add_argument("session_id", type=int, help="Session ID to disable")
    p_disable.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- delete ----
    p_delete = sub.add_parser("delete", help="Delete a session")
    p_delete.add_argument("session_id", type=int, help="Session ID to delete")
    p_delete.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- manual-exit ----
    p_exit = sub.add_parser("manual-exit",
                            help="Force session to IDLE and disable")
    p_exit.add_argument("session_id", type=int, help="Session ID")
    p_exit.add_argument("--json", action="store_true", help="Output as JSON")

    # ---- logs ----
    p_logs = sub.add_parser("logs", help="Show event log for a session")
    p_logs.add_argument("--session", type=int, dest="session_id", default=None,
                        help="Filter by session ID (omit for all user sessions)")
    p_logs.add_argument("--limit", type=int, default=20,
                        help="Max entries (default: 20)")
    p_logs.add_argument("--json", action="store_true", help="Output as JSON")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "create":
        cmd_create(args)
    elif args.command == "list":
        cmd_list(args)
    elif args.command == "status":
        cmd_status(args)
    elif args.command == "enable":
        cmd_enable(args)
    elif args.command == "disable":
        cmd_disable(args)
    elif args.command == "delete":
        cmd_delete(args)
    elif args.command == "manual-exit":
        cmd_manual_exit(args)
    elif args.command == "logs":
        cmd_logs(args)


if __name__ == "__main__":
    main()
