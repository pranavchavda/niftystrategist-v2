def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="nf-backtest-scan",
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--universe", choices=["nifty50", "nifty100", "nifty500", "niftytotal"],
                   default="nifty500", help="Scan universe (default: nifty500)")
    p.add_argument("--top", type=int, default=25,
                   help="How many scan candidates to backtest (default: 25)")
    p.add_argument("--symbols", default=None,
                   help="Comma-separated symbols — bypasses the morning scan")
    p.add_argument("--days", type=int, default=15,
                   help="Lookback window in days (default: 15)")
    p.add_argument("--interval", default="5minute", choices=list(_INTERVAL_TO_TIMEFRAME.keys()),
                   help="Candle interval (default: 5minute)")
    p.add_argument("--indicators", default=None,
                   help=f"Comma-separated indicators (default: all). Options: {','.join(ALL_INDICATORS)}")
    p.add_argument("--min-profit-factor", type=float, default=0.0,
                   help="Filter: mark stocks untradeable if best PF below this (default: 0.0)")
    p.add_argument("--min-trades", type=int, default=5,
                   help="Trades in window for a signal to be 'adequately sampled' — "
                        "recommendation prefers these, and 'high' confidence requires it "
                        "(default: 5). Stops a 2-trade fluke outranking a robust signal.")

    # Sizing
    p.add_argument("--quantity", type=int, default=None,
                   help="Fixed share quantity for all symbols (overrides --capital-per-trade)")
    p.add_argument("--capital-per-trade", type=float, default=100_000,
                   help="Per-trade notional; quantity = capital/price (default: 100000)")

    # Exit / discipline config (uniform across the panel for fair comparison)
    p.add_argument("--trail-percent", type=float, default=1.0,
                   help="Trailing stop percent (default: 1.0)")
    p.add_argument("--sl-points", type=float, default=None, help="Stop-loss in points (optional)")
    p.add_argument("--target-points", type=float, default=None, help="Target in points (optional)")
    p.add_argument("--squareoff", default="15:09", help="Intraday squareoff HH:MM IST (default: 15:09)")
    p.add_argument("--max-trades", type=int, default=3,
                   help="Max round-trips per session day (default: 3)")
    p.add_argument("--cooldown", type=int, default=60,
                   help="Seconds between trades after an exit (default: 60)")
    p.add_argument("--entry-side", default="auto", choices=["auto", "both", "long", "short"],
                   help="Direction handling. 'auto' (default) backtests long-only AND "
                        "short-only per indicator and keeps the better, so the reported "
                        "stats match the directional config that would be deployed. "
                        "'both' runs a combined long+short config. 'long'/'short' force one side.")
    p.add_argument("--slippage-bps", type=float, default=0.0, help="Slippage haircut bps (default: 0)")

    # Performance / caching
    p.add_argument("--max-workers", type=int, default=8,
                   help="Concurrent symbol fetches (default: 8)")
    p.add_argument("--no-cache", action="store_true", help="Ignore the on-disk backtest cache")
    p.add_argument("--cache-ttl-hours", type=float, default=24.0,
                   help="Cache TTL in hours (default: 24)")

    p.add_argument("--json", action="store_true", help="Emit machine-readable JSON")
    p.add_argument("--verbose", action="store_true", help="Progress to stderr")
    return p


async def _run(args: argparse.Namespace) -> dict:
    indicators = (
        [s.strip() for s in args.indicators.split(",") if s.strip()]
        if args.indicators else list(ALL_INDICATORS)
    )
    bad = [i for i in indicators if i not in ALL_INDICATORS]
    if bad:
        print_error(f"unknown indicator(s): {', '.join(bad)}. Valid: {', '.join(ALL_INDICATORS)}")
        sys.exit(1)

    # Sourcing
    if args.symbols:
        sourced = [{"symbol": s.strip().upper(), "score": None}
                   for s in args.symbols.split(",") if s.strip()]
    else:
        sourced = _get_candidates_from_scan(args.universe, args.top, args.verbose)
    if not sourced:
        print_error("no candidates to backtest")
        sys.exit(1)
    score_by_symbol = {c["symbol"]: c["score"] for c in sourced}

    client = init_market_data_client()
    sem = asyncio.Semaphore(args.max_workers)
    tasks = [
        _scan_symbol(client, c["symbol"], indicators, args, sem, args.verbose)
        for c in sourced
    ]
    symbol_results = await asyncio.gather(*tasks)

    candidates = []
    for sr in symbol_results:
        if sr is None:
            continue
        cand = _build_candidate(
            sr["symbol"], score_by_symbol.get(sr["symbol"]),
            sr["results"], args.days, args.min_profit_factor, args.min_trades,
        )
        if cand is not None:
            candidates.append(cand)

    # Sort: untradeable to the bottom, then by confidence (high→low), then by
    # PF. Confidence-first keeps a 2-trade PF-inf fluke from topping a robust
    # high-confidence signal even though its raw PF is larger.
    _conf_rank = {"high": 0, "medium": 1, "low": 2, "none": 3}

    def _sort_key(c):
        untradeable = c["classification"] == "untradeable"
        conf = _conf_rank.get(c["recommended"]["confidence"], 3)
        pf = _pf_to_float(c["best_signal"]["profit_factor"])
        return (untradeable, conf, -pf)

    candidates.sort(key=_sort_key)

    return {
        "scan_date": date.today().isoformat(),
        "lookback_days": args.days,
        "interval": args.interval,
        "indicators": indicators,
        "candidates": candidates,
        "summary": _summarize(candidates, args.days),
    }


def main():
    args = build_parser().parse_args()
    payload = run_async(_run(args))
    if args.json:
        print_json(payload)
    else:
        _format_human(payload)


if __name__ == "__main__":
    main()
