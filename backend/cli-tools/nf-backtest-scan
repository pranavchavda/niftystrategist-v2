#!/usr/bin/env python3
"""nf-backtest-scan — signal-to-stock matching engine.

Runs a panel of scalp indicators against each candidate stock over a recent
window and ranks which indicator historically works on which stock. The output
is a *deployment plan*: per-stock best indicator, a tradeability classification,
and a confidence rating — so the morning scan (and the trader) know not just
*which* stocks to trade but *which signal* to deploy on each.

This runs the backtests **in-process** (same state machine as the live scalper,
via ``run_scalp_equity_backtest``), fetching each symbol's candles exactly once
and reusing them across all indicators. It replicates the warm-up handling of
the ``POST /api/backtest/scalp`` endpoint so stateful indicators (UTBot,
SuperTrend, HalfTrend, SSL Hybrid) are evaluated against *converged* state, not
cold — otherwise the rankings for exactly the indicators that matter would be
noise.

Usage examples:

  # Backtest the morning scan's top-10 nifty50 candidates across all indicators
  nf-backtest-scan --universe nifty50 --top 10 --days 15 --json

  # Explicit symbol list (skips the morning scan — fast, good for validation)
  nf-backtest-scan --symbols SIEMENS,PERSISTENT --days 15 --json

  # Only HalfTrend + SSL Hybrid, filter to PF >= 1.5
  nf-backtest-scan --symbols RELIANCE,INFY --indicators halftrend,ssl_hybrid \\
      --min-profit-factor 1.5
"""
from __future__ import annotations

import argparse
import asyncio
import hashlib
import json
import os
import subprocess
import sys
import time
from datetime import date, datetime, timedelta, timezone

_backend_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _backend_dir not in sys.path:
    sys.path.insert(0, _backend_dir)

from base import (  # noqa: E402
    init_market_data_client,
    print_error,
    print_json,
    run_async,
)
